# ============================================================
# TripAlfa Docker Compose Environment Configuration
# ============================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.docker.local (do NOT commit)
# 2. Fill in your actual Neon database credentials
# 3. Run: docker compose --env-file .env.docker.local -f docker-compose.local.yml up -d
#
# REQUIRED VARIABLES:
#   - NEON_DATABASE_URL (pooled connection)
#   - DIRECT_NEON_DATABASE_URL (direct connection, for migrations)
#
# ============================================================

# ------- REQUIRED: NEON CLOUD DATABASE -------
# Get these from https://console.neon.tech/app/projects
# Select your project > Connection details > Pooled connection
# Format: postgresql://user:password@project.region.neon.tech/neondb?sslmode=require

NEON_DATABASE_URL=postgresql://your_user:your_password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DIRECT_NEON_DATABASE_URL=postgresql://your_user:your_password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ------- OPTIONAL: External Service API Keys -------

# Duffel Flight API (for flight search/booking)
# Get from: https://duffel.com/developers
DUFFEL_API_KEY=your_duffel_access_token_here

# LiteAPI Hotel & Transfer API (for hotel/transfer search/booking)
# Get from: https://liteapi.travel/
LITEAPI_API_KEY=your_liteapi_sandbox_or_production_key

# Kiwi.com Integration (for flight deposits)
# Get from: https://kiwi.com/developers/
KIWI_AFFIL_ID=your_kiwi_affiliate_id_here
KIWI_API_KEY=your_kiwi_api_key_here

# Open Exchange Rates (for currency conversions)
# Get from: https://openexchangerates.org/
OPENEXCHANGERATES_API_KEY=your_openexchangerates_api_key

# ------- SERVICE CONFIGURATION -------

# JWT Secret for Service-to-Service Authentication
# Change this in production! Can be any random string.
JWT_SECRET=dev-secret-key-change-in-production

# Node Environment
NODE_ENV=development

# Logging Level (debug, info, warn, error)
LOG_LEVEL=info

# ------- PAYMENT GATEWAY (Optional) -------

# Stripe Payment Processing
STRIPE_API_KEY=sk_test_your_stripe_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# PayPal Integration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# Wise Integration (Bank Transfers)
WISE_API_KEY=your_wise_api_key
WISE_PROFILE_ID=your_wise_profile_id

# ------- STATIC DATABASE (Optional) -------
# Only needed if running database/static-db/docker-compose.yml separately

STATICDB_NAME=tripalfa_static
STATICDB_USER=staticdb_admin
STATICDB_PASSWORD=your_strong_password_here
STATICDB_PORT=5435
STATICDB_HOST=localhost

# ------- FEATURE FLAGS -------

# Enable wallet ledger audit trails
ENABLE_LEDGER_AUDIT=true

# Enable webhook signature verification
ENABLE_WEBHOOK_SIGNATURE_VERIFICATION=true

# Allow test mode operations
ALLOW_TEST_MODE=false

# ============================================================
# TROUBLESHOOTING
# ============================================================
#
# If services fail to start:
#
# 1. Check environment file is loaded:
#    docker compose --env-file .env.docker.local config | grep NEON_DATABASE_URL
#
# 2. Verify database connection:
#    docker exec tripalfa-env-validator echo "Validation service ran"
#
# 3. Check service logs:
#    docker compose -f docker-compose.local.yml logs api-gateway
#
# 4. Ensure Neon database is accessible:
#    psql "$NEON_DATABASE_URL"
#
# Contact: Check README.md or DOCKER_SETUP.md for more details
#
# ============================================================
