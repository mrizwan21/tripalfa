# ============================================
# LiteAPI Hotel Testing Configuration Template
# ============================================
# 
# To get started with hotel booking tests:
#
# 1. Copy this file: cp .env.test.example .env.test
# 2. Get your API key from: https://dashboard.liteapi.travel/auth/login
# 3. Update LITEAPI_API_KEY in .env.test with your sandbox key
# 4. Run tests: npm run test:api:liteapi
#
# DO NOT commit .env.test with real API keys!
# Add to .gitignore: echo ".env.test" >> .gitignore

# ============================================
# REQUIRED: LiteAPI Sandbox API Key
# ============================================
# Get your sandbox key from: https://dashboard.liteapi.travel
# Format: sand_xxxxxxxxxxxxx (starts with "sand_" for sandbox)
# 
# Your key will be used for all hotel booking tests
LITEAPI_API_KEY=sand_your_api_key_here

# ============================================
# API Endpoints
# ============================================
# Use these defaults unless testing against custom environment
LITEAPI_API_BASE_URL=https://api.liteapi.travel/v3.0
LITEAPI_BOOK_BASE_URL=https://book.liteapi.travel/v3.0

# ============================================
# Test Parameters
# ============================================
# City and country for hotel search
LITEAPI_TEST_CITY=Paris
LITEAPI_TEST_COUNTRY=FR

# Number of adults for booking
LITEAPI_TEST_ADULTS=2

# Optional: Specific check-in/check-out dates (format: YYYY-MM-DD)
# If not set, tests will calculate dates 30-33 days from today
# LITEAPI_TEST_CHECKIN=2026-04-01
# LITEAPI_TEST_CHECKOUT=2026-04-04

# Request timeout (milliseconds)
LITEAPI_TIMEOUT_MS=90000

# ============================================
# Debug Options
# ============================================
# Enable verbose output to see detailed request/response logs
VERBOSE=false

# Enable debug mode with additional logging
DEBUG=false
