# TripAlfa Local Development Configuration
# Copy this to .env.local and adjust values as needed

# ============================================
# Database Configuration — TWO databases
# ============================================

# 1. Application DB (Neon Cloud)
#    Contains: users, bookings, payments, notifications, wallets, etc.
#    Use the same Neon connection string for both values.
#    You can copy it from Neon dashboard directly OR from MCP output.
DATABASE_URL="postgresql://<neon_user>:<neon_password>@<neon-host>/neondb?sslmode=require"
DIRECT_DATABASE_URL="postgresql://<neon_user>:<neon_password>@<neon-direct-host>/neondb?sslmode=require"

# 2. Static Data DB (always local Docker Postgres)
#    Contains: airports, airlines, cities, hotels, destinations, amenities, etc.
#    Docker container: postgres-static on port 5433
STATIC_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/staticdatabase"

# ============================================
# Service Ports
# ============================================
# NOTE: These ports must match docker-compose.local.yml

API_GATEWAY_PORT=3000
BOOKING_SERVICE_PORT=3001
STATIC_DATA_SERVICE_PORT=3002
USER_SERVICE_PORT=3003
ORGANIZATION_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007
WALLET_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3009
RULE_ENGINE_SERVICE_PORT=3010
KYC_SERVICE_PORT=3011
MARKETING_SERVICE_PORT=3012
B2B_ADMIN_SERVICE_PORT=3020
BOOKING_ENGINE_SERVICE_PORT=3021

# ============================================
# Service URLs
# ============================================

# When running locally (not in Docker)
API_GATEWAY_URL="http://localhost:3000"
BOOKING_SERVICE_URL="http://localhost:3001"
STATIC_DATA_SERVICE_URL="http://localhost:3002"
USER_SERVICE_URL="http://localhost:3004"
ORGANIZATION_SERVICE_URL="http://localhost:3006"
PAYMENT_SERVICE_URL="http://localhost:3007"
WALLET_SERVICE_URL="http://localhost:3008"
NOTIFICATION_SERVICE_URL="http://localhost:3009"
RULE_ENGINE_SERVICE_URL="http://localhost:3010"
KYC_SERVICE_URL="http://localhost:3011"
MARKETING_SERVICE_URL="http://localhost:3012"
B2B_ADMIN_SERVICE_URL="http://localhost:3020"
BOOKING_ENGINE_SERVICE_URL="http://localhost:3021"

# When running in Docker Compose
# API_GATEWAY_URL="http://api-gateway:3000"
# BOOKING_SERVICE_URL="http://booking-service:3001"
# STATIC_DATA_SERVICE_URL="http://static-data-service:3002"
# USER_SERVICE_URL="http://user-service:3004"
# ORGANIZATION_SERVICE_URL="http://organization-service:3006"
# PAYMENT_SERVICE_URL="http://payment-service:3007"
# WALLET_SERVICE_URL="http://wallet-service:3008"
# NOTIFICATION_SERVICE_URL="http://notification-service:3009"
# RULE_ENGINE_SERVICE_URL="http://rule-engine-service:3010"
# KYC_SERVICE_URL="http://kyc-service:3011"
# MARKETING_SERVICE_URL="http://marketing-service:3012"
# B2B_ADMIN_SERVICE_URL="http://b2b-admin-service:3020"
# BOOKING_ENGINE_SERVICE_URL="http://booking-engine-service:3021"

# ============================================
# Environment & Logging
# ============================================

NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# Rate Limiting (Development - Permissive)
# ============================================

RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=5000

# ============================================
# API Keys (Optional - for external integrations)
# ============================================

API_KEY=dev_local_key_12345

# ============================================
# Duffel API Configuration (Flight Booking)
# ============================================

# Duffel API Keys for flight search and booking
# Get your keys from: https://app.duffel.com/tokens
# Sandbox key for testing - get your own from the dashboard:
DUFFEL_TEST_API_KEY=your_duffel_sandbox_key_here
DUFFEL_PROD_API_KEY=your_production_key
DUFFEL_API_VERSION=v2

# Duffel Environment: 'sandbox' or 'production'
DUFFEL_ENVIRONMENT=sandbox

# ============================================
# LITEAPI Configuration
# ============================================

# LiteAPI API Keys (Hotel data and bookings)
# Get your keys from: https://dashboard.liteapi.travel
# Sandbox key for testing - get your own from the dashboard:
LITEAPI_TEST_API_KEY=your_liteapi_sandbox_key_here
LITEAPI_PROD_API_KEY=your_production_key

# LITEAPI MCP Server Configuration
# MCP server URL: https://mcp.liteapi.travel/api/mcp?apiKey=YOUR_API_KEY
# Documentation: https://docs.liteapi.travel/reference/mcp-server
# The MCP server can be used with AI tools like Claude Desktop
LITEAPI_MCP_API_KEY=${LITEAPI_TEST_API_KEY}

# OpenWeatherMap API - Weather data for hotel locations
# Sign up at: https://openweathermap.org/api/one-call-3
VITE_OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# ============================================
# Testing & Debug
# ============================================

DEBUG=true
SHOW_SQL=false

# Development Token Bypass for KYC Service
# SECURITY WARNING: Only set this to 'true' in local development!
# NEVER enable this in production - it allows authentication bypass
# When enabled, requests with Bearer dev-token will be authenticated as dev-user
# ENABLE_DEV_TOKEN_BYPASS=true

# ============================================
# Brevo Email Service Configuration
# ============================================

# Brevo (formerly Sendinblue) API Key
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# Email sender configuration
BREVO_FROM_EMAIL=noreply@tripalfa.com
BREVO_FROM_NAME=TripAlfa
BREVO_REPLY_TO=support@tripalfa.com

# ============================================
# Kiwi.com API Configuration (Wallet Service)
# ============================================

# Kiwi.com API credentials for deposit account management
# Required for wallet-service KiwiDepositService
# Get your credentials from: https://tequila.kiwi.com/portal/
# WARNING: Never commit real API keys to version control
KIWI_AFFIL_ID=your_kiwi_affil_id_here
KIWI_API_KEY=your_kiwi_api_key_here

# Optional Kiwi configuration
KIWI_WALLET_ID=
KIWI_CURRENCY=EUR
KIWI_MIN_BALANCE=1000
