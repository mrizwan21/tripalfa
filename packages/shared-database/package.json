{
  "name": "@tripalfa/shared-database",
  "version": "1.0.0",
  "description": "Shared Prisma database client factory and connection pooling",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./repositories": {
      "import": "./dist/src/repositories/index.js",
      "types": "./dist/src/repositories/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prebuild": "pnpm run db:generate",
    "postbuild": "cp -r generated dist/generated 2>/dev/null || true",
    "dev": "tsc --watch",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:push": "prisma db push --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "clean": "rm -rf dist",
    "db:seed": "tsx prisma/seed/index.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^25.2.3",
    "bcryptjs": "^3.0.3",
    "prisma": "5.22.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
