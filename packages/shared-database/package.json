{
  "name": "@tripalfa/shared-database",
  "version": "1.0.0",
  "description": "Shared database models and types for TripAlfa microservices",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm exec tsc --watch",
    "generate": "pnpm exec prisma generate --schema ../../database/prisma/schema.prisma",
    "migrate": "pnpm exec prisma migrate dev --schema ../../database/prisma/schema.prisma",
    "studio": "pnpm exec prisma studio --schema ../../database/prisma/schema.prisma",
    "lint": "pnpm exec eslint src --ext .ts,.tsx",
    "type-check": "pnpm exec tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@prisma/adapter-neon": "^7.4.0",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@tripalfa/shared-types": "workspace:*",
    "@types/pg": "^8.16.0",
    "pg": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "prisma": "^7.4.0",
    "typescript": "^5.9.3"
  }
}