  role        String
  oldStatus   String?
  newStatus   String?
  details     Json?
  createdAt   DateTime @default(now())
}

model OfflineRequestNotificationQueue {
  id          String    @id @default(uuid())
  requestId   String
  request     OfflineChangeRequest @relation(fields: [requestId], references: [id])
  type        String
  recipient   String
  status      String    @default("PENDING")
  payload     Json?
  error       String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?
}

model SupplierHotelMapping {
