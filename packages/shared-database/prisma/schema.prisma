  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([serviceType, isActive, priority])
  @@index([taxCode])
  @@index([tenantId])
  @@index([effectiveFrom, effectiveTo])
  @@map("tax_rules")
