  salesChannels String[]

  airlineCode     String?
  airlineGroup    String?
  originCode      String?
  destinationCode String?
  marketRegion    String?
  rbdClass        String?
  journeyType     String?
  cabinClass      String?

  hotelId    String?
  hotelChain String?
  hotelStars Int?
  mealPlan   String?

