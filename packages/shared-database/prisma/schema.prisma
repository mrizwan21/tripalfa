// ============================================================
// OTA PLATFORM - UNIFIED DATABASE SCHEMA (AUTO-MERGED)
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma-client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantType {
  MASTER
  SUB_AGENT
  CORPORATE
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Tenant {
  id             String       @id @default(uuid())
  agentCode      String       @unique
  name           String
  type           TenantType   @default(SUB_AGENT)
  status         TenantStatus @default(ACTIVE)
  databaseUrl    String
  databaseSchema String

  // Hierarchy
  parentId    String?
  parent      Tenant?  @relation("AgencyHierarchy", fields: [parentId], references: [id])
  subAgencies Tenant[] @relation("AgencyHierarchy")

  // Profile
  logoUrl      String?
  contactEmail String?
  contactPhone String?
  address      String?
  city         String?
  country      String?

  // Licensing
  iataNo   String?
  officeId String?
  vatNo    String?

  // Financial
  creditLimit Float  @default(0)
  paymentType String @default("CREDIT")

  // Product Access
  accessFlights Boolean @default(true)
  accessHotels  Boolean @default(true)
  accessCars    Boolean @default(false)

  // Rights
  enableB2B2C      Boolean @default(false)
  canManageMarkups Boolean @default(true)
  canManageUsers   Boolean @default(true)

  // Cached Analytics
  cachedRevenue  Float @default(0)
  cachedBookings Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  salesChannels SalesChannelConfig[]
  apiKeys       ApiKey[]

  dateOfOperations       DateTime?
  address1               String?
  address2               String?
  address3               String?
  state                  String?
  postCode               String?
  telephone              String?
  mobile                 String?
  fax                    String?
  contactName            String?
  designation            String?
  contactMobile          String?
  websiteUrl             String?
  referredBy             String?
  remarks                String?
  language               String?   @default("English")
  salesEmail             String?
  salesPhone             String?
  salesMobile            String?
  salesContactName       String?
  bankName               String?
  bankAddress            String?
  bankSwiftCode          String?
  bankPhone              String?
  bankFax                String?
  bankAccountNo          String?
  abtaNo                 String?
  atolNo                 String?
  creditLimitAlert       Float     @default(0)
  tempCreditLimit        Float     @default(0)
  tempCreditLimitStart   DateTime?
  tempCreditLimitEnd     DateTime?
  tdsApplicable          Float     @default(0) // Percentage
  tdsExemption           Float     @default(0) // Fixed
  dailyTicketValue       Float     @default(0)
  payPeriod              String?   @default("Monthly") // Next Day, 2-3 Days, Weekly, Fortnightly, Monthly
  annualTurnover         Float     @default(0)
  reserveVolumeMonthly   Float     @default(0)
  noOfEmployees          Int       @default(0)
  noOfBranches           Int       @default(0)
  accessInsurance        Boolean   @default(false)
  accessPackages         Boolean   @default(false)
  accessSightseeing      Boolean   @default(false)
  accessTransfers        Boolean   @default(false)
  accessDynamicSearch    Boolean   @default(true)
  canManageBranches      Boolean   @default(true)
  canManageRoles         Boolean   @default(true)
  canManageCreditCards   Boolean   @default(false)
  canImportPNR           Boolean   @default(true)
  canAllowAutoTicket     Boolean   @default(true)
  canAccessIITFare       Boolean   @default(false)
  canManageSupplierCreds Boolean   @default(false)
  canManagePGCreds       Boolean   @default(false)
  showLogoOnDashboard    Boolean   @default(true)
  allowAirCanx           Boolean   @default(true)
  perfSparkline          Int[]     @default([])
  isActive               Boolean   @default(true)

  @@index([agentCode])
  @@index([status])
  @@index([type])
  @@map("tenants")
}

model User {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  username     String @unique
  email        String @unique
  passwordHash String
  name         String
  role         String @default("AGENT")

  salesChannelId     String?
  salesChannelConfig SalesChannelConfig? @relation(fields: [salesChannelId], references: [id])

  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
  @@index([email])
  @@index([username])
  @@map("users")
}

model SalesChannelConfig {
  id       String @id @default(uuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  channelCode String  @unique
  name        String
  description String?
  slug        String? @unique
  isActive    Boolean @default(true)

  markupOverride  Float?
  commissionShare Float?

  settings Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@unique([tenantId, channelCode])
  @@index([tenantId])
  @@index([channelCode])
  @@map("sales_channels")
}

model ApiKey {
  id       String  @id @default(uuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  userId   String?

  key    String   @unique
  name   String
  scopes String[]

  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  lastUsedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([tenantId])
  @@map("api_keys")
}

model AuditLog {
  id       String  @id @default(uuid())
  tenantId String?
  userId   String?

  action     String
  resource   String
  resourceId String?
  oldValue   String?
  newValue   String?
  ipAddress  String?
  userAgent  String?

  createdAt DateTime @default(now())

  timestamp DateTime @default(now())
  actorId   String?
  actorName String?
  entity    String // e.g., 'Supplier', 'TravellerProfile'
  entityId  String?
  details   String? // JSON stringified context
  severity  String   @default("INFO") // 'INFO', 'WARN', 'CRITICAL'

  @@index([tenantId, createdAt])
  @@index([action])
  @@index([userId])
  @@map("audit_logs")
}

enum SalesChannel {
  POS_DC
  POS_SA
  POS_CA
  SUBAGENT
  WEBSITE
  MOBILE
}

enum BookingStatus {
  NEW_BOOKING
  PROVISIONAL
  AUTHORIZED
  TICKETED
  DOCUMENTED
  DISPATCHED
  CANCELLED
  VOID
  REFUNDED
  REFUND_ON_HOLD
  REJECTED
}

enum SegmentStatus {
  HK
  UC
  RQ
  HX
  NO
}

enum ServiceRequestType {
  REFUND
  RESCHEDULE
  CANCEL
  CLIENT_SWITCH
}

enum ServiceRequestStatus {
  OPEN
  APPROVED
  PROCESSING
  COMPLETED
  REJECTED
}

enum DocumentType {
  TICKET
  VOUCHER
  INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
  RECEIPT
}

enum ApprovalLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LINE_MANAGER
  FINANCE_MANAGER
}

model Booking {
  id                      String         @id @default(uuid())
  bookingRef              String         @unique
  pnr                     String?
  tenantId                String
  salesChannel            SalesChannel   @default(SUBAGENT)
  agentCode               String
  service                 String
  productType             String?
  status                  BookingStatus  @default(NEW_BOOKING)
  segmentStatus           SegmentStatus?
  ticketed                Boolean        @default(false)
  dispatched              Boolean        @default(false)
  bookingDate             DateTime       @default(now())
  travelDate              String
  tripStartDate           DateTime?
  ticketDeadline          DateTime?
  issuedDate              DateTime?
  passengerName           String
  amount                  Float
  currency                String
  markup                  Float          @default(0)
  netFare                 Float
  supplierCost            Float?
  route                   String?
  hotelName               String?
  destination             String?
  passengerDob            String?
  passengerNationality    String?
  passengerPassport       String?
  passengerPassportExpiry String?
  corporateId             String?
  subagentId              String?
  enquiryId               String?
  paymentStatus           String?
  paymentMethod           String?
  paymentDate             DateTime?
  receiptNo               String?
  invoiceNo               String?
  ticketNo                String?
  lockedBy                String?
  lockedAt                DateTime?
  remarks                 String?
  amendmentHistory        Json?
  inventoryBlockId        String?
  inventoryDbUrl          String?
  workflowState           String?
  metadata                Json?           @default("{}")

  // Legacy/Service specific fields
  userId        String?
  customerEmail String?
  customerPhone String?
  serviceType   String?
  baseAmount    Float?
  totalAmount   Float?
  taxAmount     Float?
  markupAmount  Float?

  bookingSegments      Segment[]
  documents            Document[]
  statusHistory        StatusChangeLog[]
  approvals            Approval[]
  serviceRequests      ServiceRequest[]
  clientSwitchApproval ClientSwitchApproval?

  // NEW RELATIONS
  queues            BookingQueue[]
  bookingPassengers BookingPassenger[]
  invoices          Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tktLater            Boolean         @default(false)
  autoCancelScheduled Boolean         @default(false)
  balanceDueDate      DateTime?
  refundAmount        Float?
  penaltyAmount       Float?
  passengerResidency  String?
  clientSwitchBlocked Boolean         @default(false) // true after VOID/REFUND/CANX
  approvalStatus      String? // Pending, ½ Approved, Fully Approved
  refundStatus        String? // None, Pending, Processing, Processed, Failed, OnHold
  authorizationStatus String? // 'Provisional', 'Authorized', 'Rejected'
  authorizationBy     String?
  authorizedAt        DateTime?
  rejectionReason     String?
  originalBookingId   String?
  modificationDelta   Float           @default(0)
  retryCount          Int             @default(0)
  errorMessage        String?
  notifications       Json?           @default("[]")
  inventoryBlock      InventoryBlock? @relation(fields: [inventoryBlockId], references: [id])
  dispatchEvents      DispatchEvent[]

  @@index([tenantId])
  @@index([salesChannel])
  @@index([status])
  @@index([agentCode])
  @@index([bookingDate])
  @@index([corporateId])
  @@index([subagentId])
  @@map("bookings")
}

model Segment {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type              String
  gdsPnr            String?
  validatingCarrier String?
  status            SegmentStatus @default(HK)
  confirmationNo    String?
  airline           String?
  airlineCode       String?
  flightNumber      String?
  origin            String?
  destination       String?
  departureDateTime DateTime?
  arrivalDateTime   DateTime?
  class             String?
  fareBasisCode     String?
  totalStops        Int?
  airlinePnr        String?
  duration          String?
  sequenceNumber    Int           @default(0)
  segmentType       String?
  tripType          String?
  operatedBy        String?
  promoCode         String?
  hotelName         String?
  hotelChain        String?
  starCategory      Int?
  checkInDate       DateTime?
  checkOutDate      DateTime?
  noOfNights        Int?
  roomType          String?
  mealPlan          String?
  noOfRooms         Int?
  noOfOccupants     Int?
  occupantsAdults   Int?
  occupantsChildren Int?
  carSupplier       String?
  pickupLocation    String?
  dropOffLocation   String?
  pickupDateTime    DateTime?
  dropOffDateTime   DateTime?
  carType           String?
  leadDriver        String?
  supplierCurrency  String?
  fareDetails       Json?
  costing           Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplierPaymentDueDate DateTime?
  additionalReferenceNo  String?
  originAirport          String?
  destinationAirport     String?
  terminal               String?
  openSegment            Boolean   @default(false)
  rateCode               String?
  hotelAddress           String?
  cityCode               String?
  phone                  String?
  email                  String?
  cancellationDate       DateTime?
  cancellationConditions String?
  specialRequest         String?
  notes                  String?
  serviceDescription     String?
  serviceQuantity        Int?
  pickupAddress          String?
  dropOffAddress         String?
  carName                String?
  carGroup               String?
  additionalDriver       String?
  driverDob              String?
  passengerIds           Json?
  calculationMode        String? // Auto, Manual
  miscCharges            Json? // Miscellaneous/Other charges

  @@index([bookingId])
  @@index([status])
  @@index([type])
  @@map("booking_segments")
}

model Document {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type           DocumentType
  documentNo     String
  status         String       @default("Active")
  refundStatus   String?
  fareDetails    Json?
  tstDetails     Json?
  baggage        String?
  nvdNva         Json?
  ticketingDate  DateTime?
  fareType       String?
  airlineCode    String?
  voucherDetails Json?
  refundAmount   Float?
  agencyCharge   Float?
  airlineCharge  Float?
  issuedAt       DateTime?
  issuedBy       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  iataNo             String?
  checkDigit         String?
  conjunctionTickets Int? // Number of conjunction tickets
  gdsValidated       Boolean @default(false)
  refundedAmount     Float?
  nonRefundedAmount  Float?

  @@index([bookingId])
  @@index([type])
  @@index([status])
  @@map("documents")
}

model ServiceRequest {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  type   ServiceRequestType
  status ServiceRequestStatus @default(OPEN)

  requestDate    DateTime @default(now())
  requestedBy    String
  requestFrom    String?
  requestRemarks String?

  approvalDate    DateTime?
  approvedBy      String?
  approvalRemarks String?

  processedDate DateTime?
  processedBy   String?
  productType   String?

  approvals Approval[]

  lastModifiedDate DateTime @updatedAt

  @@index([bookingId])
  @@index([type, status])
  @@map("service_requests")
}

model Approval {
  id               String          @id @default(uuid())
  bookingId        String?
  booking          Booking?        @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceRequestId String?
  serviceRequest   ServiceRequest? @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  level         ApprovalLevel
  approverEmail String
  approverName  String?
  status        String        @default("Pending")
  actionDate    DateTime?
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([serviceRequestId])
  @@index([level])
  @@map("approvals")
}

model StatusChangeLog {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  fromStatus    String?
  toStatus      String
  changedBy     String
  changedByName String?
  changedAt     DateTime @default(now())
  reason        String?

  @@index([bookingId])
  @@index([changedAt])
  @@map("status_change_logs")
}

model ClientSwitchApproval {
  id        String  @id @default(uuid())
  bookingId String  @unique
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  fromCorporateId String
  toCorporateId   String
  reason          String
  status          String @default("Pending")

  level1Approver String?
  level1Status   String?
  level1Date     DateTime?
  level1Remarks  String?

  level2Approver String?
  level2Status   String?
  level2Date     DateTime?
  level2Remarks  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
  @@map("client_switch_approvals")
}

model Enquiry {
  id        String @id @default(uuid())
  enquiryId String @unique
  tenantId  String

  type          String  @default("Quote")
  corporateId   String?
  travellerId   String?
  travellerName String?
  status        String  @default("Pending")

  itineraries         Json
  approverEmails      Json
  sendToEmployeeFirst Boolean @default(false)
  quoteWithoutCost    Boolean @default(false)
  sendFareRules       Boolean @default(false)
  includeCheapest     Boolean @default(false)
  format              String  @default("PDF")
  upsertData          Json?
  remarks             String?

  createdBy      String
  assignedTo     String?
  approvedDate   DateTime?
  approverRemark String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([corporateId])
  @@index([status])
  @@map("enquiries")
}

model CorporateTraveller {
  id            String @id @default(uuid())
  tenantId      String
  employeeId    String @unique
  corporateId   String
  corporateName String

  title       String?
  firstName   String
  lastName    String
  designation String?
  department  String?
  costCenter  String?

  email String
  phone String?

  fop               String
  availableCredit   Float?
  creditLimit       Float?
  vip               Boolean @default(false)
  cip               Boolean @default(false)
  frequentFlyerNos  Json?
  preferences       Json?
  travelCoordinator String?
  last3Bookings     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([corporateId])
  @@index([email])
  @@map("corporate_travellers")
}

enum ContactType {
  CORPORATE
  SUB_AGENT
  INDIVIDUAL
  WALK_IN
}

enum ActivityType {
  BOOKING
  EMAIL
  CALL
  MEETING
  NOTE
  TASK
  REMINDER
}

model Contact {
  id        String      @id @default(uuid())
  tenantId  String
  agentCode String
  type      ContactType
  status    String      @default("Active")

  companyName String?
  firstName   String?
  lastName    String?
  designation String?
  department  String?

  email   String
  phone   String?
  mobile  String?
  fax     String?
  website String?

  address    String?
  city       String?
  userId     String?
  tier       String?
  comments   String?
  totalSpent Float?
  state      String?
  country    String?
  postCode   String?

  iataNo   String?
  officeId String?
  vatNo    String?

  creditLimit Float  @default(0)
  paymentType String @default("CREDIT")
  payPeriod   String @default("Monthly")

  frequentFlyerNos  Json?
  travelPreferences Json?
  travelPolicy      Json?

  salesChannel String?
  tags         String[]
  notes        String?

  assignedTo      String?
  lastBookingDate DateTime?
  totalBookings   Int       @default(0)
  totalSpend      Float     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  activities  Activity[]
  preferences Preference[]

  @@index([tenantId])
  @@index([type])
  @@index([email])
  @@index([status])
  @@index([salesChannel])
  @@map("contacts")
}

model Activity {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  type        ActivityType
  title       String?
  bookingId   String?
  ticketId    String?
  subject     String
  description String?
  slug        String?      @unique
  bookingRef  String?
  amount      Float?

  scheduledAt DateTime?
  completedAt DateTime?

  createdBy  String
  assignedTo String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
  @@index([type])
  @@index([scheduledAt])
  @@map("activities")
}

model Preference {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  category   String
  key        String
  value      String
  priority   Int     @default(0)
  isRequired Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId, category, key])
  @@index([contactId])
  @@index([category])
  @@map("preferences")
}

enum InventoryType {
  Flight
  Hotel
}

enum InventoryStatus {
  Active
  Depleted
  Expired
  CarryForwarded
}

enum InventoryTransactionType {
  Purchase
  Sale
  CarryForward
  Adjustment
  GroupSale
}

model InventoryBlock {
  id        String        @id @default(uuid())
  type      InventoryType
  provider  String
  reference String

  totalQuantity     Int
  availableQuantity Int
  costPerUnit       Float
  sellPricePerUnit  Float
  expiryDate        DateTime
  status            InventoryStatus @default(Active)

  parentBlockId String?
  parentBlock   InventoryBlock?  @relation("BlockCarryForward", fields: [parentBlockId], references: [id])
  childBlocks   InventoryBlock[] @relation("BlockCarryForward")

  tenantId  String?
  agentCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions InventoryTransaction[]

  bookings Booking[]

  @@index([tenantId])
  @@index([provider])
  @@index([status])
  @@index([expiryDate])
  @@index([type])
  @@map("inventory_blocks")
}

model InventoryTransaction {
  id               String         @id @default(uuid())
  inventoryBlockId String
  inventoryBlock   InventoryBlock @relation(fields: [inventoryBlockId], references: [id])

  bookingId   String?
  bookingRef  String?
  quantity    Int
  type        InventoryTransactionType
  description String?
  slug        String?                  @unique

  tenantId  String?
  agentCode String?

  createdAt DateTime @default(now())

  @@index([inventoryBlockId])
  @@index([bookingId])
  @@index([type])
  @@index([createdAt])
  @@map("inventory_transactions")
}

model InventoryAllocation {
  id               String @id @default(uuid())
  inventoryBlockId String
  bookingRef       String
  tenantId         String

  quantity      Int
  reservedUntil DateTime
  status        String    @default("Reserved")
  confirmedAt   DateTime?
  releasedAt    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([inventoryBlockId])
  @@index([bookingRef])
  @@index([tenantId])
  @@index([status])
  @@map("inventory_allocations")
}

enum NotificationChannel {
  email
  sms
  push
  in_app
}

enum NotificationPriority {
  low
  medium
  high
  urgent
}

enum NotificationStatus {
  pending
  sent
  failed
  retrying
}

model NotificationTemplate {
  id           String              @id @default(uuid())
  name         String
  code         String              @unique
  channel      NotificationChannel
  subject      String?
  bodyTemplate String
  variables    Json?

  isActive  Boolean @default(true)
  isDefault Boolean @default(false)

  tenantId  String?
  agentCode String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs NotificationLog[]

  @@index([channel])
  @@index([tenantId])
  @@map("notification_templates")
}

model NotificationLog {
  id         String                @id @default(uuid())
  templateId String?
  template   NotificationTemplate? @relation(fields: [templateId], references: [id])

  channel  NotificationChannel
  priority NotificationPriority @default(medium)
  status   NotificationStatus   @default(pending)

  to  String
  cc  String?
  bcc String?

  subject     String?
  body        String?
  attachments Json?

  tenantId   String?
  bookingRef String?
  userId     String?

  provider          String?
  providerMessageId String?
  providerError     String?

  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  nextRetryAt DateTime?
  sentAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([channel])
  @@index([tenantId])
  @@index([bookingRef])
  @@index([createdAt])
  @@index([nextRetryAt])
  @@map("notification_logs")
}

enum WalletOwnerType {
  CUSTOMER
  AGENT
  CORPORATE
  SUPPLIER
  SUB_AGENT
}

enum WalletStatus {
  ACTIVE
  SUSPENDED
  CLOSED
  PENDING_ACTIVATION
}

enum TransactionCategory {
  FLIGHT_BOOKING
  HOTEL_BOOKING
  MARKUP_EARNING
  COMMISSION_EARNING
  REFUND
  CREDIT_LIMIT
  AUTO_RELOAD
  MANUAL_ADJUSTMENT
  PAYMENT
  HOLD
}

enum HoldStatus {
  ACTIVE
  RELEASED
  CONVERTED
  EXPIRED
}

model Wallet {
  id        String          @id @default(uuid())
  walletNo  String          @unique
  ownerType WalletOwnerType @default(AGENT)
  ownerId   String
  ownerName String          @default("Default Wallet")

  balance     Float  @default(0)
  creditLimit Float  @default(0)
  currency    String @default("USD")

  autoReloadEnabled   Boolean @default(false)
  autoReloadAmount    Float?
  autoReloadThreshold Float?
  autoReloadCurrency  String? @default("USD")

  status          WalletStatus @default(ACTIVE)
  defaultCurrency String       @default("USD")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions       WalletTransaction[]
  holds              WalletHold[]
  creditLimits       AgentCreditLimit[]
  walletRefunds      WalletRefund[]
  currencyAccounts   CurrencyAccount[]
  reconciliationLogs WalletReconciliationLog[]
  corporateAccounts  CorporateAccount[]
  supplierWallets    SupplierWallet[]

  @@index([ownerType, ownerId])
  @@index([status])
  @@map("wallets")
}

model CurrencyAccount {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  currency String
  balance  Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  computedBalance  Float               @default(0) // Total balance in this currency
  availableBalance Float               @default(0) // Available for use
  blockedBalance   Float               @default(0) // On hold/reserved
  ledgerAccountId  String? // Link to double-entry ledger account
  ledgerAccount    LedgerAccount?      @relation(fields: [ledgerAccountId], references: [id])
  transactions     WalletTransaction[]

  @@unique([walletId, currency])
  @@index([currency])
  @@map("currency_accounts")
}

model WalletTransaction {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  referenceId  String
  amount       Float
  currency     String
  balanceAfter Float
  category     TransactionCategory
  status       String              @default("Completed")
  description  String

  createdAt DateTime @default(now())
  userId    String? // The user who performed the transaction
  userName  String? // The name of the user who performed the transaction

  transactionNo     String                @unique // TXN-{timestamp}-{random}
  currencyAccountId String
  currencyAccount   CurrencyAccount       @relation(fields: [currencyAccountId], references: [id], onDelete: Cascade)
  type              WalletTransactionType
  bookingId         String?
  bookingRef        String?
  paymentMethod     PaymentMethod?
  paymentReference  String? // External payment reference (e.g., Stripe charge ID)
  fxRate            Float? // Exchange rate used
  originalAmount    Float? // Original amount before conversion
  originalCurrency  String? // Original currency
  reference         String? // Internal reference
  notes             String?
  processedAt       DateTime?

  @@index([walletId])
  @@index([category])
  @@index([createdAt])
  @@index([referenceId])
  @@map("wallet_transactions")
}

model WalletHold {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  bookingRef String
  amount     Float
  currency   String
  status     HoldStatus @default(ACTIVE)
  reason     String?

  expiresAt   DateTime?
  releasedAt  DateTime?
  convertedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  holdNo            String  @unique // HOLD-{timestamp}-{random}
  currencyAccountId String
  bookingId         String?
  description       String?
  slug              String? @unique

  @@index([walletId])
  @@index([status])
  @@index([bookingRef])
  @@map("wallet_holds")
}

model AgentCreditLimit {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  creditLimit          Float     @default(0)
  tempCreditLimit      Float     @default(0)
  tempCreditLimitStart DateTime?
  tempCreditLimitEnd   DateTime?

  alertThreshold Float  @default(0)
  tdsPercentage  Float  @default(0)
  tdsExemption   Float  @default(0)
  payPeriod      String @default("Monthly")
  annualTurnover Float  @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usedCredit           Float     @default(0)
  availableCredit      Float     @default(0)
  currency             String    @default("USD")
  tempCreditStart      DateTime?
  tempCreditEnd        DateTime?
  creditAlertThreshold Float     @default(0.8) // Alert when 80% used
  status               String    @default("ACTIVE") // ACTIVE, SUSPENDED, EXCEEDED
  lastCheckedAt        DateTime  @default(now())

  @@unique([walletId])
  @@index([walletId])
  @@map("agent_credit_limits")
}

model WalletRefund {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  bookingRef     String
  originalAmount Float
  penaltyAmount  Float   @default(0)
  refundAmount   Float
  currency       String
  status         String  @default("Pending")
  reason         String?

  processedAt DateTime?
  processedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refundNo              String  @unique // REF-{timestamp}
  originalTransactionId String
  bookingId             String?
  reasonCategory        String? // CANCELLATION, ERROR, CUSTOMER_REQUEST
  notes                 String?

  @@index([walletId])
  @@index([bookingRef])
  @@index([status])
  @@map("wallet_refunds")
}

model WalletReconciliationLog {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id])

  balanceBefore  Float
  balanceAfter   Float
  adjustedAmount Float
  reason         String

  reconciledBy String
  reconciledAt DateTime @default(now())

  reconciliationDate   DateTime @default(now())
  currency             String
  systemBalance        Float // Balance according to transactions
  ledgerBalance        Float // Balance according to ledger
  discrepancy          Float // Difference
  discrepancyTolerance Float    @default(0.01) // Tolerance for rounding
  status               String   @default("PENDING") // PENDING, RECONCILED, DISCREPANCY_FOUND
  adjustmentAmount     Float?
  adjustmentReason     String?
  notes                String?
  processedBy          String?
  createdAt            DateTime @default(now())

  @@index([walletId])
  @@index([reconciledAt])
  @@map("wallet_reconciliation_logs")
}

model CorporateAccount {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  corporateId   String
  corporateName String
  billingCycle  String @default("Monthly")
  invoiceDay    Int    @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  paymentTerms       Int                @default(30) // Days to pay
  creditLimit        Float              @default(0)
  outstandingBalance Float              @default(0)
  autoInvoiceEnabled Boolean            @default(true)
  invoiceEmail       String?
  status             String             @default("ACTIVE")
  invoices           CorporateInvoice[]

  @@index([walletId])
  @@index([corporateId])
  @@map("corporate_accounts")
}

model SupplierWallet {
  id       String @id @default(uuid())
  walletId String
  wallet   Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  supplierCode String
  supplierName String
  supplierType String
  balance      Float  @default(0)
  currency     String @default("USD")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplierId         String
  settlementCycle    String               @default("MONTHLY") // DAILY, WEEKLY, MONTHLY
  settlementCurrency String               @default("USD")
  payableBalance     Float                @default(0) // Amount owed to supplier
  paidBalance        Float                @default(0)
  bankName           String?
  accountNumber      String?
  iban               String?
  swiftCode          String?
  status             String               @default("ACTIVE")
  lastSettlementDate DateTime?
  settlements        SupplierSettlement[]

  @@index([walletId])
  @@index([supplierCode])
  @@map("supplier_wallets")
}

enum MarkupValueType {
  Percentage
  Fixed
}

enum MarkupRuleLevel {
  BASE
  OVERRIDE
  EXCEPTION
}

enum CommissionSourceType {
  Airline
  HotelSupplier
  GDS
  DirectContract
}

enum CommissionType {
  Percentage
  Fixed
  Tiered
}

enum TaxValueType {
  Percentage
  Fixed
  Tiered
}

enum TaxRuleLevel {
  BASE
  OVERRIDE
  EXCEPTION
}

model MarkupRule {
