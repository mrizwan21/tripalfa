  name        String
  description String?
  slug        String?         @unique
  serviceType String
  valueType   MarkupValueType
  value       Float
  isActive    Boolean         @default(true)
  priority    Int             @default(0)
  ruleLevel   MarkupRuleLevel @default(BASE)

  salesChannels String[]

  airlineCode     String?
  airlineGroup    String?
  originCode      String?
  destinationCode String?
  marketRegion    String?
  rbdClass        String?
  journeyType     String?
  cabinClass      String?

  hotelId    String?
  hotelChain String?
  hotelStars Int?
  mealPlan   String?

  supplierCode String?
  customerId   String?
  customerType String?
  customerTier String?

  tenantId  String?
  agentCode String?

