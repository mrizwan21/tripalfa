}

model PrebookSession {
  id            String   @id @default(uuid())
  sessionId     String?  @unique
  transactionId String?  @unique // Used by LiteAPI
  flightType    String   @default("duffel")
  offerId       String?
  hotelId       String?
  price         String?
  currency      String?
  guestEmail    String?
  guestName     String?
  expiresAt     DateTime?
  status        String   @default("pending")
  bookingId     String?
  searchParams  Json?
  selectedOffer Json?
