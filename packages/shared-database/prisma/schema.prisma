  @@index([ruleId, action])
  @@index([changedAt])
  @@map("tax_rule_audit_logs")
}

model LedgerTransaction {
  id             String   @id @default(uuid())
  referenceId    String // Connects to a Booking Ref or Settlement Ref
  amount         Float
  currency       String
  runningBalance Float
  category       String // e.g., 'Flight Booking', 'Hotel Booking', 'Markup Earning'
  status         String   @default("Completed")
  description    String
  date           DateTime @default(now())
}

model DispatchEvent {
  id        String   @id @default(uuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id])
  type      String // 'email', 'download', 'issue', 'modify', 'refund'
  label     String
  status    String   @default("Success")
  recipient String?
  timestamp DateTime @default(now())
}

model ApprovalHistory {
  id            String    @id @default(uuid())
  bookingId     String
  approvalLevel Int // 1, 2, or 3
  approverEmail String
  approverName  String?
  status        String // Pending, Approved, Rejected
  actionDate    DateTime?
  remarks       String?
  createdAt     DateTime  @default(now())

  @@index([bookingId])
  @@index([approvalLevel])
}

model CommissionSharingRule {
  id               String         @id @default(uuid())
  commissionRuleId String
  commissionRule   CommissionRule @relation(fields: [commissionRuleId], references: [id], onDelete: Cascade)

  // Sharing Configuration
  shareType  String // 'Percentage', 'Fixed', 'Tiered'
  shareValue Float // Percentage or fixed amount to share

  // Recipient
  recipientType String // 'SubAgent', 'Corporate', 'DirectClient', 'Internal'
  customerId    String? // Specific customer/client ID
  customerType  String? // Customer segment
  customerTier  String? // Loyalty tier

  // Conditions
  minBookingValue Float? // Minimum booking value to qualify
  maxShareValue   Float? // Maximum share cap
  priority        Int     @default(0)
  isActive        Boolean @default(true)

  // Temporal
  effectiveFrom DateTime?
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions CommissionTransaction[]

  @@index([commissionRuleId, recipientType, isActive])
  @@index([priority])
}

model CommissionTransaction {
  id               String                 @id @default(uuid())
  bookingRef       String // Related booking reference
  commissionRuleId String
  commissionRule   CommissionRule         @relation(fields: [commissionRuleId], references: [id])
  sharingRuleId    String?
  sharingRule      CommissionSharingRule? @relation(fields: [sharingRuleId], references: [id])

  // Financial
  baseCommission Float // Total commission received from supplier
  sharedAmount   Float // Amount shared with recipient
  retainedAmount Float // Amount retained by agency
  currency       String @default("USD")

  // Recipient
  recipientType String // Who received the share
  recipientId   String? // Specific recipient ID

  // Status
  status String    @default("Pending") // 'Pending', 'Paid', 'Reversed'
  paidAt DateTime?

  // Metadata
  description String?
  slug        String?  @unique
  createdAt   DateTime @default(now())

  @@index([bookingRef, status])
  @@index([commissionRuleId])
  @@index([createdAt])
}

model TravellerProfile {
  id       String @id @default(uuid())
  tenantId String @default("default")

  // Basic Profile Information
  title         String  @default("Mr")
  firstName     String
  middleName    String?
  lastName      String
  preferredName String?
  dateOfBirth   String
  gender        String? // Male, Female, Non-Binary
  nationality   String?
  travellerType String  @default("Regular") // VIP, CIP, Regular
  username      String?
  status        String  @default("Active") // Active, Inactive

  // Contact Information (Encrypted)
  email           String? // Encrypted
  alternateEmail  String? // Encrypted
  mobile          String? // Encrypted
  alternateMobile String? // Encrypted
  phone           String? // Encrypted
  fax             String?

  // Addresses (JSON for flexibility)
  homeAddress     Json? // {streetAddress, country, state, city, suburb, postCode}
  businessAddress Json?
  deliveryAddress Json?

  // Emergency Contact (Encrypted)
  emergencyContactName     String?
  emergencyContactRelation String?
  emergencyPhone           String? // Encrypted
  emergencyEmail           String? // Encrypted

  // Profile Metadata
  noEmail Boolean @default(false)
  remarks String?

  // Encryption Metadata
  encryptionIv Json? // Stores the IV for each encrypted field

  // Multi-language Support
  preferredLanguage String? @default("en") // en, ar, fr, es, etc.

  // Compliance & Consent
  gdprConsent              Boolean   @default(false)
  gdprConsentDate          DateTime?
  dataRetentionExpiry      DateTime? // Auto-delete after this date
  marketingConsent         Boolean   @default(false)
  thirdPartySharingConsent Boolean   @default(false)

  // Third-party Integration
  externalCRMId String? // External CRM system ID
  lastSyncedAt  DateTime?
  syncStatus    String    @default("SYNCED") // SYNCED, PENDING, FAILED, ERROR

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  passports         ClientPassport[]
  visas             ClientVisa[]
  dependents        ClientDependent[]
  preferences       ClientPreferences?
  documents         ClientDocument[]
  personalCards     ClientPersonalCard[]
  associatedClients ClientAssociation[]
  communicationLogs CommunicationLog[]
  customAlerts      CustomAlert[]
  integrationLogs   IntegrationLog[]

  @@index([tenantId, status])
  @@index([email, mobile])
  @@index([travellerType])
  @@index([createdAt])
}

model ClientPassport {
  id          String           @id @default(uuid())
  travellerId String
  traveller   TravellerProfile @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  passportNumber String // Encrypted
  dateOfBirth    String
  nationality    String
  issuingCountry String
  expiryDate     String
  isPrimary      Boolean @default(false)
  status         String  @default("Active") // Active, About to Expire, Expired

  // Encryption
  encryptionIv String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([travellerId])
  @@index([expiryDate, status])
}

model ClientVisa {
  id          String           @id @default(uuid())
  travellerId String
  traveller   TravellerProfile @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  visaNumber   String // Encrypted
  country      String
  type         String? // Tourist, Business, Student, etc.
  dateOfIssue  String
  dateOfExpiry String

  // Encryption
  encryptionIv String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([travellerId])
  @@index([dateOfExpiry])
}

model ClientDependent {
  id          String           @id @default(uuid())
  travellerId String
  traveller   TravellerProfile @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  status        String  @default("Active")
  title         String?
  firstName     String
  middleName    String?
  lastName      String
  preferredName String?
  gender        String
  dateOfBirth   String
  relation      String

  // Contact (Encrypted)
  email           String? // Encrypted
  mobile          String? // Encrypted
  alternateMobile String? // Encrypted

  // Preferences (JSON)
  flightPreferences Json?
  hotelPreferences  Json?
  carPreferences    Json?

  // Passport & Visa (embedded or relation)
  passportNumber      String? // Encrypted
  passportExpiry      String?
  passportNationality String?
  visaNumber          String? // Encrypted
  visaExpiry          String?

  // Encryption
  encryptionIv Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([travellerId])
}

model ClientPreferences {
  id          String           @id @default(uuid())
  travellerId String           @unique
  traveller   TravellerProfile @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  // Flight Preferences (JSON)
  flightPreferences Json? // {longHaulSeat, shortHaulSeat, mealPreference, stopOverPreference, classPreference, preferredAirlines[], loyaltyPrograms[], osiRemarks[], interests[]}

  // Hotel Preferences (JSON)
  hotelPreferences Json? // {roomPreference, smokingPreference, starRating, facilities[], loyaltyPrograms[]}

  // Car Preferences (JSON)
  carPreferences Json? // {carType, carHireCompany, loyaltyPrograms[]}

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([travellerId])
}

model ClientDocument {
  id          String           @id @default(uuid())
  travellerId String
  traveller   TravellerProfile @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  title        String
  fileName     String
  fileSize     Int // in bytes
  fileType     String // PDF, JPG, PNG, etc.
  fileUrl      String? // Secure storage URL
  documentType String // Passport, Visa, Ticket, Receipt, Other

  // Encryption for sensitive documents
  encrypted     Boolean @default(false)
  encryptionKey String? // Reference to encrypted file key

  uploadedBy String?
  uploadedAt DateTime @default(now())

  @@index([travellerId])
  @@index([documentType])
}

model ClientPersonalCard {
  id          String           @id @default(uuid())
  travellerId String
  traveller   TravellerProfile @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  cardName        String
  cardOption      String // Credit, Debit
  cardType        String // Visa, MasterCard, Amex, etc.
  nameOnCard      String
  cardNumber      String // Encrypted - Last 4 digits only visible
  cardNumberLast4 String // Last 4 digits for display
  expiryDate      String
  product         String?

  // Encryption
  encryptionIv String?
  encrypted    Boolean @default(true)

  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([travellerId])
}

model ClientAssociation {
  id          String           @id @default(uuid())
  travellerId String
  traveller   TravellerProfile @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  associatedClientId   String // ID of associated client
  associatedClientName String
  associationType      String? // Family, Corporate, Travel Companion, etc.

  associatedAt DateTime @default(now())

  @@index([travellerId])
  @@index([associatedClientId])
}

model CustomAlert {
  id          String           @id @default(uuid())
  travellerId String
  traveller   TravellerProfile @relation(fields: [travellerId], references: [id], onDelete: Cascade)

  alertType String // PASSPORT_EXPIRY, VISA_EXPIRY, BIRTHDAY, DOCUMENT_EXPIRY, CUSTOM
  title     String
  message   String
  severity  String @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL

  triggerDate    DateTime
  isRecurring    Boolean  @default(false)
  recurrenceRule String? // Cron expression for recurring alerts

  isActive    Boolean   @default(true)
  isDismissed Boolean   @default(false)
  dismissedAt DateTime?
  dismissedBy String?

  notificationChannels Json? // ["EMAIL", "SMS", "IN_APP", "WEBHOOK"]
  metadata             Json? // Additional context

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([travellerId, isActive])
  @@index([triggerDate, severity])
}

model IntegrationLog {
  id          String            @id @default(uuid())
  travellerId String?
  traveller   TravellerProfile? @relation(fields: [travellerId], references: [id], onDelete: SetNull)

  integrationType String // CRM, GDS, LOYALTY, PAYMENT, EMAIL_SERVICE
  provider        String // Salesforce, HubSpot, Amadeus, Sabre, etc.
  operation       String // SYNC, CREATE, UPDATE, DELETE, QUERY

  requestPayload  String? // Encrypted if contains PII
  responsePayload String?
  statusCode      Int?
  errorMessage    String?

  duration      Int? // milliseconds
  syncDirection String @default("OUTBOUND") // OUTBOUND, INBOUND

  status      String    @default("PENDING") // PENDING, SUCCESS, FAILED, RETRY
  retryCount  Int       @default(0)
  nextRetryAt DateTime?

  createdAt DateTime @default(now())

  @@index([travellerId])
  @@index([integrationType, status])
  @@index([createdAt])
}

model SubUser {
  id       String @id @default(uuid())
  username String @unique
  name     String
  email    String @unique
  role     String @default("Agent") // 'Admin', 'Agent'

  // v12 Profile Details
  title           String?
  firstName       String?
  lastName        String?
  gender          String?
  language        String? @default("English")
  allowAutoTicket Boolean @default(true)

  // Address & Contact
  streetAddress String?
  city          String?
  state         String?
  postCode      String?
  telephone     String?
  mobile        String?
  remarks       String?

  creditLimit     Float    @default(0)
  availableCredit Float    @default(0)
  createdAt       DateTime @default(now())

  favorites FavoriteAsset[]
}

model Branch {
  id    String  @id @default(uuid())
  name  String
  email String?

  // v12 Address Shard
  address1   String?
  address2   String?
  address3   String?
  city       String?
  userId     String?
  tier       String?
  comments   String?
  totalSpent Float?
  state      String?
  postCode   String?
  country    String?

  // v12 Contact Cluster
  telephone     String?
  mobile        String?
  fax           String?
  contactName   String?
  contactEmail  String?
  contactMobile String?

  remark    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FavoriteAsset {
  id        String   @id @default(uuid())
  subUserId String
  subUser   SubUser  @relation(fields: [subUserId], references: [id])
  type      String // 'Flight', 'Hotel'
  assetId   String
  name      String
  details   Json
  createdAt DateTime @default(now())
}

model Supplier {
  id     String  @id @default(uuid())
  name   String
  code   String  @unique // e.g., 'SABRE', 'LITEAPI'
  type   String // 'GDS', 'Bedbank', 'NDC'
  status Boolean @default(true)

  // v12 Contact Shard
  address    String?
  city       String?
  state      String?
  postCode   String?
  country    String?
  telephone1 String?
  telephone2 String?
  mobile     String?
  fax        String?
  email      String?
  website    String?
  logoUrl    String?

  // v12 Financial Shards
  taxId         String? // General Tax ID
  panNo         String? // Permanent Account Number
  serviceTaxNo  String?
  atolNo        String? // Air Travel Organiser's Licence
  bankName      String?
  accountNumber String?
  swiftCode     String?
  rtgsCode      String?
  currency      String  @default("USD")

  // Settlement Governance
  settlementPeriod String   @default("Monthly") // 'Fortnightly', 'Monthly', 'Weekly', 'On Request'
  securityDeposit  Float    @default(0)
  contractDate     DateTime @default(now())
  financialRemarks String?

  // Governance & Alerts
  creditLimit      Float   @default(0)
  availableCredit  Float   @default(0)
  onboardingStatus String  @default("PENDING") // 'PENDING', 'AUTHORIZED', 'ACTIVE'
  loginStatus      Boolean @default(true)

  contracts SupplierContract[]
  metrics   SupplierMetric[]
  alerts    SupplierAlert[]
}

model SupplierAlert {
  id         String   @id @default(uuid())
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  type       String // 'BALANCE_LOW', 'LATENCY_HIGH', 'ERROR_RATE_HIGH'
  threshold  Float
  status     String   @default("ACTIVE") // 'ACTIVE', 'TRIGGERED', 'RESOLVED'
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SupplierContract {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  contractRef String
  startDate   DateTime
  endDate     DateTime
  terms       String?
  netMarkup   Float    @default(0)
  isActive    Boolean  @default(true)
}

model SupplierMetric {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  timestamp   DateTime @default(now())
  latencyMs   Int
  successRate Float
  errorCount  Int      @default(0)
  pnrVelocity Int      @default(0) // Bookings per hour
}

model CommunicationLog {
  id          String           @id @default(uuid())
  travellerId String
  traveller   TravellerProfile @relation(fields: [travellerId], references: [id], onDelete: Cascade)
  timestamp   DateTime         @default(now())
  type        String // 'EMAIL', 'CALL', 'SMS', 'SYSTEM'
  subject     String
  content     String?
  status      String           @default("SENT")
}

enum WalletTransactionType {
  CREDIT // Add funds
  DEBIT // Deduct funds
  HOLD // Reserve funds
  RELEASE // Release hold
  TRANSFER // Transfer between wallets
  REFUND // Refund to wallet
  FEE // Transaction fee
  ADJUSTMENT // Manual adjustment
  RECONCILIATION // Reconciliation adjustment
  AUTO_RELOAD // Automatic wallet reload
}

enum WalletTransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
  QUEUED
}

enum WalletHistoryType {
  DEPOSIT
  WITHDRAWAL
  BOOKING_DEBIT
  BOOKING_CREDIT
  REFUND
  TRANSFER_IN
  TRANSFER_OUT
  HOLD_PLACED
  HOLD_RELEASED
  ADJUSTMENT
  RECONCILIATION
  AUTO_RELOAD
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  BANK_TRANSFER
  WALLET
  CHEQUE
  ON_HOLD
  SKIP_PAYMENT
}

model CurrencyExchangeRate {
  id String @id @default(uuid())

  // Currency Pair
  baseCurrency  String // e.g., USD
  quoteCurrency String // e.g., BHD

  // Rate Information
  rate        Float // Exchange rate
  inverseRate Float // 1/rate
  source      String? // e.g., "ECB", "OpenExchangeRates", "Manual"

  // Validity
  validFrom DateTime  @default(now())
  validTo   DateTime?

  // Metadata
  isLocked  Boolean @default(false) // True if locked for a booking
  bookingId String? // If locked for a specific booking

  createdAt DateTime @default(now())

  @@unique([baseCurrency, quoteCurrency, validFrom])
  @@index([baseCurrency, quoteCurrency])
  @@index([validFrom])
}

model CorporateInvoice {
  id        String @id @default(uuid())
  invoiceNo String @unique // INV-{corporateId}-{timestamp}

  // Corporate Account Reference
  corporateAccountId String
  corporateAccount   CorporateAccount @relation(fields: [corporateAccountId], references: [id], onDelete: Cascade)

  // Invoice Details
  billingPeriodStart DateTime
  billingPeriodEnd   DateTime
  totalAmount        Float
  currency           String   @default("USD")

  // Line Items
  lineItems Json? // Array of {bookingRef, description, amount}

  // Status
  status String @default("PENDING") // PENDING, SENT, PAID, OVERDUE, CANCELLED

  // Dates
  dueDate DateTime
  sentAt  DateTime?
  paidAt  DateTime?

  // Payment
  paymentMethod    PaymentMethod?
  paymentReference String?

  // Metadata
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([corporateAccountId])
  @@index([status])
  @@index([dueDate])
}

model SupplierSettlement {
  id           String @id @default(uuid())
  settlementNo String @unique // SETT-{supplierId}-{timestamp}

  // Supplier Wallet Reference
  supplierWalletId String
  supplierWallet   SupplierWallet @relation(fields: [supplierWalletId], references: [id], onDelete: Cascade)

  // Settlement Details
  settlementPeriodStart DateTime
  settlementPeriodEnd   DateTime
  totalAmount           Float
  currency              String

  // Line Items
  lineItems Json? // Array of {bookingRef, description, amount, currency}

  // Exchange Rate (if multi-currency)
  exchangeRate  Float?
  localAmount   Float?
  localCurrency String?

  // Status
  status String @default("PENDING") // PENDING, PROCESSING, PAID, FAILED

  // Payment
  paymentMethod    PaymentMethod?
  paymentReference String?
  paidAt           DateTime?

  // Adjustments
  adjustments      Float   @default(0)
  adjustmentReason String?

  // Metadata
  notes       String?
  processedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplierWalletId])
  @@index([status])
  @@index([settlementPeriodStart])
}

model LedgerAccount {
  id          String @id @default(uuid())
  accountNo   String @unique // ACC-{type}-{number}
  accountName String
  accountType String // ASSET, LIABILITY, EQUITY, REVENUE, EXPENSE

  // Parent Account (for hierarchy)
  parentAccountId String?
  parentAccount   LedgerAccount?  @relation("LedgerHierarchy", fields: [parentAccountId], references: [id])
  childAccounts   LedgerAccount[] @relation("LedgerHierarchy")

  // Currency
  currency String @default("USD")

  // Balance
  balance     Float @default(0)
  debitTotal  Float @default(0)
  creditTotal Float @default(0)

  // Status
  isActive Boolean @default(true)

  // Metadata
  description String?
  slug        String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  currencyAccounts CurrencyAccount[]
  ledgerEntries    LedgerEntry[]

  @@index([accountType])
  @@index([currency])
  @@index([isActive])
}

model LedgerEntry {
  id      String @id @default(uuid())
  entryNo String @unique // LE-{timestamp}-{random}

  // Transaction Reference
  transactionId String?
  bookingId     String?
  bookingRef    String?

  // Double-Entry: Each transaction has 2 entries (debit and credit)
  entryType String // DEBIT or CREDIT
  amount    Float
  currency  String

  // Account
  accountId String
  account   LedgerAccount @relation(fields: [accountId], references: [id])

  // Description
  description String?
  slug        String? @unique

  // Metadata
  createdAt DateTime @default(now())

  @@index([accountId])
  @@index([bookingId])
  @@index([createdAt])
}

model FinancialEvent {
  id String @id @default(uuid())

  // Event Details
  eventType String // WALLET_CREDIT, WALLET_DEBIT, HOLD_PLACED, HOLD_RELEASED, etc.
  entity    String // Wallet, Booking, Transaction, etc.
  entityId  String

  // Financial Impact
  amount        Float
  currency      String
  balanceBefore Float?
  balanceAfter  Float?

  // Context
  metadata Json?

  // Status
  status String @default("COMPLETED")

  // Metadata
  createdAt DateTime @default(now())

  // Service alignment
  paymentMethod String?

  // Reverse relations for unified includes
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  invoiceId String?

  @@index([entity])
  @@index([entityId])
  @@index([createdAt])
  @@map("financial_events")
}

model BookingQueue {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  queueType String // 'verification', 'ticketing', 'refund', etc.
  status    String  @default("pending")
  priority  String  @default("medium")
  notes     String?
  metadata  Json? // Stores extra context (details, customerName, etc.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@index([status])
  @@map("booking_queues")
}

model BookingPassenger {
  id        String  @id @default(uuid())
  bookingId String
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  firstName     String
  lastName      String
  email         String?
  phone         String?
  passengerType String  @default("ADULT")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingId])
  @@map("booking_passengers")
}

model Invoice {
  id            String  @id @default(uuid())
  invoiceNumber String  @unique
  bookingId     String
  booking       Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  totalAmount Float
  currency    String @default("USD")
  status      String @default("PENDING")

  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  dueDate            DateTime?
  paidAt             DateTime?
  paymentMethod      String?
  paymentReference   String?

  lineItems Json? // Array of objects
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Compatibility relations
  payments FinancialEvent[]

  @@index([bookingId])
  @@index([invoiceNumber])
  @@map("invoices")
}

model DuffelOrder {
  id              String   @id @default(uuid())
  orderId         String   @unique
  bookingId       String
  clientKey       String
  pnr             String?
  status          String   @default("CREATED")
  totalAmount     Float    @default(0)
  totalCurrency   String   @default("USD")
  passengers      Json
  slices          Json
  taxAmount       Float?
  taxCurrency     String?
  ticketingStatus String?
  paymentStatus   String?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model DuffelOfferRequest {
