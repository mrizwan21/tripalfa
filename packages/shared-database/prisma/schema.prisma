model OfflineChangeRequest {
  id              String   @id @default(uuid())
  requestRef      String?  @unique
  bookingId       String
  bookingRef      String?
  requestType     String
  status          String   @default("PENDING")
  requestedBy     String?
  requestedRole   String?
  submittedBy     String?  // Legacy field support
  assignedTo      String?
  priority        String   @default("MEDIUM")
  subject         String?
  description     String?
  attachments     Json?
  internalRemarks String?
  requestDetails  Json?
  resolutionData  Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  auditLogs       OfflineRequestAuditLog[]
  notifications   OfflineRequestNotificationQueue[]
}

model OfflineRequestAuditLog {
  id          String   @id @default(uuid())
