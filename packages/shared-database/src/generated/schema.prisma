  @@map("offline_request_notification_queue")
}

model Document {
  id         String              @id @default(cuid())
  userId     String?
  bookingId  String?
  invoiceId  String?
  templateId String?
  type       String
  status     String              @default("draft")
  url        String?
  storageKey String?
  mimeType   String?
  fileSize   Int?
  expiresAt  DateTime?
  metadata   Json?
  deletedAt  DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  access     DocumentAccess[]
  retention  DocumentRetention[]
  template   DocumentTemplate?   @relation(fields: [templateId], references: [id])
  user       User?               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([bookingId])
  @@index([templateId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([userId, type, status])
  @@map("documents")
}

