{
  "name": "@tripalfa/rules",
  "version": "1.0.0",
  "description": "Centralized Rules Engine for pricing, markups, commissions, coupons, and loyalty management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "pnpm exec tsc -p tsconfig.json",
    "dev": "pnpm exec tsc -p tsconfig.json --watch",
    "lint": "pnpm exec eslint src --ext .ts,.tsx",
    "type-check": "pnpm exec tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "pricing",
    "rules",
    "markup",
    "commission",
    "coupon",
    "loyalty",
    "discount"
  ],
  "author": "TripAlfa",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^7.4.0",
    "express": "^5.0.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "typescript": "^5.9.3",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@prisma/client": "^7.4.0",
    "express": "^5.0.6"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
