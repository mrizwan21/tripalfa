{
  "name": "@tripalfa/static-data",
  "version": "1.0.0",
  "description": "Static data and reference data for TripAlfa",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./frontend-index": {
      "types": "./dist/frontend-index.d.ts",
      "import": "./dist/frontend-index.mjs",
      "require": "./dist/frontend-index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/frontend-index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/frontend-index.ts --format cjs,esm --dts --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
