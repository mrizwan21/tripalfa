{
  "name": "@tripalfa/static-data",
  "version": "1.0.0",
  "description": "Centralized static data management system for TripAlfa",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./frontend-index": {
      "import": "./dist/frontend-index.js",
      "require": "./dist/frontend-index.js",
      "types": "./dist/frontend-index.d.ts"
    }
  },
  "scripts": {
    "build": "npx tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "static-data",
    "cache",
    "fallback",
    "travel",
    "booking"
  ],
  "author": "TripAlfa Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrizwan21/tripalfa.git"
  },
  "bugs": {
    "url": "https://github.com/mrizwan21/tripalfa/issues"
  },
  "homepage": "https://github.com/mrizwan21/tripalfa#readme"
}
