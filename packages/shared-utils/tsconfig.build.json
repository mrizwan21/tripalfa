{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist",
    "rootDir": ".",
    "strict": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tripalfa/*": [
        "../../node_modules/@tripalfa/*/dist",
        "../../node_modules/@tripalfa/*"
      ]
    },
    "types": ["node"]
  },
  "include": ["index.ts", "constants.ts", "types.ts", "utils.ts", "logger.ts"],
  "exclude": ["dist", "node_modules", "hooks.ts", "api.ts"]
}
