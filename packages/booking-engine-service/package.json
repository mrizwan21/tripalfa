{
  "name": "@tripalfa/booking-engine-service",
  "version": "1.0.0",
  "description": "Booking Engine Backend Service for TripAlfa",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "pnpm dlx tsx watch src/index.ts",
    "build": "pnpm exec tsc",
    "start": "node dist/index.js",
    "lint": "pnpm exec eslint 'src/**/*.{ts,tsx}' --no-error-on-unmatched-pattern",
    "test": "pnpm exec vitest run --passWithNoTests"
  },
  "dependencies": {
    "@tripalfa/shared-database": "workspace:*",
    "@tripalfa/shared-openapi": "workspace:*",
    "@tripalfa/shared-types": "workspace:*",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.0.6",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.2.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.4"
  }
}
