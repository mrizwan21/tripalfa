{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "noCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "paths": {
      "@/*": ["src/*"],
      "@tripalfa/shared-types": ["../../packages/shared-types/src"],
      "@tripalfa/shared-types/*": ["../../packages/shared-types/src/*"],
      "@tripalfa/shared-express": ["../../packages/shared-express/src"],
      "@tripalfa/shared-express/*": ["../../packages/shared-express/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
