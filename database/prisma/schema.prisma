// ============================================

model Document {
  id         String              @id @default(cuid())
  userId     String?
  user       User?               @relation(fields: [userId], references: [id])
  bookingId  String?
  invoiceId  String?
  templateId String?
  template   DocumentTemplate?   @relation(fields: [templateId], references: [id])
  type       String
  status     String              @default("draft")
  url        String?
  storageKey String?
  mimeType   String?
  fileSize   Int?
  expiresAt  DateTime?
  metadata   Json?
  deletedAt  DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  access    DocumentAccess[]
  retention DocumentRetention[]

  @@index([userId])
  @@index([bookingId])
  @@index([templateId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@map("documents")
}

model DocumentAccess {
  id         String   @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userId     String?
  action     String
  ipAddress  String?
  userAgent  String?
  metadata   Json?
  timestamp  DateTime @default(now())

  @@index([documentId])
  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@map("document_access")
}

model DocumentRetention {
  id                String   @id @default(cuid())
  documentId        String
  document          Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  retentionDays     Int
  scheduledDeleteAt DateTime?
  isRetained        Boolean  @default(true)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([documentId])
  @@map("document_retention")
}

model DocumentTemplate {
  id           String     @id @default(cuid())
  name         String
  type         String
  version      String     @default("1.0")
  content      Json?
  htmlTemplate String?
  variables    String[]   @default([])
  isActive     Boolean    @default(true)
  metadata     Json?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  documents    Document[]

  @@unique([name, type, version])
  @@index([type])
  @@index([isActive])
  @@map("document_templates")
}

// ============================================
// DISPUTE & SETTLEMENT MODELS
// ============================================

model Dispute {
  id         String    @id @default(cuid())
  bookingId  String?
  userId     String?
  type       String
  status     String    @default("open")
  amount     Decimal   @db.Decimal(12, 2)
  currency   String    @default("USD")
  reason     String?
  resolution String?
  resolvedAt DateTime?
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@map("disputes")
}

model Settlement {
  id             String    @id @default(cuid())
  bookingId      String?
  walletId       String?
  amount         Decimal   @db.Decimal(12, 2)
  currency       String    @default("USD")
  type           String
  status         String    @default("pending")
  settlementDate DateTime?
  referenceId    String?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([bookingId])
  @@index([walletId])
  @@index([status])
  @@map("settlements")
}

// ============================================
// AUDIT & SYSTEM MODELS
// ============================================

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String?
  resourceId String?
  ipAddress  String?
  userAgent  String?
  changes    Json?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([resource])
  @@index([resourceId])
  @@index([createdAt])
  @@map("audit_logs")
}

model CircuitBreaker {
  id            String    @id @default(cuid())
  service       String
  channel       String
  state         String    @default("closed")
  failureCount  Int       @default(0)
  successCount  Int       @default(0)
  lastFailureAt DateTime?
  lastSuccessAt DateTime?
  openedAt      DateTime?
  closedAt      DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([service, channel])
  @@index([state])
  @@map("circuit_breakers")
}

// ============================================
// REFERENCE DATA (airports, airlines, destinations, etc.)
// ============================================

model Airport {
  id          String   @id @default(cuid())
  iataCode    String   @unique
  icaoCode    String?
  name        String
  city        String?
  country     String?
  countryCode String?
  timezone    String?
  latitude    Decimal? @db.Decimal(10, 6)
  longitude   Decimal? @db.Decimal(10, 6)
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([iataCode])
  @@index([city])
  @@index([countryCode])
  @@map("airports")
}

model Airline {
  id        String   @id @default(cuid())
  iataCode  String   @unique
  icaoCode  String?
  name      String
  country   String?
  logoUrl   String?
  isActive  Boolean  @default(true)
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([iataCode])
  @@map("airlines")
}

model Destination {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  type        String   @default("city")
  country     String?
  countryCode String?
  continent   String?
  latitude    Decimal? @db.Decimal(10, 6)
  longitude   Decimal? @db.Decimal(10, 6)
  imageUrl    String?
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([code])
  @@index([type])
  @@index([countryCode])
  @@map("destinations")
}

model HotelAmenity {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  category  String?
  iconUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("hotel_amenities")
}

model BoardType {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  description   String?
  includesMeals String[] @default([])
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@map("board_types")
}

model Currency {
  id       String  @id @default(cuid())
  code     String  @unique
  name     String
  symbol   String?
  decimals Int     @default(2)
  isActive Boolean @default(true)

  @@map("currencies")
}
