// ============================================
// Wallet Models (from wallet-service - raw SQL tables)
// ============================================

model Wallet {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  currency String

  balance         Decimal @default(0) @db.Decimal(15, 2)
  reservedBalance Decimal @default(0) @db.Decimal(15, 2)
  status          String  @default("active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([userId, currency])
  @@index([userId])
}

model WalletTransaction {
  id       String  @id @default(cuid())
  walletId String  @map("wallet_id")
  type     String // deposit, withdrawal, purchase, refund, transfer, commission, settlement
  flow     String? // credit, debit

  amount   Decimal @db.Decimal(15, 2)
  currency String

  payerId   String? @map("payer_id")
  payeeId   String? @map("payee_id")
  bookingId String? @map("booking_id")
  invoiceId String? @map("invoice_id")

  idempotencyKey String? @map("idempotency_key")
  status         String  @default("completed")

  description String?
  metadata    Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([walletId])
  @@index([bookingId])
  @@index([idempotencyKey])
}

model WalletLedger {
  id            String @id @default(cuid())
  transactionId String @map("transaction_id")
