  baseCurrency   String   @map("base_currency")
  targetCurrency String   @map("target_currency")
  rate           Decimal  @db.Decimal(18, 8)
  fetchedAt      DateTime @default(now()) @map("fetched_at")

  @@unique([source, baseCurrency, targetCurrency])
}

// ============================================
// Settlement & Dispute Models (from wallet-service)
// ============================================

model Settlement {
  id       String @id @default(cuid())
  walletId String @map("wallet_id")

  amount   Decimal @db.Decimal(15, 2)
  currency String

  settlementType String // automatic, manual
  status         String @default("pending") // pending, matched, disputed, completed

  referenceNumber String? @map("reference_number")
  bankReference   String? @map("bank_reference")

  reconciledAt DateTime? @map("reconciled_at")
  processedAt  DateTime? @map("processed_at")

  metadata Json?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([walletId])
  @@index([status])
}

model Dispute {
  id            String  @id @default(cuid())
  walletId      String  @map("wallet_id")
  transactionId String? @map("transaction_id")

  amount   Decimal @db.Decimal(15, 2)
  currency String

  reason String
  status String @default("open") // open, under_review, lost, won, resolved

  customerNote String? @map("customer_note")
  staffNote    String? @map("staff_note")

  resolvedAt  DateTime? @map("resolved_at")
  processedAt DateTime? @map("processed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([walletId])
  @@index([status])
}

model FxAdjustment {
  id            String  @id @default(cuid())
  settlementId  String  @map("settlement_id")
  transactionId String? @map("transaction_id")

  originalAmount  Decimal @map("original_amount") @db.Decimal(15, 2)
  convertedAmount Decimal @map("converted_amount") @db.Decimal(15, 2)
  currency        String

  adjustmentType String  @map("adjustment_type") // fx_variance, rate_change
  description    String?

  createdAt DateTime @default(now()) @map("created_at")

  @@index([settlementId])
}

model IdempotencyCache {
  id         String @id @default(cuid())
  key        String @unique @map("idempotency_key")
  response   Json
  statusCode Int    @map("status_code")

  expiresAt DateTime @map("expires_at")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
}

// ============================================
// SUPPLIER REGISTRY - Multi-Supplier Management
// ============================================

/// Registry of all integrated suppliers (Hotelbeds, LITEAPI, Duffel, etc.)
/// Registry of all integrated suppliers (Hotelbeds, LITEAPI, Duffel, etc.)
model Supplier {
  id              String   @id @default(cuid()) @map("id")
  code            String   @unique @map("code")
  name            String   @map("name")
  type            String   @map("type")
  status          Boolean  @default(true) @map("status")
  
  // API Configuration
  apiBaseUrl      String?  @map("api_base_url")
  apiKey          String?  @map("api_key") @db.Text
  apiSecret       String?  @map("api_secret") @db.Text
  apiCredentials  Json?    @map("api_credentials")
  
  // Rate Limiting
  rateLimitPerMin Int?     @map("rate_limit_per_min")
  rateLimitPerDay Int?    @map("rate_limit_per_day")
  currentUsage    Json?    @map("current_usage")
  
  // Sync Configuration
  syncEnabled     Boolean  @default(true) @map("sync_enabled")
  syncInterval    Int      @default(3600) @map("sync_interval")
  lastSyncAt      DateTime? @map("last_sync_at")
  lastSyncStatus  String?  @map("last_sync_status")
  lastSyncRecords Int?     @map("last_sync_records")
  
  // Feature Flags
  features        Json?    @map("features")
  
  // Metadata
  metadata        Json?    @map("metadata")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  // Relations
  hotelMappings   SupplierHotelMapping[]
  syncLogs        SupplierSyncLog[]
  credentials     SupplierCredential[]
  
  @@index([code])
  @@index([type])
  @@index([status])
  
  @@map("suppliers")
}

/// Multiple API credentials per supplier for rotation
model SupplierCredential {
  id              String   @id @default(cuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  // Credential Set
  name            String   // Primary, Secondary, Backup
  apiKey          String   @db.Text // Encrypted
  apiSecret       String   @db.Text // Encrypted
  
  // Usage Tracking
  usageCount      Int      @default(0)
  lastUsedAt      DateTime?
  status          String   @default("active") // active, rate_limited, expired
  
  // Rate Limit Tracking
  rateLimitResetAt DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([supplierId, name])
  @@index([supplierId])
  @@index([status])
}

/// Sync tracking for incremental imports
model SupplierSyncLog {
  id              String   @id @default(cuid())
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  
  // Sync Details
  syncType        String   // full, incremental, delta
  dataType        String   // hotels, rooms, rates, availability
  status          String   @default("pending") // pending, running, completed, failed
  
  // Progress
  totalRecords    Int      @default(0)
  processedRecords Int     @default(0)
  createdRecords  Int      @default(0)
  updatedRecords  Int      @default(0)
  failedRecords   Int      @default(0)
  
  // Timing
  startedAt       DateTime?
  completedAt     DateTime?
  durationMs      Int?
  
  // Error Tracking
  errors          Json?    // [{ record: "...", error: "..." }]
  lastError       String?
  
  // Pagination State (for incremental)
  paginationState Json?    // { lastId: "...", page: 5, totalPages: 100 }
  
  // Metadata
  metadata        Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([supplierId])
  @@index([dataType])
  @@index([status])
  @@index([createdAt])
}

// ============================================
// CANONICAL HOTEL MODELS - Unified Hotel Identity
// ============================================

/// Canonical hotel record - unified identity across all suppliers
model CanonicalHotel {
  id              String   @id @default(cuid()) @map("id")
  
  // Primary Identifiers
  canonicalCode   String?  @unique @map("canonical_code") // Internal unique code (generated)
  
  // Basic Information
  name            String @map("name")
  nameNormalized  String? @map("name_normalized") // Lowercase, for fuzzy matching
  description     String? @db.Text @map("description")
  
  // Location
  address         String? @map("address")
  addressNormalized String? @map("address_normalized")
  city            String? @map("city")
  cityCode        String? @map("city_code") // IATA city code
  state           String? @map("state")
  stateCode       String? @map("state_code")
  country         String? @map("country")
  countryCode     String? @map("country_code") // ISO 3166-1 alpha-2
  postalCode      String? @map("postal_code")
  latitude        Float? @map("latitude")
  longitude       Float? @map("longitude")
  timezone        String? @map("timezone")
  
  // Classification
  starRating      Float? @map("star_rating") // 1.0 to 5.0
  hotelType       String? @map("hotel_type") // hotel, resort, apartment, villa, boutique
  propertyType    String? @map("property_type") // From supplier classification
  
  // Chain & Brand
  chainCode       String? @map("chain_code") // MAR, HIL, IHG, etc.
  chainName       String? @map("chain_name")
  brandCode       String? @map("brand_code")
  brandName       String? @map("brand_name")
  
  // Contact
  phone           String? @map("phone")
  email           String? @map("email")
  website         String? @map("website")
  
  // Check-in/out
  checkInTime     String? @map("checkin_time")
  checkOutTime    String? @map("checkout_time")
  
  // Quality Score (computed from multiple sources)
  qualityScore    Decimal? @db.Decimal(3, 2) @map("quality_score") // 0.00 to 1.00
  confidenceScore Decimal? @db.Decimal(3, 2) @map("confidence_score") // How confident in the match
  
  // Status
  status          String? @default("active") @map("status") // active, inactive, closed, demolished
  isActive        Boolean? @default(true) @map("is_active")
  
  // Legacy fields (JSON/serialized data)
  slug            String? @map("slug")
  shortDescription String? @map("short_description")
  userRating      Decimal? @db.Decimal(3, 2) @map("user_rating")
  reviewCount     Int? @default(0) @map("review_count")
  contentScore    Int? @default(0) @map("content_score")
  primarySource   String? @map("primary_source")
  hotelTypeId     Int? @map("hotel_type_id")
  chainId         Int? @map("chain_id")
  cityId          Int? @map("city_id")
  
  // Metadata
  metadata        Json? @map("metadata")
  
  createdAt       DateTime? @default(now()) @map("created_at")
  updatedAt       DateTime? @updatedAt @map("updated_at")
  
  // Relations
  supplierMappings  SupplierHotelMapping[]
  images            HotelImage[]
  amenities         HotelAmenityMapping[]
  roomTypes         HotelRoomType[]
  descriptions      HotelDescription[]
  contacts          HotelContact[]
  reviews           HotelReview[]
  
  @@index([canonicalCode])
  @@index([city])
  @@index([countryCode])
  @@index([starRating])
  @@index([chainCode])
  @@index([status])
  @@index([isActive])
  
  @@map("canonical_hotels")
}

/// Supplier-specific hotel mapping - links supplier hotels to canonical
model SupplierHotelMapping {
  id              String   @id @default(cuid())
  canonicalHotelId String
  canonicalHotel  CanonicalHotel @relation(fields: [canonicalHotelId], references: [id], onDelete: Cascade)
  
  // Supplier Reference
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierHotelId String   // Supplier's hotel code
  supplierHotelCode String? // Alternative supplier code
  
  // Mapping Confidence
  matchType       String    @default("auto") // auto, manual, giata
  matchConfidence Decimal?  @db.Decimal(3, 2)
  matchVerifiedAt DateTime?
  matchVerifiedBy String?  // User ID who verified
  
  // Supplier-specific Data
  supplierData    Json?    // Raw supplier data snapshot
  
  // Sync Status
  lastSyncedAt    DateTime?
  syncStatus      String   @default("pending") // pending, synced, error
  
  // Status
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([supplierId, supplierHotelId])
  @@index([canonicalHotelId])
  @@index([supplierId])
  @@index([supplierHotelId])
  @@index([isActive])
  
  @@map("SupplierHotelMapping")
}

/// Hotel images from multiple suppliers (hotel-level images: exterior, lobby, pool, restaurant, etc.)
model HotelImage {
  id              String   @id @default(cuid())
  canonicalHotelId String
  canonicalHotel  CanonicalHotel @relation(fields: [canonicalHotelId], references: [id], onDelete: Cascade)
  
  // Image Source
  supplierId      String?
  supplierImageId String?
  
  // Image URLs
  url             String
  urlHash         String   // MD5 for deduplication
  thumbnailUrl    String?
  
  // Size Variant (for supplier image mapping)
  sizeVariant     String   @default("original") // thumbnail, small, medium, large, original
  width           Int?
  height          Int?
  fileSize        Int?
  
  // Multiple Size Variants (stores URLs for different sizes from supplier)
  variants        Json?    // { thumbnail: "...", small: "...", medium: "...", large: "...", original: "..." }
  
  // Image Metadata
  imageType       String?  // exterior, lobby, pool, restaurant, gym, spa, garden, etc.
  caption         String?
  captionLocalized Json?   // { en: "...", fr: "..." }
  format          String?  // jpg, png, webp
  
  // Classification (added for Mishor image classification)
  confidence      Float?   // Classification confidence score (0.00-1.00)
  classificationSource String? @default("url") // url, ai, manual
  
  // Quality & Ranking
  isPrimary       Boolean  @default(false)
  isVerified      Boolean  @default(false)
  qualityScore    Float?
  displayOrder    Int      @default(0)
  
  // Status
  status          String   @default("active") // active, inactive, broken
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([urlHash])
  @@index([canonicalHotelId])
  @@index([supplierId])
  @@index([imageType])
  @@index([isPrimary])
  @@index([sizeVariant])
}

/// Room images from multiple suppliers (room-specific images)
model RoomImage {
  id              String   @id @default(cuid())
  roomTypeId      String
  roomType        HotelRoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  
  // Image Source
  supplierId      String?
  supplierImageId String?
  
  // Image URLs
  url             String
  urlHash         String   // MD5 for deduplication
  thumbnailUrl    String?
  
  // Size Variant (for supplier image mapping)
  sizeVariant     String   @default("original") // thumbnail, small, medium, large, original
  width           Int?
  height          Int?
  fileSize        Int?
  
  // Multiple Size Variants (stores URLs for different sizes from supplier)
  variants        Json?    // { thumbnail: "...", small: "...", medium: "...", large: "...", original: "..." }
  
  // Image Metadata
  imageType       String?  // bedroom, bathroom, balcony, view, etc.
  caption         String?
  captionLocalized Json?   // { en: "...", fr: "..." }
  format          String?  // jpg, png, webp
  
  // Classification (added for Mishor image classification)
  confidence      Float?   // Classification confidence score (0.00-1.00)
  classificationSource String? @default("url") // url, ai, manual
  
  // Quality & Ranking
  isPrimary       Boolean  @default(false)
  isVerified      Boolean  @default(false)
  qualityScore    Float?
  displayOrder    Int      @default(0)
  
  // Status
  status          String   @default("active") // active, inactive, broken
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([urlHash])
  @@index([roomTypeId])
  @@index([supplierId])
  @@index([imageType])
  @@index([isPrimary])
  @@index([sizeVariant])
}

/// Hotel descriptions in multiple languages
model HotelDescription {
  id              String   @id @default(cuid())
  canonicalHotelId String
  canonicalHotel  CanonicalHotel @relation(fields: [canonicalHotelId], references: [id], onDelete: Cascade)
  
  // Language
  languageCode    String   // en, fr, de, ar, etc.
  
  // Content
  descriptionType String   // general, location, amenities, dining, etc.
  content         String   @db.Text
  
  // Source
  supplierId      String?
  
  // Status
  isPrimary       Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([canonicalHotelId, languageCode, descriptionType])
  @@index([canonicalHotelId])
  @@index([languageCode])
}

/// Hotel contact information
model HotelContact {
  id              String   @id @default(cuid())
  canonicalHotelId String
  canonicalHotel  CanonicalHotel @relation(fields: [canonicalHotelId], references: [id], onDelete: Cascade)
  
  // Contact Type
  contactType     String   // main, reservations, groups, events
  
  // Contact Details
  name            String?
  title           String?
  phone           String?
  phoneTollFree   String?
  fax             String?
  email           String?
  website         String?
  
  // Source
  supplierId      String?
  
  isPrimary       Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([canonicalHotelId])
  @@index([contactType])
}

// ============================================
// HOTEL AMENITIES - Hotel-Level Facilities
// ============================================

/// Canonical hotel amenity definitions (pool, spa, restaurant, gym, etc.)
model HotelAmenity {
  id              String   @id @default(cuid())
  code            String   @unique // POOL, SPA, RESTAURANT, GYM, etc.
  name            String
  nameLocalized   Json?    // { en: "Swimming Pool", fr: "Piscine", ar: "مسبح" }
  
  // Classification
  category        String   // Recreation, Wellness, Dining, Business, Services, Facilities
  
  // Display
  icon            String?  // Lucide icon name: Waves, Utensils, Wifi, Car, etc.
  iconType        String?  // lucide, custom, image
  isPopular       Boolean  @default(false)
  sortOrder       Int      @default(0)
  
  // Status
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  hotelMappings   HotelAmenityMapping[]
  supplierMappings HotelAmenitySupplierMapping[]
  
  @@index([code])
  @@index([category])
  @@index([isActive])
  @@index([isPopular])
}

// ============================================
// HOTEL REVIEWS - Static Review Data
// ============================================

/// Hotel reviews from various sources (stored statically in DB)
model HotelReview {
  id              String   @id @default(cuid())
  canonicalHotelId String
  canonicalHotel  CanonicalHotel @relation(fields: [canonicalHotelId], references: [id], onDelete: Cascade)
  
  // Author info
  authorName      String
  authorCountry   String?
  authorAvatar    String?
  
  // Review content
  rating          Decimal  @db.Decimal(2, 1) // 0.0 to 5.0
  title           String?
  reviewText      String?  @db.Text
  
  // Stay details
  stayDate        DateTime?
  travelerType    String?  // solo, couple, family, business, friends
  roomType        String?
  
  // Review metadata
  language        String   @default("en")
  helpfulCount    Int      @default(0)
  
  // Source tracking
  source          String   // internal, tripadvisor, booking_com, google
  sourceId        String?  // External review ID
  sourceUrl       String?
  
  // Review categories (optional breakdown)
  cleanliness     Decimal? @db.Decimal(2, 1)
  service         Decimal? @db.Decimal(2, 1)
  location        Decimal? @db.Decimal(2, 1)
  value           Decimal? @db.Decimal(2, 1)
  
  // Status
  isVerified      Boolean  @default(false)
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([canonicalHotelId])
  @@index([rating])
  @@index([source])
  @@index([isActive])
  @@index([createdAt])
  @@index([canonicalHotelId, isActive])
  
  @@map("hotel_reviews")
}

/// Mapping of hotel to hotel-level amenities
model HotelAmenityMapping {
  id              String   @id @default(cuid())
  canonicalHotelId String
  canonicalHotel  CanonicalHotel @relation(fields: [canonicalHotelId], references: [id], onDelete: Cascade)
  amenityId       String
  
  // Amenity Details
  amenity         HotelAmenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  
  // Additional Info
  isFree          Boolean  @default(true)
  description     String?
  operatingHours  String?  // "06:00-22:00"
  
  // Source
  supplierId      String?
  supplierAmenityCode String?
  
  // Verification
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([canonicalHotelId, amenityId])
  @@index([canonicalHotelId])
  @@index([amenityId])
}

/// Supplier-specific hotel amenity code mapping
model HotelAmenitySupplierMapping {
  id              String   @id @default(cuid())
  amenityId       String
  amenity         HotelAmenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  
  // Supplier Reference
  supplierId      String
  supplierCode    String   // Supplier's amenity code
  supplierName    String?  // Supplier's amenity name
  
  // Mapping Confidence
  matchConfidence Decimal? @db.Decimal(3, 2)
  isVerified      Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([supplierId, supplierCode])
  @@index([amenityId])
  @@index([supplierId])
}

// ============================================
// ROOM AMENITIES - Room-Level Facilities
// ============================================

/// Canonical room amenity definitions (WiFi, AC, TV, minibar, safe, etc.)
model RoomAmenity {
  id              String   @id @default(cuid())
  code            String   @unique // WIFI, AC, TV, MINIBAR, SAFE, etc.
  name            String
  nameLocalized   Json?    // { en: "Free Wi-Fi", fr: "Wi-Fi gratuit", ar: "واي فاي مجاني" }
  
  // Classification
  category        String   // Technology, Comfort, Bathroom, Entertainment, Security
  
  // Display
  icon            String?
  isPopular       Boolean  @default(false)
  sortOrder       Int      @default(0)
  
  // Status
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  roomMappings    RoomAmenityMapping[]
  supplierMappings RoomAmenitySupplierMapping[]
  
  @@index([code])
  @@index([category])
  @@index([isActive])
}

/// Mapping of room type to room-level amenities
model RoomAmenityMapping {
  id              String   @id @default(cuid())
  roomTypeId      String
  roomType        HotelRoomType @relation(fields: [roomTypeId], references: [id], onDelete: Cascade)
  amenityId       String
  
  // Amenity Details
  amenity         RoomAmenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  
  // Additional Info
  isFree          Boolean  @default(true)
  description     String?
  
  // Source
  supplierId      String?
  supplierAmenityCode String?
  
  // Verification
  isVerified      Boolean  @default(false)
  verifiedAt      DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([roomTypeId, amenityId])
  @@index([roomTypeId])
  @@index([amenityId])
}

/// Supplier-specific room amenity code mapping
model RoomAmenitySupplierMapping {
  id              String   @id @default(cuid())
  amenityId       String
  amenity         RoomAmenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)
  
  // Supplier Reference
  supplierId      String
  supplierCode    String   // Supplier's amenity code
  supplierName    String?  // Supplier's amenity name
  
  // Mapping Confidence
  matchConfidence Decimal? @db.Decimal(3, 2)
  isVerified      Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([supplierId, supplierCode])
  @@index([amenityId])
  @@index([supplierId])
}

// ============================================
// HOTEL ROOM TYPES & BOARD TYPES
// ============================================

/// Hotel room type definitions
model HotelRoomType {
  id              String   @id @default(cuid())
  canonicalHotelId String
  canonicalHotel  CanonicalHotel @relation(fields: [canonicalHotelId], references: [id], onDelete: Cascade)
  
  // Room Identification
  roomTypeCode    String   // Internal code
  roomTypeName    String
  
  // Room Characteristics
  bedType         String?  // king, queen, twin, double
  bedCount        Int      @default(1)
  maxOccupancy    Int      @default(2)
  maxAdults       Int      @default(2)
  maxChildren     Int      @default(0)
  roomSize        Int?     // Square meters
  
  // Room Features
  hasBalcony      Boolean  @default(false)
  hasSeaView      Boolean  @default(false)
  hasMountainView Boolean  @default(false)
  hasCityView     Boolean  @default(false)
  
  // Supplier Mapping
  supplierId      String?
  supplierRoomCode String?
  supplierRoomName String?
  
  // Status
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  roomAmenities   RoomAmenityMapping[]
  roomImages      RoomImage[]
  
  @@unique([canonicalHotelId, roomTypeCode])
  @@index([canonicalHotelId])
  @@index([supplierId])
}

/// Board type (meal plan) definitions
model BoardType {
  id              String   @id @default(cuid())
  code            String   @unique // RO, BB, HB, FB, AI, UAI
  name            String
  nameLocalized   Json?    // { en: "Bed & Breakfast", fr: "Nuit et petit-déjeuner" }
  description     String?
  
  // Meal Inclusions
  includesBreakfast Boolean @default(false)
  includesLunch     Boolean @default(false)
  includesDinner    Boolean @default(false)
  includesDrinks    Boolean @default(false)
  includesSnacks    Boolean @default(false)
  
  // Display
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  supplierMappings BoardTypeSupplierMapping[]
  
  @@index([code])
  @@index([isActive])
}

/// Supplier-specific board type mapping
model BoardTypeSupplierMapping {
  id              String   @id @default(cuid())
  boardTypeId     String
  boardType       BoardType @relation(fields: [boardTypeId], references: [id], onDelete: Cascade)
  
  // Supplier Reference
  supplierId      String
  supplierCode    String   // Supplier's board type code
  supplierName    String?
  
  // Mapping
  matchConfidence Decimal? @db.Decimal(3, 2)
  isVerified      Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([supplierId, supplierCode])
  @@index([boardTypeId])
  @@index([supplierId])
}

// ============================================
// HOTEL TYPES & CHAINS (from LiteAPI)
// ============================================

/// Hotel property types (Hotel, Apartment, Hostel, Resort, etc.)
model HotelType {
  id              Int      @id @default(autoincrement()) @map("id")
  externalId      Int?     @unique @map("external_id")
  name            String   @map("name")
  nameNormalized  String?  @map("name_normalized")
  description     String?  @map("description")
  code            String?  @map("code")
  icon            String?  @map("icon")
  sortOrder       Int?     @default(0) @map("sort_order")
  
  // Status
  isActive        Boolean  @default(true) @map("is_active")
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  
  @@index([externalId])
  @@index([name])
  @@index([isActive])
  
  @@map("hotel_types")
}

/// Hotel chains (Marriott, Hilton, Accor, etc.)
model HotelChain {
  id              String   @id @default(cuid())
  externalId      Int      @unique // LiteAPI chain ID
  name            String
  nameNormalized  String?  // Lowercase for search
  logoUrl         String?
  
  // Status
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([externalId])
  @@index([name])
  @@index([isActive])
  
  @@map("hotel_chains")
}

// ============================================
// DESTINATIONS & GEOGRAPHIC HIERARCHY
// ============================================

/// Geographic destination hierarchy
model Destination {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  nameNormalized  String?
  nameLocalized   Json?
  
  // Hierarchy
  parentId        String?
  parent          Destination?  @relation("DestinationHierarchy", fields: [parentId], references: [id])
  children        Destination[] @relation("DestinationHierarchy")
  level           Int      @default(0) // 0=country, 1=state/region, 2=city, 3=area/district
  
  // Type
  destinationType String   // country, state, city, area, airport
  
  // Location
  countryCode     String?
  countryName     String?
  stateCode       String?
  stateName       String?
  latitude        Float?
  longitude       Float?
  timezone        String?
  
  // IATA Codes
  iataCountryCode String?
  iataCityCode    String?
  iataAirportCode String?
  
  // Popularity
  popularityScore Decimal? @db.Decimal(5, 2)
  hotelCount      Int      @default(0)
  
  // Frontend display
  imageUrl        String?  // Hero image for popular destinations
  isPopular       Boolean  @default(false)
  
  // Status
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  supplierMappings DestinationSupplierMapping[]
  
  @@index([code])
  @@index([parentId])
  @@index([destinationType])
  @@index([countryCode])
  @@index([isActive])
  @@index([isPopular])
  @@index([isActive, destinationType, isPopular])
  @@index([isActive, hotelCount(sort: Desc)])
}

/// Supplier-specific destination mapping
model DestinationSupplierMapping {
  id              String   @id @default(cuid())
  destinationId   String
  destination     Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  
  // Supplier Reference
  supplierId      String
  supplierCode    String
  supplierName    String?
  
  // Mapping
  matchConfidence Decimal? @db.Decimal(3, 2)
  isVerified      Boolean  @default(false)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@unique([supplierId, supplierCode])
  @@index([destinationId])
  @@index([supplierId])
}

// ============================================
// LITEAPI Loyalty Models
// ============================================

model LoyaltyProgram {
  id            String   @id @default(cuid())
  code          String?  @unique // Duffel programme ID (for airline/hotel programmes)
  name          String   @default("TripAlfa Rewards")
  
  // Programme type (internal, airline, hotel)
  program_type  String?  @default("internal") // internal, airline, hotel
  
  // Provider info (for Duffel programmes)
  provider_code String?  // Airline IATA code or hotel chain code
  logo_url      String?  // Logo URL
  
  enabled       Boolean  @default(true)
  cashbackRate  Decimal  @db.Decimal(5, 4) // e.g., 0.03 for 3%
  
  // Settings
  minPointsForRedemption Int?
  pointsExpirationDays   Int?
  
  // Status
  status String @default("active")
  
  // For Duffel programmes
  is_active     Boolean  @default(true)
  
  metadata Json?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  guests Guest[]
  
  @@index([enabled])
  @@index([code])
  @@index([program_type])
  @@index([is_active])
}

model Guest {
  id            String        @id @default(cuid())
  externalId    String?       @unique // LITEAPI guest ID
  
  // Contact
  email         String
  firstName     String?
  lastName      String?
  phoneNumber   String?
  
  // Loyalty info
  loyaltyProgramId String?
  loyaltyProgram  LoyaltyProgram? @relation(fields: [loyaltyProgramId], references: [id])
  
  // Points
  totalPoints     Int         @default(0)
  availablePoints Int         @default(0)
  earnedPoints    Int         @default(0)
  redeemedPoints  Int         @default(0)
  cashbackEarned  Decimal?    @db.Decimal(12, 2)
  cashbackRedeemed Decimal?  @db.Decimal(12, 2)
  
  // Status
  status         String      @default("active")
  tierStatus     String?     // bronze, silver, gold, platinum
  
  // Metadata
  metadata       Json?
  
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  
  // Relations
  bookings       Booking[]
  transactions   GuestTransaction[]
  
  @@index([email])
  @@index([loyaltyProgramId])
}

model GuestTransaction {
  id          String   @id @default(cuid())
  guestId     String
  guest       Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  
  // Transaction details
  type        String   // points_earned, points_redeemed, cashback_earned, cashback_redeemed
  amount      Int      // points or cashback amount
  amountType  String   @default("points") // points, cashback
  
  // Booking reference
  bookingId   String?
  bookingRef  String?
  
  // Description
  description String?
  
  // Status
  status      String   @default("completed")
  
  metadata    Json?
  
  createdAt   DateTime @default(now())
  
  @@index([guestId])
  @@index([bookingId])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// Prebook Session (for LITEAPI checkout flow)
// ============================================

model PrebookSession {
  id            String    @id @default(cuid())
  transactionId String    @unique // LITEAPI transaction ID
  
  // Offer details
  offerId       String
  hotelId       String?
  price         Decimal   @db.Decimal(12, 2)
  currency      String    @default("USD")
  
  // Guest details
  guestEmail    String?
  guestName     String?
  
  // Expiry
  expiresAt     DateTime
  confirmedAt   DateTime?
  
  // Status
  status        String    @default("pending") // pending, confirmed, expired, cancelled
  
  // Linked booking
  bookingId     String?
  
  metadata      Json?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([offerId])
  @@index([expiresAt])
  @@index([status])
}

// ============================================
// Duffel Flight Integration Models
// ============================================

model DuffelOfferRequest {
  id                    String   @id @default(cuid())
  externalId            String   @unique // Duffel's orq_xxx ID
  
  // Search parameters
  slices                Json     // Origin/destination/departure_date
  passengers            Json     // Passenger types
  cabinClass            String?
  
  // Response metadata
  expiresAt             DateTime?
  offersCount           Int      @default(0)
  
  // Status
  status                String   @default("pending") // pending, completed, expired, failed
  
  // Metadata
  metadata              Json?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  offers                DuffelOffer[]
  
  @@index([externalId])
  @@index([status])
  @@index([createdAt])
}

model DuffelOffer {
  id                    String   @id @default(cuid())
  externalId            String   @unique // Duffel's off_xxx ID
  
  // Parent request
  offerRequestId        String
  offerRequest          DuffelOfferRequest @relation(fields: [offerRequestId], references: [id], onDelete: Cascade)
  
  // Offer details
  totalAmount           Decimal  @db.Decimal(12, 2)
  totalCurrency         String   @default("USD")
  taxAmount             Decimal? @db.Decimal(12, 2)
  
  // Airline info
  ownerName             String?
  ownerIataCode         String?
  
  // Cabin class
  cabinClass           String?
  
  // slices - full itinerary data
  slices                Json
  
  // Available services (ancillaries)
  availableServices     Json?
  
  // Conditions
  conditions            Json?
  
  // Payment requirements
  paymentRequirements   Json?
  
  // Status
  status                String   @default("available") // available, unavailable, expired
  
  // Metadata
  metadata              Json?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  orders                DuffelOrder[]
  
  @@index([offerRequestId])
  @@index([externalId])
  @@index([ownerIataCode])
  @@index([cabinClass])
  @@index([createdAt])
}

model DuffelOrder {
  id                    String   @id @default(cuid())
  externalId            String   @unique // Duffel's ord_xxx ID
  
  // Source offer
  offerId              String?
  offer                 DuffelOffer? @relation(fields: [offerId], references: [id])
  
  // Customer info
  customerEmail         String?
  customerPhone         String?
  
  // Booking reference
  bookingReference      String?   @unique // Local booking ref (links to Booking table)
  localBookingId        String?   @db.Uuid // Link to our Booking model
  
  // Financial
  baseAmount            Decimal   @db.Decimal(12, 2)
  taxAmount             Decimal   @db.Decimal(12, 2)
  totalAmount           Decimal   @db.Decimal(12, 2)
  currency              String    @default("USD")
  
  // Status
  status                String    @default("pending") // pending, confirmed, cancelled, completed
  type                  String?   // instant, hold
  
  // Trip details
  slices                Json     // Full itinerary
  passengers            Json     // Passenger details with loyalty info
  
  // Payment
  payments              Json?
  
  // Metadata
  metadata              Json?
  
  // Key events timestamps
  confirmedAt           DateTime?
  cancelledAt           DateTime?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  // Relations
  cancellations         DuffelOrderCancellation[]
  changes               DuffelOrderChange[]
  
  @@index([externalId])
  @@index([localBookingId])
  @@index([bookingReference])
  @@index([status])
  @@index([customerEmail])
  @@index([createdAt])
}

model DuffelOrderCancellation {
  id                    String   @id @default(cuid())
  externalId            String   @unique // Duffel's ore_xxx ID
  
  // Parent order
  orderId              String
  order                DuffelOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Refund details
  refundAmount          Decimal?  @db.Decimal(12, 2)
  refundCurrency        String?
  refundTo              String?   // original_form_of_payment, wallet
  
  // Status
  status                String    @default("pending") // pending, confirmed, rejected
  
  // Key events
  confirmedAt           DateTime?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([orderId])
  @@index([externalId])
  @@index([status])
  @@index([createdAt])
}

model DuffelOrderChange {
  id                    String   @id @default(cuid())
  externalId            String   @unique // Duffel's ocr_xxx ID
  
  // Parent order
  orderId              String
  order                DuffelOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Change details
  requestedChanges     Json     // What was requested (new dates/routes)
  changeOffers         Json?    // Available change offers from airlines
  
  // Selected offer
  selectedOfferId       String?
  
  // Price difference
  changeFee             Decimal?  @db.Decimal(12, 2)
  newTotal              Decimal?  @db.Decimal(12, 2)
  penalty               Decimal?  @db.Decimal(12, 2)
  
  // Status
  status                String    @default("pending") // pending, confirmed, rejected
  
  // Key events
  confirmedAt           DateTime?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([orderId])
  @@index([externalId])
  @@index([status])
  @@index([createdAt])
}

model DuffelAirlineCredit {
  id                    String   @id @default(cuid())
  externalId            String   @unique // Duffel's arc_xxx ID
  
  // Customer association
  customerId            String   @db.Uuid
  customerEmail         String?
  
  // Airline info
  airlineName           String
  airlineIataCode       String?
  
  // Credit details
  creditType            String   // miles, points
  amount                Int      @default(0)
  currency              String?  // For value-based credits
  
  // Status
  status                String   @default("active") // active, expired, transferred
  
  // Expiration
  expiresAt            DateTime?
  
  // Metadata
  metadata              Json?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@index([customerId])
  @@index([customerEmail])
  @@index([airlineIataCode])
  @@index([status])
  @@index([createdAt])
}

model DuffelWebhookEvent {
  id                    String   @id @default(cuid())
  eventId               String?  @unique // Duffel's event ID
  
  // Event details
  eventType             String   // order.created, order.updated, etc.
  
  // Resource
  resourceType          String?  // order, order_change, etc.
  resourceId            String?
  
  // Payload
  payload               Json
  
  // Processing status
  processed             Boolean  @default(false)
  processedAt           DateTime?
  error                 String?
  
  createdAt             DateTime @default(now())
  
  @@index([eventType])
  @@index([resourceType])
  @@index([resourceId])
  @@index([processed])
  @@index([createdAt])
}

// ============================================
// Rules Engine & Pricing Models
// ============================================

model MarkupRule {
  id           String   @id @default(cuid())
  companyId    String?
  name         String
  code         String   @unique
  priority     Int      @default(0)
  applicableTo String[]
  serviceTypes String[]
  markupType   String
  markupValue  Decimal  @db.Decimal(12, 2)
  minMarkup    Decimal? @db.Decimal(12, 2)
  maxMarkup    Decimal? @db.Decimal(12, 2)
  conditions   Json?
  supplierIds  String[]
  branchIds    String[]
  userIds      String[]
  isActive     Boolean  @default(true)
  validFrom    DateTime
  validTo      DateTime?
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId])
  @@index([code])
  @@index([priority])
  @@index([isActive])
}

model SupplierDeals {
  id                      String   @id @default(cuid())
  name                    String
  code                    String   @unique
  productType             String
  dealType                String
