// TripAlfa — Unified Neon Cloud Prisma Schema
// All application data lives in a single Neon database (neondb).
// The static-db (port 5433/5435) is a separate locally-deployed Docker Postgres
// containing static reference data (hotel inventory, flight data) — accessed only via pg.Pool in services.
// This schema must NOT reference the static DB — it is Neon-only.

generator client {
  provider = "prisma-client-js"
  output   = "../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  // URL is supplied at runtime via prisma.config.ts → DIRECT_DATABASE_URL / DATABASE_URL
}

// ============================================
// USER & AUTH MODELS
// ============================================

model User {
  id              String            @id @default(cuid())
  externalId      String?           @unique
  email           String            @unique
  phoneNumber     String?
  firstName       String?
  lastName        String?
  avatarUrl       String?
  companyId       String?
  company         Company?          @relation(fields: [companyId], references: [id])
  preferences     UserPreferences?
  notifications   Notification[]
  notificationTargets NotificationTarget[]
  userRoles       UserRole[]
  kycVerifications KycVerification[]
  loyalty         CustomerLoyalty?
  wallet          Wallet[]
  documents       Document[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([email])
  @@index([companyId])
  @@index([createdAt])
  @@map("users")
}

model UserPreferences {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailNotifications    Boolean  @default(true)
  smsNotifications      Boolean  @default(true)
  pushNotifications     Boolean  @default(true)
  inAppNotifications    Boolean  @default(true)
  unsubscribeCategories String[] @default([])
  marketingEmails       Boolean  @default(false)
  language              String   @default("English")
  currency              String   @default("USD")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@map("user_preferences")
}

model Role {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  permissions Json?
  isSystem    Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  userRoles   UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  companyId String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ============================================
// COMPANY & ORGANISATION MODELS
// ============================================

model Company {
  id              String            @id @default(cuid())
  name            String
  code            String?           @unique
  legalName       String?
  taxId           String?
  email           String?
  phone           String?
  website         String?
  logoUrl         String?
  industry        String?
  size            String?
  type            String            @default("b2b")
  isActive        Boolean           @default(true)
  metadata        Json?
  address         Json?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  users           User[]
  branches        Branch[]
  departments     Department[]
  designations    Designation[]
  costCenters     CostCenter[]
  campaigns       Campaign[]
  commissionRules CommissionRule[]
  markupRules     MarkupRule[]
  discountCoupons DiscountCoupon[]
  contracts       CorporateContract[]

  @@index([code])
  @@index([isActive])
  @@map("companies")
}

model Branch {
  id             String   @id @default(cuid())
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name           String
  code           String?
  address        Json?
  phone          String?
  email          String?
  isActive       Boolean  @default(true)
  isHeadquarters Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  costCenters CostCenter[]

  @@index([companyId])
  @@map("branches")
}

model Department {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  code         String?
  description  String?
  headId       String?
  parentId     String?
  parent       Department?   @relation("DeptParent", fields: [parentId], references: [id])
  children     Department[]  @relation("DeptParent")
  level        Int           @default(0)
  budget       Decimal?      @db.Decimal(12, 2)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  designations Designation[]
  costCenters  CostCenter[]

  @@index([companyId])
  @@map("departments")
}

model Designation {
  id               String       @id @default(cuid())
  companyId        String
  company          Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId     String?
  department       Department?  @relation(fields: [departmentId], references: [id])
  name             String
  level            Int          @default(0)
  description      String?
  responsibilities String[]     @default([])
  requirements     String[]     @default([])
  salaryRange      Json?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([companyId])
  @@map("designations")
}

model CostCenter {
  id           String      @id @default(cuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  branchId     String?
  branch       Branch?     @relation(fields: [branchId], references: [id])
  name         String
  code         String?
  description  String?
  budget       Decimal?    @db.Decimal(12, 2)
  currency     String      @default("USD")
  managerId    String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([companyId])
  @@map("cost_centers")
}

// ============================================
// KYC MODELS
// ============================================

model KycVerification {
  id                     String    @id @default(cuid())
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  documentType           String
  documentNumber         String
  documentFront          String?
  documentBack           String?
  selfie                 String?
  firstName              String
  lastName               String
  dateOfBirth            DateTime?
  nationality            String?
  address                Json?
  status                 String    @default("pending")
  submittedAt            DateTime  @default(now())
  reviewedAt             DateTime?
  reviewedBy             String?
  rejectionReason        String?
  notes                  String?
  expiresAt              DateTime?
  previousVerificationId String?
  metadata               Json?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@map("kyc_verifications")
}

// ============================================
// NOTIFICATION MODELS
// ============================================

model Notification {
  id               String    @id @default(cuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId          String?
  bookingId        String?
  notificationType String
  priority         String    @default("medium")
  status           String    @default("pending")
  channels         String[]
  content          Json
  contentHash      String?
  metadata         Json?
  tags             String[]  @default([])
  sentAt           DateTime?
  deliveredAt      DateTime?
  openedAt         DateTime?
  clickedAt        DateTime?
  failedAt         DateTime?
  failureReason    String?
  failureDetails   Json?
  providerMessageIds Json?
  retryCount       Int       @default(0)
  maxRetries       Int       @default(5)
  nextRetryAt      DateTime?
  isDLQ            Boolean   @default(false)
  dlqReason        String?
  dlqMovedAt       DateTime?
  dlqReplays       Int       @default(0)
  opened           Boolean   @default(false)
  clicked          Boolean   @default(false)
  dismissed        Boolean   @default(false)
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  channelStatuses  ChannelStatus[]
  deadLetters      DeadLetterQueue[]
  retryAttempts    NotificationRetry[]
  analyticsEvents  NotificationAnalytics[]
  webhookEvents    WebhookEvent[]

  @@index([userId])
  @@index([orderId])
  @@index([bookingId])
  @@index([notificationType])
  @@index([status])
  @@index([createdAt])
  @@index([isDLQ])
  @@map("notifications")
}

model ChannelStatus {
  id                  String       @id @default(cuid())
  notificationId      String       @unique
  notification        Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  email               String       @default("pending")
  sms                 String       @default("pending")
  push                String       @default("pending")
  in_app              String       @default("pending")
  email_sent_at       DateTime?
  sms_sent_at         DateTime?
  push_sent_at        DateTime?
  in_app_sent_at      DateTime?
  email_delivered_at  DateTime?
  sms_delivered_at    DateTime?
  push_delivered_at   DateTime?
  in_app_delivered_at DateTime?
  email_opened_at     DateTime?
  sms_opened_at       DateTime?
  push_opened_at      DateTime?
  in_app_opened_at    DateTime?
  email_clicked_at    DateTime?
  push_clicked_at     DateTime?
  email_error         String?
  sms_error           String?
  push_error          String?
  in_app_error        String?
  email_message_id    String?
  sms_message_id      String?
  push_message_id     String?
  in_app_message_id   String?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@map("channel_statuses")
}

model NotificationTemplate {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  category      String   @default("general")
  description   String?
  templates     Json?
  emailTemplate Json?
  smsTemplate   Json?
  pushTemplate  Json?
  inAppTemplate Json?
  variables     String[] @default([])
  enabled       Boolean  @default(true)
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([slug])
  @@index([category])
  @@index([enabled])
  @@map("notification_templates")
}

model NotificationRetry {
  id               String       @id @default(cuid())
  notificationId   String
  notification     Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  attempt          Int
  maxAttempts      Int          @default(5)
  failureReason    String?
  scheduledRetryAt DateTime?
  actualRetryAt    DateTime?
  delayMs          Int          @default(1000)
  channel          String
  status           String       @default("pending")
  providerResponse Json?
  errorDetails     Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([notificationId])
  @@index([status])
  @@index([scheduledRetryAt])
  @@map("notification_retries")
}

model NotificationAnalytics {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  channel        String
  event          String
  timestamp      DateTime     @default(now())
  createdAt      DateTime     @default(now())
  metadata       Json?
  providerId     String?
  providerStatus String?

  @@index([notificationId])
  @@index([channel])
  @@index([event])
  @@index([timestamp])
  @@map("notification_analytics")
}

model NotificationMetrics {
  id               String   @id @default(cuid())
  date             DateTime
  channel          String
  notificationType String
  sent             Int      @default(0)
  delivered        Int      @default(0)
  opened           Int      @default(0)
  clicked          Int      @default(0)
  failed           Int      @default(0)
  bounced          Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([date, channel, notificationType])
  @@index([date])
  @@index([channel])
  @@map("notification_metrics")
}

model ScheduledNotification {
  id               String   @id @default(cuid())
  userId           String
  jobId            String   @unique
  notificationType String
  scheduledTime    DateTime
  payload          Json?
  status           String   @default("pending")
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([scheduledTime])
  @@index([active])
  @@map("scheduled_notifications")
}

model NotificationTarget {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  targetType String
  target     String
  verified   Boolean  @default(false)
  verifiedAt DateTime?
  preferred  Boolean  @default(false)
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, target])
  @@index([userId])
  @@index([targetType])
  @@map("notification_targets")
}

model DeadLetterQueue {
  id             String       @id @default(cuid())
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  reason         String
  status         String       @default("pending")
  movedAt        DateTime     @default(now())
  originalError  String?
  errorDetails   Json?
  replayCount    Int          @default(0)
  lastReplayAt   DateTime?
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([notificationId])
  @@index([reason])
  @@index([status])
  @@index([movedAt])
  @@map("dead_letter_queue")
}

model WebhookEvent {
  id              String        @id @default(cuid())
  notificationId  String?
  notification    Notification? @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  supplierId      String?
  externalEventId String?
  eventType       String
  provider        String
  payload         Json?
  responseStatus  Int?
  responseBody    String?
  processed       Boolean       @default(false)
  processedAt     DateTime?
  createdAt       DateTime      @default(now())

  @@index([notificationId])
  @@index([supplierId])
  @@index([externalEventId])
  @@index([eventType])
  @@index([provider])
  @@index([processed])
  @@map("webhook_events")
}

// ============================================
// RULE ENGINE MODELS
// ============================================

model Rule {
  id                  String         @id @default(cuid())
  name                String
  description         String?
  category            String         @default("general")
  trigger             String         @default("event")
  triggerEvent        String?
  condition           Json
  actions             Json
  priority            Int            @default(50)
  status              String         @default("draft")
  enabled             Boolean        @default(false)
  version             Int            @default(1)
  timeout             Int?           @default(30000)
  maxRetries          Int            @default(3)
  asyncExecution      Boolean        @default(false)
  metadata            Json?
  tags                String[]
  totalExecutions     Int            @default(0)
  successCount        Int            @default(0)
  failureCount        Int            @default(0)
  lastExecutionAt     DateTime?
  lastExecutionStatus String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  executions          RuleExecution[]
  analyses            RuleAnalysis[]

  @@index([category])
  @@index([status])
  @@index([enabled])
  @@index([triggerEvent])
  @@map("rules")
}

model RuleExecution {
  id              String   @id @default(cuid())
  ruleId          String
  status          String   @default("pending")
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  duration        Int?
  inputData       Json?
  outputData      Json?
  conditionMet    Boolean  @default(false)
  conditionEval   Json?
  actionsExecuted Json?
  error           String?
  errorStack      String?
  retryCount      Int      @default(0)
  userId          String?
  bookingId       String?
  sessionId       String?
  createdAt       DateTime @default(now())
  rule            Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([status])
  @@index([userId])
  @@index([bookingId])
  @@index([startedAt])
  @@map("rule_executions")
}

model RuleAnalysis {
  id              String   @id @default(cuid())
  ruleId          String
  riskLevel       String   @default("low")
  conflictCount   Int      @default(0)
  conflicts       Json?
  performance     Json?
  recommendations Json?
  createdAt       DateTime @default(now())
  rule            Rule     @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@map("rule_analyses")
}

// ============================================
// BOOKING MODELS
// ============================================

model Booking {
  id              String   @id @default(cuid())
  bookingRef      String   @unique
  userId          String
  serviceType     String
  status          String   @default("pending")
  workflowState   String   @default("pending")
  paymentStatus   String   @default("pending")
  customerEmail   String?
  customerPhone   String?
  baseAmount      Decimal  @db.Decimal(12, 2)
  taxAmount       Decimal  @db.Decimal(12, 2) @default(0)
  markupAmount    Decimal  @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal  @db.Decimal(12, 2)
  currency        String   @default("USD")
  travelDate      DateTime?
  returnDate      DateTime?
  metadata        Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookingSegments   BookingSegment[]
  bookingPassengers BookingPassenger[]
  modifications     BookingModification[]
  prebookSessions   PrebookSession[]

  @@index([userId])
  @@index([status])
  @@index([serviceType])
  @@index([bookingRef])
  @@index([createdAt])
  @@map("bookings")
}

model BookingSegment {
  id               String    @id @default(cuid())
  bookingId        String
  segmentType      String
  sequenceNumber   Int       @default(0)
  flightNumber     String?
  airline          String?
  departureAirport String?
  arrivalAirport   String?
  departureTime    DateTime?
  arrivalTime      DateTime?
  hotelName        String?
  checkInDate      DateTime?
  checkOutDate     DateTime?
  roomType         String?
  supplierHotelId  String?
  createdAt        DateTime  @default(now())
  booking          Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_segments")
}

model BookingPassenger {
  id             String    @id @default(cuid())
  bookingId      String
  passengerType  String    @default("adult")
  title          String?
  firstName      String?
  lastName       String?
  dateOfBirth    DateTime?
  passportNumber String?
  passportExpiry DateTime?
  createdAt      DateTime  @default(now())
  booking        Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_passengers")
}

model BookingModification {
  id               String   @id @default(cuid())
  bookingId        String
  modificationType String
  status           String   @default("pending")
  requestNote      String?
  responseNote     String?
  oldValue         Json?
  newValue         Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  booking          Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_modifications")
}

model PrebookSession {
  id            String    @id @default(cuid())
  transactionId String    @unique
  offerId       String
  hotelId       String?
  price         Decimal   @db.Decimal(12, 2)
  currency      String    @default("USD")
  guestEmail    String?
  guestName     String?
  status        String    @default("pending")
  expiresAt     DateTime
  bookingId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  booking       Booking?  @relation(fields: [bookingId], references: [id])

  @@index([transactionId])
  @@index([status])
  @@map("prebook_sessions")
}

// ============================================
// WALLET MODELS
// ============================================

model Wallet {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance         Decimal   @db.Decimal(12, 2) @default(0)
  reservedBalance Decimal   @db.Decimal(12, 2) @default(0)
  currency        String    @default("USD")
  status          String    @default("active")
  dailyLimit      Decimal?  @db.Decimal(12, 2)
  monthlyLimit    Decimal?  @db.Decimal(12, 2)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  transactions    WalletTransaction[]
  ledgerEntries   WalletLedger[]
  reconciliations WalletReconciliation[]

  @@unique([userId, currency])
  @@index([userId])
  @@map("wallets")
}

model WalletTransaction {
  id             String   @id @default(cuid())
  walletId       String
  payerId        String?
  payeeId        String?
  referenceId    String?  @unique
  idempotencyKey String?  @unique
  type           String
  flow           String?
  amount         Decimal  @db.Decimal(12, 2)
  balance        Decimal  @db.Decimal(12, 2)
  currency       String   @default("USD")
  credit         Decimal? @db.Decimal(12, 2)
  debit          Decimal? @db.Decimal(12, 2)
  description    String?
  bookingId      String?
  paymentId      String?
  
  // Booking details for flights and hotels
  serviceType    String?  // 'flight', 'hotel', 'car', 'insurance', 'deposit', 'withdrawal', 'refund', 'settlement'
  supplierId    String?  // Supplier ID (airline code, hotel ID, etc.)
  supplierName  String?  // Airline name, hotel name, etc.
  bookingRef    String?  // Customer-facing booking reference
  travelDate    DateTime? // For flights: departure date, for hotels: check-in date
  returnDate    DateTime? // For flights: return date, for hotels: check-out date
  route         String?  // For flights: route (e.g., "LHR → JFK")
  hotelAddress  String?  // For hotels: address
  guestName    String?  // For hotels: guest name
  roomType     String?  // For hotels: room type
  
  metadata       Json?
  status         String   @default("completed")
  createdAt      DateTime @default(now())
  wallet         Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  ledgerEntries  WalletLedger[]

  @@index([walletId])
  @@index([type])
  @@index([bookingId])
  @@index([createdAt])
  @@index([idempotencyKey])
  @@index([serviceType])
  @@index([supplierId])
  @@map("wallet_transactions")
}

model WalletLedger {
  id            String            @id @default(cuid())
  walletId      String
  transactionId String
  entryType     String
  amount        Decimal           @db.Decimal(12, 2)
  balance       Decimal           @db.Decimal(12, 2)
  currency      String            @default("USD")
  credit        Decimal?          @db.Decimal(12, 2)
  debit         Decimal?          @db.Decimal(12, 2)
  accountType   String
  account       String?
  createdAt     DateTime          @default(now())
  wallet        Wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction   WalletTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([transactionId])
  @@map("wallet_ledger")
}

model WalletReconciliation {
  id                 String    @id @default(cuid())
  walletId           String
  wallet             Wallet    @relation(fields: [walletId], references: [id], onDelete: Cascade)
  reconciliationDate DateTime
  openingBalance     Decimal   @db.Decimal(12, 2)
  closingBalance     Decimal   @db.Decimal(12, 2)
  totalCredits       Decimal   @db.Decimal(12, 2) @default(0)
  totalDebits        Decimal   @db.Decimal(12, 2) @default(0)
  transactionCount   Int       @default(0)
  status             String    @default("pending")
  notes              String?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([walletId])
  @@index([reconciliationDate])
  @@index([status])
  @@map("wallet_reconciliations")
}

// ============================================
// LOYALTY MODELS
// ============================================

model LoyaltyTier {
  id         String            @id @default(cuid())
  name       String            @unique
  level      Int               @unique
  minPoints  Int               @default(0)
  maxPoints  Int?
  benefits   Json?
  multiplier Decimal           @db.Decimal(5, 2) @default(1.0)
  isActive   Boolean           @default(true)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  customers  CustomerLoyalty[]

  @@index([level])
  @@index([isActive])
  @@map("loyalty_tiers")
}

model CustomerLoyalty {
  id              String               @id @default(cuid())
  userId          String               @unique
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  loyaltyTierId   String?
  tier            LoyaltyTier?         @relation(fields: [loyaltyTierId], references: [id])
  totalPoints     Int                  @default(0)
  availablePoints Int                  @default(0)
  lifetimePoints  Int                  @default(0)
  joinedAt        DateTime             @default(now())
  lastActivityAt  DateTime?
  metadata        Json?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  transactions    LoyaltyTransaction[]
  vouchers        LoyaltyVoucher[]

  @@index([userId])
  @@index([loyaltyTierId])
  @@map("customer_loyalty")
}

model LoyaltyTransaction {
  id                String          @id @default(cuid())
  customerLoyaltyId String
  customerLoyalty   CustomerLoyalty @relation(fields: [customerLoyaltyId], references: [id], onDelete: Cascade)
  userId            String
  bookingId         String?
  transactionType   String
  points            Int
  balanceBefore     Int
  balanceAfter      Int
  description       String?
  expiresAt         DateTime?
  metadata          Json?
  createdAt         DateTime        @default(now())

  @@index([customerLoyaltyId])
  @@index([userId])
  @@index([bookingId])
  @@index([transactionType])
  @@index([createdAt])
  @@map("loyalty_transactions")
}

model LoyaltyVoucher {
  id                String          @id @default(cuid())
  customerLoyaltyId String
  customerLoyalty   CustomerLoyalty @relation(fields: [customerLoyaltyId], references: [id], onDelete: Cascade)
  code              String          @unique
  pointsRequired    Int
  discountType      String          @default("percentage")
  discountValue     Decimal         @db.Decimal(12, 2)
  currency          String          @default("USD")
  status            String          @default("active")
  validFrom         DateTime?
  validTo           DateTime?
  usedAt            DateTime?
  usedForBookingId  String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([customerLoyaltyId])
  @@index([code])
  @@index([status])
  @@map("loyalty_vouchers")
}

// ============================================
// PRICING & COMMISSION MODELS
// ============================================

model CommissionRule {
  id          String                @id @default(cuid())
  companyId   String?
  company     Company?              @relation(fields: [companyId], references: [id])
  code        String                @unique
  name        String
  description String?
  targetType  String?
  targetId    String?
  serviceType String?
  ruleType    String                @default("percentage")
  value       Decimal               @db.Decimal(12, 4)
  minValue    Decimal?              @db.Decimal(12, 2)
  maxValue    Decimal?              @db.Decimal(12, 2)
  currency    String                @default("USD")
  validFrom   DateTime?
  validTo     DateTime?
  isActive    Boolean               @default(true)
  priority    Int                   @default(50)
  conditions  Json?
  metadata    Json?
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  settlements CommissionSettlement[]

  @@index([code])
  @@index([companyId])
  @@index([isActive])
  @@index([validFrom])
  @@index([validTo])
  @@map("commission_rules")
}

model CommissionSettlement {
  id               String          @id @default(cuid())
  commissionRuleId String?
  commissionRule   CommissionRule? @relation(fields: [commissionRuleId], references: [id])
  agentId          String?
  bookingId        String
  bookingRef       String?
  amount           Decimal         @db.Decimal(12, 2)
  currency         String          @default("USD")
  settlementStatus String          @default("pending")
  settledAt        DateTime?
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([commissionRuleId])
  @@index([agentId])
  @@index([bookingId])
  @@index([settlementStatus])
  @@map("commission_settlements")
}

model MarkupRule {
  id          String   @id @default(cuid())
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  code        String   @unique
  name        String
  description String?
  targetType  String?
  targetId    String?
  serviceType String?
  ruleType    String   @default("percentage")
  value       Decimal  @db.Decimal(12, 4)
  minValue    Decimal? @db.Decimal(12, 2)
  maxValue    Decimal? @db.Decimal(12, 2)
  currency    String   @default("USD")
  validFrom   DateTime?
  validTo     DateTime?
  isActive    Boolean  @default(true)
  priority    Int      @default(50)
  conditions  Json?
