// ============================================
// OFFLINE CHANGE REQUESTS
// ============================================

model OfflineChangeRequest {
  id             String    @id @default(cuid())
  requestRef     String    @unique
  bookingId      String?
  bookingRef     String?
  requestType    String
  status         String    @default("pending")
  priority       String    @default("normal")
  submittedBy    String?
  assignedTo     String?
  requestDetails Json?
  resolution     Json?
  notes          String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  auditLogs     OfflineRequestAuditLog[]
  notifications OfflineRequestNotificationQueue[]

  @@index([bookingId])
  @@index([bookingRef])
  @@index([requestRef])
  @@index([status])
  @@index([priority])
  @@index([requestType])
  @@index([createdAt])
  @@map("offline_change_requests")
}

model OfflineRequestAuditLog {
  id               String               @id @default(cuid())
  offlineRequestId String
  offlineRequest   OfflineChangeRequest @relation(fields: [offlineRequestId], references: [id], onDelete: Cascade)
  action           String
  actorId          String?
  actorType        String?
  previousStatus   String?
  newStatus        String?
  notes            String?
  metadata         Json?
  createdAt        DateTime             @default(now())

  @@index([offlineRequestId])
  @@index([action])
  @@index([createdAt])
  @@map("offline_request_audit_logs")
}

model OfflineRequestNotificationQueue {
  id               String               @id @default(cuid())
  offlineRequestId String
  offlineRequest   OfflineChangeRequest @relation(fields: [offlineRequestId], references: [id], onDelete: Cascade)
  notificationType String
  recipientId      String?
  recipientEmail   String?
  payload          Json?
  status           String               @default("pending")
  sentAt           DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([offlineRequestId])
  @@index([notificationType])
  @@index([status])
  @@map("offline_request_notification_queue")
}

