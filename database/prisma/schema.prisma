// ============================================
// KIWI NOMAD - Deposit Account & Booking Models
// ============================================

/// Kiwi booking holds - reserved funds during booking flow
model KiwiBookingHold {
  id              String   @id @default(cuid())
  bookingId       String   @unique
  kiwiBookingId   String
  
  // Amount
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("EUR")
  
  // Status
  status          String   @default("held") // held, confirmed, released, refunded
  
  // Timestamps
  heldAt          DateTime @default(now())
  expiresAt       DateTime
  confirmedAt     DateTime?
  releasedAt      DateTime?
  
  // Metadata
  metadata        Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([bookingId])
  @@index([kiwiBookingId])
  @@index([status])
  @@index([expiresAt])
}

/// Kiwi settlements - after ticketing confirmation
model KiwiSettlement {
  id              String   @id @default(cuid())
  kiwiBookingId   String
  
  // Amounts
  amount          Decimal  @db.Decimal(12, 2)
  currency        String   @default("EUR")
  commission      Decimal  @default(0) @db.Decimal(12, 2)
  netAmount       Decimal  @db.Decimal(12, 2)
  
  // Status
  status          String   @default("pending") // pending, settled, failed
  
  // Invoice reference
  invoiceId       String?
  
  // Timestamps
  settledAt       DateTime?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([kiwiBookingId])
  @@index([status])
  @@index([invoiceId])
}

/// Kiwi refunds tracking
model KiwiRefund {
  id              String   @id @default(cuid())
  kiwiBookingId   String
  kiwiRefundId    String?
  
  // Amount
  amount          Decimal  @db.Decimal(12, 2)
  currency        String
  
  // Reason
  reason          String   // customer_cancel, airline_cancel, schedule_change, other
  
  // Status
  status          String   @default("pending") // pending, processing, completed, failed
  
  // Idempotency
  idempotencyKey  String   @unique
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([kiwiBookingId])
  @@index([kiwiRefundId])
  @@index([status])
}

/// Kiwi price change notifications
model KiwiPriceChange {
  id              String   @id @default(cuid())
  kiwiBookingId   String
  
  // Price details
  oldPrice        Decimal  @db.Decimal(12, 2)
  newPrice        Decimal  @db.Decimal(12, 2)
  currency        String
  
  // Review status
  status          String   @default("pending_review") // pending_review, accepted, rejected
  
  // Metadata
  metadata        Json?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([kiwiBookingId])
  @@index([status])
}

/// Kiwi supplier wallet (links to Wallet model)
model KiwiSupplierWallet {
  id              String   @id @default(cuid())
  walletId        String   @unique
  
  // Kiwi credentials (encrypted)
  affilId         String
  apiKeyEncrypted String?
  
  // Balance tracking
  lastBalance     Decimal? @db.Decimal(15, 2)
  lastSyncAt      DateTime?
  
  // Alert threshold
  minBalance      Decimal  @default(1000) @db.Decimal(15, 2)
  
  // Status
  status          String   @default("active")
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([walletId])
}
