}

// ============================================
// SUPPLIER MODELS
// ============================================

model Supplier {
  id              String                 @id @default(cuid())
  name            String
  code            String                 @unique
  supplierType    String
  status          String                 @default("active")
  apiEndpoint     String?
  apiVersion      String?
  supportedRoutes String[]               @default([])
  metadata        Json?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  credentials     SupplierCredential[]
  syncLogs        SupplierSyncLog[]
  hotelMappings   SupplierHotelMapping[]

  @@index([code])
  @@index([status])
  @@map("suppliers")
}

model SupplierCredential {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  environment String   @default("sandbox")
  apiKey      String?
  apiSecret   String?
  username    String?
  password    String?
  token       String?
  expiresAt   DateTime?
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([supplierId])
  @@map("supplier_credentials")
}

model SupplierSyncLog {
  id               String    @id @default(cuid())
  supplierId       String
  supplier         Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  syncType         String
  status           String    @default("running")
  startedAt        DateTime  @default(now())
  completedAt      DateTime?
  recordsProcessed Int       @default(0)
  recordsFailed    Int       @default(0)
  errors           Json?
  metadata         Json?
  createdAt        DateTime  @default(now())

  @@index([supplierId])
  @@index([status])
  @@map("supplier_sync_logs")
}

model SupplierHotelMapping {
  id              String    @id @default(cuid())
  supplierId      String
  supplier        Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  supplierHotelId String
  localHotelId    String?
  liteapiHotelId  String?
  hotelName       String?
  matchScore      Decimal?  @db.Decimal(5, 4)
  status          String    @default("pending")
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([supplierId])
  @@index([supplierHotelId])
  @@index([status])
  @@map("supplier_hotel_mappings")
}

model SupplierDeals {
  id               String            @id @default(cuid())
  supplier         String
  dealType         String
  productType      String?
  name             String
  description      String?
  code             String?           @unique
  discountType     String?           @default("percentage")
  discountValue    Decimal?          @db.Decimal(12, 2) @default(0)
  discountPercent  Decimal?          @db.Decimal(5, 2)
  discountAmount   Decimal?          @db.Decimal(12, 2)
  currency         String            @default("USD")
  validFrom        DateTime?
  validTo          DateTime?
  isActive         Boolean           @default(true)
  status           String            @default("active")
  priority         Int               @default(50)
  minPurchase      Decimal?          @db.Decimal(12, 2)
  minOrderAmount   Decimal?          @db.Decimal(12, 2)
  maxDiscount      Decimal?          @db.Decimal(12, 2)
  applicableRoutes String[]
  excludedDates    String[]
  promoCode        String?
  usageLimit       Int?
  usageCount       Int               @default(0)
  isCombinableWithCoupons Boolean    @default(false)
  mappingRules     Json?
  supplierCodes    String[]
  metadata         Json?
  tags             String[]
  dealMappingRules DealMappingRule[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([supplier])
  @@index([dealType])
  @@index([isActive])
  @@index([code])
  @@map("supplier_deals")
}

model DealMappingRule {
  id                   String        @id @default(cuid())
  dealId               String
  originCities         String[]
  originCountries      String[]
  destinationCities    String[]
  destinationCountries String[]
  cabinClasses         String[]
  fareClasses          String[]
  airlines             String[]
  priority             Int           @default(50)
  isActive             Boolean       @default(true)
  metadata             Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  deal                 SupplierDeals @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([isActive])
  @@map("deal_mapping_rules")
}

