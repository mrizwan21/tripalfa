// ============== PLB (PERFORMANCE LINKED BONUS) ==============

model airline_plb_program {
  id                String    @id @default(cuid())
  airlineId         Int
  airlineCode       String
  name              String
  code              String?
  plbType           String
  status            String    @default("active")
  basePercentage    Decimal?  @db.Decimal(5, 2)
  validFrom         DateTime  @db.Timestamptz(6)
  validTo           DateTime  @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  tiers             airline_plb_tier[]
  snapshots         airline_plb_snapshot[]
  bookings          airline_booking_analytics[]

  @@index([airlineId])
  @@index([airlineCode])
  @@index([status])
  @@map("airline_plb_program")
}

model airline_plb_tier {
  id                String    @id @default(cuid())
  plbProgramId      String
  tierName          String
  tierLevel         Int
  minBookings       Int       @default(0)
  minRevenue        Decimal?  @db.Decimal(12, 2)
  minPassengers     Int       @default(0)
  minGrowthPercentage Decimal? @db.Decimal(5, 2)
  bonusPercentage   Decimal   @db.Decimal(5, 2)
  maxBonusAmount    Decimal?  @db.Decimal(12, 2)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  program           airline_plb_program @relation(fields: [plbProgramId], references: [id])

  @@index([plbProgramId])
  @@map("airline_plb_tier")
}

model airline_booking_analytics {
  id                String    @id @default(cuid())
  bookingId         String
  airlineId         Int
  airlineCode       String
  totalFare         Decimal   @db.Decimal(12, 2)
  baseFare          Decimal   @db.Decimal(12, 2)
  route             String
  status            String    @default("booked")
  plbProgramId      String?
  plbEligible       Boolean   @default(false)
  plbEligibleAmount Decimal   @db.Decimal(12, 2) @default(0)
  bookedAt          DateTime  @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  program           airline_plb_program? @relation(fields: [plbProgramId], references: [id])

  @@index([airlineId])
  @@index([bookingId])
  @@index([plbProgramId])
  @@index([bookedAt])
  @@map("airline_booking_analytics")
}

model airline_plb_snapshot {
  id                    String    @id @default(cuid())
  plbProgramId          String
  airlineId             Int
  airlineCode           String
  periodType            String
  periodStart           DateTime  @db.Timestamptz(6)
  periodEnd             DateTime  @db.Timestamptz(6)
  totalBookings         Int       @default(0)
  totalRevenue          Decimal   @db.Decimal(12, 2) @default(0)
  totalPassengers       Int       @default(0)
  revenueGrowth         Decimal?  @db.Decimal(5, 2)
  calculatedBonusAmount Decimal   @db.Decimal(12, 2) @default(0)
  achievedTierName      String?
  achievedTierLevel     Int?
  calculationStatus     String    @default("pending")
  approvedAt            DateTime? @db.Timestamptz(6)
  paidAt                DateTime? @db.Timestamptz(6)
  metadata              Json?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)

  program               airline_plb_program @relation(fields: [plbProgramId], references: [id])

  @@index([plbProgramId])
  @@index([airlineId])
  @@index([calculationStatus])
  @@map("airline_plb_snapshot")
}

// ============== CAMPAIGNS & MARKETING ==============
// v2.0: Merged campaign + marketing_campaign into single campaigns table with type column

model campaigns {
  id                String    @id @default(cuid())
  name              String
  description       String?   @db.Text
  status            String    @default("active")
  type              String    @default("marketing")  // 'marketing' or 'internal'
  
  // Marketing-specific fields (optional, used when type = 'marketing')
  channel           String?
  budget            Decimal?  @db.Decimal(12, 2)
  actualSpend       Decimal?  @db.Decimal(12, 2)
  impressions       Int?
  clicks            Int?
  conversions       Int?
  roi               Decimal?  @db.Decimal(5, 2)
  
  // Common fields
  startDate         DateTime? @db.Timestamptz(6)
  endDate           DateTime? @db.Timestamptz(6)
  companyId         String?
  targetAudience    Json?
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  // v2.0 relations
  discountCoupons   discount_coupon[]

  @@index([status])
  @@index([type])
  @@index([channel])
  @@map("campaigns")
}

model discount_coupon {
  id                String    @id @default(cuid())
  code              String    @unique
  campaignId        String?
  discount          Decimal   @db.Decimal(12, 2)
  discountType      String    @default("percentage")
  minOrderValue     Decimal?  @db.Decimal(12, 2)
  maxOrderValue     Decimal?  @db.Decimal(12, 2)
  maxUses           Int?
  usedCount         Int       @default(0)
  status            String    @default("active")
  startDate         DateTime? @db.Timestamptz(6)
  expiryDate        DateTime? @db.Timestamptz(6)
  applicableCategories String[]
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  // v2.0 FK relation
  campaign          campaigns? @relation(fields: [campaignId], references: [id])
  redemptions       coupon_redemption[]

  @@index([code])
  @@index([status])
  @@index([campaignId])
  @@map("discount_coupon")
}

model coupon_redemption {
  id                String    @id @default(cuid())
  couponId          String
  userId            String?
  bookingId         String?
  redeemedAt        DateTime  @db.Timestamptz(6)
  discountApplied   Decimal?  @db.Decimal(12, 2)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  // v2.0 relation
  coupon            discount_coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([couponId])
  @@index([userId])
  @@map("coupon_redemption")
}

model promo_code {
  id                String    @id @default(cuid())
  code              String    @unique
  promoType         String
  discount          Decimal   @db.Decimal(12, 2)
  discountType      String    @default("percentage")
  description       String?
  status            String    @default("active")
  startDate         DateTime? @db.Timestamptz(6)
  expiryDate        DateTime? @db.Timestamptz(6)
  maxUses           Int?
  usedCount         Int       @default(0)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([code])
  @@index([status])
  @@map("promo_code")
}

// CRM Models for Marketing Service
model crm_contact {
  id                String    @id @default(cuid())
  email             String    @unique
  firstName         String?
  lastName          String?
  phone             String?
  company           String?
  status            String    @default("lead") // lead, prospect, customer, inactive
  source            String?
  tier              String?   @default("bronze") // platinum, gold, silver, bronze
  totalBookings     Int       @default(0)
  totalSpent        Decimal?  @db.Decimal(12, 2) @default(0)
  bookingsCount     Int       @default(0)
  openTicketsCount  Int       @default(0)
  location          String?
  lastInteractionAt DateTime? @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  activities        crm_activity[]
  campaigns         crm_campaign_contact[]
  leadScore         crm_lead_score?

  @@index([email])
  @@index([status])
  @@index([source])
  @@index([tier])
  @@map("crm_contact")
}

model crm_activity {
  id                String    @id @default(cuid())
  contactId         String
  activityType      String    // email, call, meeting, note, task
  title             String
  description       String?
  dueDate           DateTime? @db.Timestamptz(6)
  completedAt       DateTime? @db.Timestamptz(6)
  status            String    @default("pending") // pending, completed, cancelled
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  contact           crm_contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([activityType])
  @@index([status])
  @@map("crm_activity")
}

model crm_campaign {
  id                String    @id @default(cuid())
  name              String
  description       String?
  status            String    @default("draft") // draft, scheduled, active, completed, paused
  type              String    // email, sms, webinar, event, other
  startDate         DateTime? @db.Timestamptz(6)
  endDate           DateTime? @db.Timestamptz(6)
  targetAudience    String?
  budget            Decimal?  @db.Decimal(12, 2)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  contacts          crm_campaign_contact[]

  @@index([status])
  @@index([type])
  @@map("crm_campaign")
}

model crm_campaign_contact {
  id                String    @id @default(cuid())
  campaignId        String
  contactId         String
  status            String    @default("pending") // pending, sent, opened, clicked, converted, failed
  engagement        Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  campaign          crm_campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact           crm_contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
@@unique([campaignId, contactId])
@@index([campaignId])
@@index([contactId])
@@index([status])
@@map("crm_campaign_contact")
}

// Lead Scoring & Analytics
model crm_lead_score {
id                  String    @id @default(cuid())
contactId           String    @unique
email               String    @unique
score               Int       @default(0) // 0-100
grade               String    @default("D") // A, B, C, D
emailsReceived      Int       @default(0)
lastEngagementDate  DateTime? @db.Timestamptz(6)
source              String?
interests           String[]
pageViews           Int       @default(0)
searchQueries       Int       @default(0)
conversionProbability Decimal? @db.Decimal(5, 2) // 0.00-1.00
lastCalculatedAt    DateTime  @default(now()) @db.Timestamptz(6)
metadata            Json?
createdAt           DateTime  @default(now()) @db.Timestamptz(6)
updatedAt           DateTime  @updatedAt @db.Timestamptz(6)

contact             crm_contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
@@index([contactId])
@@index([email])
@@index([score])
@@index([grade])
@@index([lastEngagementDate])
@@map("crm_lead_score")
}

// Visitor Analytics
model crm_visitor_session {
id                String    @id @default(cuid())
sessionId         String    @unique
visitorId         String?
ipAddress         String?
userAgent         String?
deviceType        String?   // desktop, mobile, tablet
browser           String?
os                String?
country           String?
region            String?
city              String?
landingPage       String?
referrer          String?
utmSource         String?
utmMedium         String?
utmCampaign       String?
utmTerm           String?
utmContent        String?
startTime         DateTime  @default(now()) @db.Timestamptz(6)
endTime           DateTime? @db.Timestamptz(6)
pageViews         Int       @default(0)
durationSeconds   Int?      @default(0)
converted         Boolean   @default(false)
conversionType    String?   // signup, booking, download, etc.
metadata          Json?
createdAt         DateTime  @default(now()) @db.Timestamptz(6)

pageViewsRel      crm_visitor_page_view[]
events            crm_visitor_event[]

@@index([sessionId])
@@index([visitorId])
@@index([startTime])
@@index([country])
@@index([converted])
@@map("crm_visitor_session")
}

model crm_visitor_page_view {
id                String    @id @default(cuid())
sessionId         String
pageUrl           String
pageTitle         String?
pageCategory      String?
timeOnPageSeconds Int?      @default(0)
scrollDepth       Decimal?  @db.Decimal(5, 2) // 0.00-1.00
timestamp         DateTime  @default(now()) @db.Timestamptz(6)
metadata          Json?
createdAt         DateTime  @default(now()) @db.Timestamptz(6)

session           crm_visitor_session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

@@index([sessionId])
@@index([timestamp])
@@index([pageCategory])
@@map("crm_visitor_page_view")
}

model crm_visitor_event {
id                String    @id @default(cuid())
sessionId         String
eventType         String    // click, form_submit, download, video_play, etc.
eventName         String
elementId         String?
elementClass      String?
elementText       String?
url               String?
metadata          Json?
timestamp         DateTime  @default(now()) @db.Timestamptz(6)
createdAt         DateTime  @default(now()) @db.Timestamptz(6)

session           crm_visitor_session @relation(fields: [sessionId], references: [sessionId], onDelete: Cascade)

@@index([sessionId])
@@index([eventType])
@@index([timestamp])
@@map("crm_visitor_event")
}

