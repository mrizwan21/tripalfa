  @@index([walletId])
  @@index([bookingId])
  @@index([payerId])
  @@index([payeeId])
  @@map("wallet_transaction")
}

model wallet_ledger {
  id            String   @id
  walletId      String
  transactionId String
  entryType     String
  amount        Decimal  @db.Decimal(12, 2)
  balance       Decimal  @db.Decimal(12, 2)
  currency      String   @default("USD")
  credit        Decimal? @db.Decimal(12, 2)
  debit         Decimal? @db.Decimal(12, 2)
  accountType   String
  account       String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  // v2.0 FK relations - enables explicit tracing
  wallet        wallet            @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction   wallet_transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([transactionId])
  @@index([createdAt])
  // Note: Consider partitioning by createdAt (monthly) for high-volume systems
  // Example: PARTITION BY RANGE (createdAt)
  @@map("wallet_ledger")
}

model wallet_approval_request {
