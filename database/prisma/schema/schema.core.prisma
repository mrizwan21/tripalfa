  updatedAt       DateTime      @updatedAt @db.Timestamptz(6)

  // Relations
  order           duffelOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  paymentIntent   payment_intent? @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
