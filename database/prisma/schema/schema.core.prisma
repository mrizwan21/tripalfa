model duffelOrderChangeRequest {
  id              String    @id @default(cuid())
  externalId      String?   @unique
  orderId         String
  order           duffelOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Request details
  requestedChanges Json?    // The slices that were requested to be changed
  changeOffers     Json?    // The order_change_offers returned by Duffel
  
  // Status tracking
  status          OrderChangeRequestStatus    @default(pending)
  errorMessage    String?
  
  // Timestamps
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  expiresAt       DateTime? @db.Timestamptz(6)
  
  // Metadata
  metadata        Json?
  
  // Relations
  changes         duffelOrderChange[]
  
  // Indexes
  @@index([externalId])
  @@index([orderId])
  @@index([status])
  @@index([createdAt])
  @@map("duffel_order_change_request")
}

model duffelOrderChange {
  id                      String    @id @default(cuid())
  externalId              String?   @unique
  orderId                 String
  orderChangeRequestId    String?
  
  // Relations
  order                   duffelOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderChangeRequest      duffelOrderChangeRequest? @relation(fields: [orderChangeRequestId], references: [id], onDelete: SetNull)
  
  // Change details
  requestedChanges       Json?        // Added for code compatibility
  selectedOrderChangeOfferId String?  // The selected offer ID
  changeDetails          Json?        // The full change details from Duffel
  paymentRequired        Boolean     @default(false)
  paymentAmount          Decimal?    @db.Decimal(12, 2)
  paymentCurrency        String      @default("USD")
  refundAmount           Decimal?    @db.Decimal(12, 2)
  refundCurrency         String      @default("USD")
  // Additional financial details from Duffel API
  changeTotalAmount      Decimal?    @db.Decimal(12, 2)  // Net change amount (positive = pay, negative = refund)
  changeTotalCurrency    String      @default("USD")
  penaltyAmount          Decimal?    @db.Decimal(12, 2)  // Penalty charges
  penaltyCurrency        String      @default("USD")
  
  // Status tracking
  status                  OrderChangeStatus    @default(pending) // pending, confirmed, failed, expired
  confirmedAt             DateTime? @db.Timestamptz(6)
  failedAt                DateTime? @db.Timestamptz(6)
  failureReason           String?
  
  // Timestamps
  createdAt               DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @db.Timestamptz(6)
  expiresAt               DateTime? @db.Timestamptz(6)
  
  // Metadata
  metadata                Json?
  
  // Indexes
  @@index([externalId])
  @@index([orderId])
  @@index([status])
  @@index([orderChangeRequestId])
  @@map("duffel_order_change")
}

model duffelOrderCancellation {
  id              String    @id @default(cuid())
  externalId      String?   @unique
  orderId         String
  order           duffelOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Cancellation details
  refundAmount    Decimal?  @db.Decimal(12, 2)
  refundCurrency  String    @default("USD")
  refundTo        RefundTo?   // original_form_of_payment, airline_credits, voucher
  airlineCredits  Json?     // Airline credits details if applicable
  voucher         Json?     // Voucher details if applicable
  
  // Status tracking
  status          OrderCancellationStatus    @default(pending) // pending, confirmed, failed, expired
  confirmedAt     DateTime? @db.Timestamptz(6)
  failedAt        DateTime? @db.Timestamptz(6)
  failureReason   String?
  expiresAt       DateTime? @db.Timestamptz(6)
  
  // Timestamps
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  
  // Metadata
  metadata        Json?
  
  // Relations
  airlineCreditsList duffelAirlineCredit[]
  
  // Indexes
  @@index([externalId])
  @@index([orderId])
  @@index([status])
  @@map("duffel_order_cancellation")
}

model duffelAirlineCredit {
