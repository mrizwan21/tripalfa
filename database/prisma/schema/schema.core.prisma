  monthlyLimit    Decimal?  @db.Decimal(12, 2)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  // v2.0 relation
  ledgerEntries   wallet_ledger[]

  @@index([userId])
  @@unique([userId, currency])
  @@map("wallet")
}

model wallet_transaction {
  id              String    @id
  walletId        String
  payerId         String?
  payeeId         String?
  referenceId     String?
  idempotencyKey  String?
  type            String
  flow            String?
  amount          Decimal   @db.Decimal(12, 2)
  balance         Decimal   @db.Decimal(12, 2)
  currency        String    @default("USD")
  credit          Decimal?  @db.Decimal(12, 2)
  debit           Decimal?  @db.Decimal(12, 2)
  description     String?
  bookingId       String?
  paymentId       String?
  serviceType     String?
  supplierId      String?
  supplierName    String?
  bookingRef      String?
  travelDate      DateTime? @db.Timestamptz(6)
  returnDate      DateTime? @db.Timestamptz(6)
  route           String?
  hotelAddress    String?
  guestName       String?
  roomType        String?
  metadata        Json?
  status          String    @default("completed")
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)

  // v2.0 relation
