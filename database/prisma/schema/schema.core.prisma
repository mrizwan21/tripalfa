  payment         duffelPayment?    @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  refunds         refund[]

  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@index([paymentId])
  @@map("refund_request")
}

// ============== REFUND TRANSACTIONS ==============

model refund {
  id              String        @id @default(cuid())
  refundRequestId String?       // Link to refund_request if applicable
  paymentId       String        // Reference to original payment
  amount          Decimal       @db.Decimal(12, 2)
  currency        String        @default("USD")
  status          RefundStatus  @default(PENDING)
  refundMethod    PaymentMethod // How the refund was processed
  transactionId   String?       // External refund transaction ID
  processedAt     DateTime?     @db.Timestamptz(6)
  completedAt     DateTime?     @db.Timestamptz(6)
  failureReason   String?
  metadata        Json?
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(6)

  // Relations
  refundRequest   refund_request? @relation(fields: [refundRequestId], references: [id], onDelete: SetNull)
  payment         duffelPayment   @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([refundRequestId])
  @@index([paymentId])
  @@index([status])
  @@index([transactionId])
  @@map("refund")
}

