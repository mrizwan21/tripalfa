// ============== CORE BOOKING TABLES ==============

model booking {
  id             String    @id
  bookingRef     String?   @unique // Made unique for findUnique
  userId         String
  serviceType    String
  status         String    @default("pending")
  workflowState  String    @default("pending")
  paymentStatus  String    @default("pending")
  customerEmail  String?
  customerPhone  String?
  baseAmount     Decimal   @db.Decimal(12, 2)
  taxAmount      Decimal   @db.Decimal(12, 2) @default(0)
  markupAmount   Decimal   @db.Decimal(12, 2) @default(0)
  totalAmount    Decimal   @db.Decimal(12, 2)
  currency       String    @default("USD")
  travelDate     DateTime? @db.Timestamptz(6)
  returnDate     DateTime? @db.Timestamptz(6)
  metadata       Json?
  createdAt      DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@map("booking")

  // Relations
  bookingSegments   booking_segment[]
  bookingPassengers booking_passenger[]
  modifications     booking_modification[]
  workQueueItems    booking_work_queue[]
  approvals         booking_approval[]
  escalations       booking_escalation[]
  reissues          ticket_reissue[]
  refundRequests    refund_request[]
  paymentIntents    payment_intent[]
  supportTickets    support_ticket[]
}

model booking_segment {
  id          String   @id @default(cuid())
