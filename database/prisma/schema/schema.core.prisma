// ============== AIRCRAFT SEAT MAP SYSTEM ==============

enum CabinClass {
  first
  business
  premium_economy
  economy
}

enum ElementType {
  seat
  empty
  bassinet
  exit_row
  lavatory
  galley
  closet
  stairs
  restricted_seat_general
}

enum AvailabilityStatus {
  available
  booked
  blocked
  reserved
}


model cabin_configuration {
  id                  String    @id
  aircraftId          String
  configurationName   String?
  totalSeats          Int
  businessSeats       Int       @default(0)
  premiumEconomySeats Int       @default(0)
  economySeats        Int       @default(0)
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)

  cabins              cabin[]
  seatMaps            seat_map[]

  @@index([aircraftId])
  @@map("cabin_configuration")
}

model cabin {
  id                      String    @id
  cabinConfigurationId    String
  cabinClass              CabinClass
  deck                    Int       @default(0)
  aisles                  Int       @default(1)
  wingPositionFirstRowIndex Int?
  wingPositionLastRowIndex  Int?
  createdAt               DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt               DateTime  @updatedAt @db.Timestamptz(6)

  cabinConfiguration      cabin_configuration @relation(fields: [cabinConfigurationId], references: [id], onDelete: Cascade)
  seatRows                seat_row[]

  @@index([cabinConfigurationId])
  @@map("cabin")
}

model seat_row {
  id              String    @id
  cabinId         String
  rowNumber       Int
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  cabin           cabin    @relation(fields: [cabinId], references: [id], onDelete: Cascade)
  seatSections    seat_section[]

  @@unique([cabinId, rowNumber])
  @@map("seat_row")
}

model seat_section {
  id              String    @id
  seatRowId       String
  sectionIndex    Int
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  seatRow         seat_row  @relation(fields: [seatRowId], references: [id], onDelete: Cascade)
  seatElements    seat_element[]

  @@unique([seatRowId, sectionIndex])
  @@map("seat_section")
}

model seat_element {
  id              String        @id
  seatSectionId   String
  elementType     ElementType
  designator      String?
  name            String?
  disclosures     String[]
  coordinatesX    Int?
  coordinatesY    Int?
  amenities       Json?
  createdAt       DateTime      @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @db.Timestamptz(6)

  seatSection     seat_section  @relation(fields: [seatSectionId], references: [id], onDelete: Cascade)
  seatAvailabilities seat_availability[]

  @@index([seatSectionId])
  @@map("seat_element")
}

model seat_map {
  id                    String    @id
  segmentId             String
  sliceId               String
  cabinConfigurationId  String?
  rawData               Json?
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)

  cabinConfiguration    cabin_configuration? @relation(fields: [cabinConfigurationId], references: [id], onDelete: SetNull)

  @@index([segmentId])
  @@map("seat_map")
}

model seat_availability {
  id                  String              @id
  seatElementId       String
  segmentId           String
  availabilityStatus  AvailabilityStatus  @default(available)
  passengerId         String?
  bookingId           String?
  priceAmount         Decimal?            @db.Decimal(12, 2)
  priceCurrency       String?
  serviceId           String?
  validUntil          DateTime?           @db.Timestamptz(6)
  createdAt           DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime            @updatedAt @db.Timestamptz(6)

  seatElement         seat_element        @relation(fields: [seatElementId], references: [id], onDelete: Cascade)
  seatServices        seat_service[]

  @@unique([seatElementId, segmentId])
  @@index([segmentId])
  @@index([seatElementId])
  @@map("seat_availability")
}

model seat_service {
  id                  String    @id
  seatAvailabilityId  String
  passengerId         String
  totalAmount         Decimal   @db.Decimal(12, 2)
  totalCurrency       String
  status              String    @default("confirmed")
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)

  seatAvailability    seat_availability @relation(fields: [seatAvailabilityId], references: [id], onDelete: Cascade)

  @@index([seatAvailabilityId])
