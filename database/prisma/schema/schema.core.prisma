// Prisma Schema: tripalfa_core (Core operational database)
// Database: PostgreSQL (tripalfa_core)
// Purpose: Users, companies, bookings, wallet, KYC, inventory, admin UI state

generator client {
  provider = "prisma-client-js"
  output   = "../../packages/shared-database/src/generated/core"
}

datasource db {
  provider = "postgresql"
}

// ============== USER & AUTHENTICATION ==============

enum UserType {
  B2C
  B2B_ADMIN
  B2B_EMPLOYEE
  SUPER_ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  APPLE
  FACEBOOK
  SAML
  OIDC
}

enum PaymentMethod {
  CARD
  WALLET
  HYBRID
  BALANCE
  BANK_TRANSFER
  CASH
  UNKNOWN
}

enum PaymentStatus {
  PENDING
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELED
  REFUNDED
  PARTIALLY_REFUNDED
  REQUIRES_ACTION
  REQUIRES_CONFIRMATION
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  CANCELLED
  EXPIRED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RefundStatus {
  PENDING
  APPROVED
  PROCESSING
  COMPLETED
  FAILED
  REJECTED
  CANCELLED
}

enum PaymentProvider {
  STRIPE
  DUFFEL
  PAYPAL
  RAZORPAY
  CCAVENUE
  MANUAL
  WALLET
}

enum OrderChangeRequestStatus {
  pending
  confirmed
  failed
  expired
}

enum OrderChangeStatus {
  pending
  confirmed
  failed
  expired
}

enum OrderCancellationStatus {
  pending
  confirmed
  failed
  expired
}

enum RefundTo {
  original_form_of_payment
  airline_credits
  voucher
}

enum AirlineCreditStatus {
  active
  used
  expired
}

enum BatchOfferRequestStatus {
  pending
  processing
  completed
  expired
}

model user {
  id              String    @id @default(cuid())
  externalId      String?   // OAuth provider user ID
  email           String    @unique
  phoneNumber     String?
  firstName       String?
  lastName        String?
  avatarUrl       String?
  companyId       String?

  // Authentication fields
  passwordHash    String?
  userType        UserType  @default(B2C)
  authProvider    AuthProvider @default(EMAIL)
  isEmailVerified Boolean   @default(false)
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime? @db.Timestamptz(6)
  failedLoginAttempts Int   @default(0)
  lockedUntil     DateTime? @db.Timestamptz(6)

  // MFA
  mfaEnabled      Boolean   @default(false)
  mfaSecret       String?
  backupCodes     String[]  // Hashed backup codes

  // SSO fields
  samlIdpId       String?   // SAML Identity Provider ID
  oidcSubject     String?   // OIDC subject claim
  idpTenantId     String?   // For B2B multi-tenant SSO

  // Timestamps
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  // Relations
  role            role?     @relation(fields: [roleId], references: [id])
  roleId          String?
  sessions        session_state[]
  oauthAccounts   oauth_account[]
  company         company?  @relation("CompanyUsers", fields: [companyId], references: [id])
  userRoles       userRole[]
  preferences     admin_ui_preference[]
  emailVerificationTokens emailVerificationToken[]
  supportTickets  support_ticket[]

  @@index([email])
  @@index([companyId])
  @@index([userType])
  @@index([authProvider])
  @@map("user")
}

model userPreference {
  id              String    @id @default(cuid())
  userId          String    @unique
  language        String    @default("en")
  currency        String    @default("USD")
  notifications   Boolean   @default(true)
  theme           String?   @default("light")
  timezone        String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  // Relations - link to user (note: not using FK relation as user-service expects this)
  @@map("user_preferences")
}

model emailVerificationToken {
  id                String            @id @default(cuid())
  userId            String
  user              user              @relation(fields: [userId], references: [id], onDelete: Cascade)
  email             String            @db.VarChar(255)
  token             String            @unique @db.VarChar(255)
  expiresAt         DateTime
  verifiedAt        DateTime?
  attemptCount      Int               @default(0)
  maxAttempts       Int               @default(3)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("email_verification_token")
}

model oauth_account {
  id            String    @id @default(cuid())
  userId        String
  provider      String
  providerId    String
  accessToken   String?
  refreshToken  String?
  expiresAt     DateTime? @db.Timestamptz(6)
  scope         String?
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  user          user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("oauth_account")
}

model identity_provider {
  id                  String    @id @default(cuid())
  name                String
  type                String
  tenantId            String?

  samlEntryPoint      String?
  samlIssuer          String?
  samlCertificate     String?

  oidcIssuer          String?   // Authorization endpoint
  oidcClientId        String?
  oidcClientSecret    String?   // Encrypted
  oidcScopes          String?   // Space-separated scopes

  isActive            Boolean   @default(true)
  isDefault           Boolean   @default(false)
  createdAt           DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt           DateTime  @updatedAt @db.Timestamptz(6)

  company             company?   @relation("CompanyIdP", fields: [tenantId], references: [id])

  @@unique([type, tenantId])
  @@map("identity_provider")
}

// ============== SERVICE ACCESS CONTROL ==============

model service {
  id            String    @id @default(cuid())
  name          String    @unique
  displayName   String
  description   String?
  baseUrl       String
  isInternal    Boolean   @default(false)
  isActive      Boolean   @default(true)
  priority      Int       @default(0)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  permissions   service_permission[]
  roleAccess    role_service_access[]

  @@map("service")
}

model service_permission {
  id            String    @id @default(cuid())
  serviceId     String
  name          String
  description   String?
  endpoint      String?
  method        String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)

  service       service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  roles         role_service_access[]

  @@unique([serviceId, name])
  @@index([serviceId])
  @@map("service_permission")
}

model role_service_access {
  id              String    @id @default(cuid())
  roleId          String
  serviceId       String
  permissionId    String?
  accessLevel     String    @default("read") // read, write, admin
  rateLimit       Int?      // Requests per minute
  quota           Int?      // Daily quota
  quotaUsed       Int       @default(0)
  quotaResetAt    DateTime? @db.Timestamptz(6)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  role            role               @relation(fields: [roleId], references: [id], onDelete: Cascade)
  service         service            @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  permission      service_permission? @relation(fields: [permissionId], references: [id])

  @@unique([roleId, serviceId])
  @@index([roleId])
  @@index([serviceId])
  @@map("role_service_access")
}

// ============== IP MANAGEMENT ==============

model ip_whitelist {
  id            String    @id @default(cuid())
  ipAddress     String
  ipRange       String?   // CIDR notation for ranges
  description   String?
  isActive      Boolean   @default(true)
  isBlacklist   Boolean   @default(false) // If true, this is a blacklist entry
  countryCode   String?   // Country code for geo-blocking
  region        String?
  city          String?
  provider      String?   // ISP name
  userId        String?   // User-specific IP (for 2FA trusted devices)
  companyId     String?   // Company-specific IP
  expiresAt     DateTime? @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  createdBy     String?
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([ipAddress, userId])
  @@index([ipAddress])
  @@index([companyId])
  @@index([userId])
  @@map("ip_whitelist")
}

model ip_audit_log {
  id            String    @id @default(cuid())
  ipAddress     String
  userId        String?
  action        String    // login_success, login_failed, access_denied, suspicious
  serviceId     String?
  endpoint      String?
  userAgent     String?
  countryCode   String?
  countryName   String?
  city          String?
  isVpn         Boolean   @default(false)
  isProxy       Boolean   @default(false)
  isTor         Boolean   @default(false)
  isp           String?
  latitude      Decimal?  @db.Decimal(10, 6)
  longitude     Decimal?  @db.Decimal(10, 6)
  requestId     String?   // Trace ID
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)

  @@index([ipAddress])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("ip_audit_log")
}

// ============== DEVICE & STATE MANAGEMENT ==============

model device {
  id              String    @id @default(cuid())
  userId          String
  deviceId        String    @unique // Fingerprint ID
  deviceType      String    // mobile, desktop, tablet
  browser         String?
  os              String?
  engine          String?
  cpu             String?
  deviceBrand    String?
  deviceModel     String?
  isMobile        Boolean   @default(false)
  isTablet        Boolean   @default(false)
  isDesktop       Boolean   @default(true)
  isBot           Boolean   @default(false)
  screenWidth     Int?
  screenHeight    Int?
  languages       String[]  // Accept-Language header
  colorDepth      Int?
  platform        String?
  vendor          String?
  canvasFingerprint String?
  webglFingerprint String?
  
  // Trust & State
  isTrusted       Boolean   @default(false)
  isVerified      Boolean   @default(false) // Verified via 2FA
  lastVerifiedAt  DateTime? @db.Timestamptz(6)
  firstSeenAt     DateTime  @default(now()) @db.Timestamptz(6)
  lastSeenAt      DateTime  @default(now()) @db.Timestamptz(6)
  lastIpAddress   String?
  isActive        Boolean   @default(true)
  isCompromised   Boolean   @default(false)
  
  // Geolocation
  countryCode     String?
  region          String?
  city            String?
  
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([deviceId])
  @@index([isTrusted])
  @@map("device")
}

// ============== LOGIN & AUDIT TRAIL ==============

model login_audit {
  id              String    @id @default(cuid())
  userId          String?
  email           String?
  ipAddress       String
  ipCountryCode   String?
  ipCity          String?
  userAgent       String?
  deviceId        String?
  deviceFingerprint String?
  browser         String?
  os              String?
  
  // Login details
  action          String    // login_success, login_failed, logout, password_changed, mfa_enabled, etc.
  status          String    // success, failed, blocked
  failureReason   String?
  
  // Security checks
  isVpn           Boolean   @default(false)
  isProxy         Boolean   @default(false)
  isTor           Boolean   @default(false)
  isNewDevice     Boolean   @default(false)
  isNewLocation   Boolean   @default(false)
  isNewIp         Boolean   @default(false)
  
  // Session info
  sessionId       String?
  tokenId         String?   // JTI of the token
  
  // Metadata
  requestId       String?   // For tracing
  metadata        Json?
  
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([userId])
  @@index([ipAddress])
  @@index([action])
  @@index([status])
  @@index([createdAt])
  @@map("login_audit")
}

model session_state {
  id              String    @id @default(cuid())
  userId          String
  sessionToken    String    @unique
  refreshToken    String?   @unique
  
  // State
  isValid         Boolean   @default(true)
  isBlocked       Boolean   @default(false)
  blockReason     String?   // manual, suspicious_activity, policy_violation
  blockedAt       DateTime? @db.Timestamptz(6)
  blockedBy       String?
  
  // Device info
  deviceId        String?
  deviceFingerprint String?
  ipAddress       String?
  ipCountryCode   String?
  userAgent       String?
  
  // Timestamps
  issuedAt        DateTime  @db.Timestamptz(6)
  expiresAt       DateTime  @db.Timestamptz(6)
  lastActivityAt  DateTime  @default(now()) @db.Timestamptz(6)
  previousActivityAt DateTime? @db.Timestamptz(6)
  
  // Security state
  isMfaVerified   Boolean   @default(false)
  riskScore       Int       @default(0) // 0-100 risk score
  riskLevel        String    @default("low") // low, medium, high, critical
  
  // Location tracking
  currentCity     String?
  currentCountry  String?
  isNewLocation   Boolean   @default(false)
  
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([sessionToken])

  user            user      @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([expiresAt])
  @@index([isValid])
  @@map("session_state")
}

// ============== RATE LIMITING ==============

model rate_limit {
  id              String    @id @default(cuid())
  identifier      String    // IP address, user ID, or API key
  identifierType  String    // ip, user, api_key
  endpoint        String?
  method          String?
  windowSeconds   Int       @default(60)
  maxRequests     Int       @default(100)
  currentCount    Int       @default(0)
  resetAt         DateTime  @db.Timestamptz(6)
  isPermanent     Boolean   @default(false)
  isWhitelisted   Boolean   @default(false)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([identifier, endpoint, windowSeconds])
  @@index([identifier])
  @@index([resetAt])
  @@map("rate_limit")
}

// ============== SECURITY POLICIES ==============

model security_policy {
  id                    String    @id @default(cuid())
  name                  String    @unique
  description           String?
  
  // Password policy
  minPasswordLength     Int       @default(8)
  requireUppercase      Boolean   @default(true)
  requireLowercase      Boolean   @default(true)
  requireNumbers        Boolean   @default(true)
  requireSpecialChar    Boolean   @default(true)
  passwordExpiryDays    Int?      // 0 = never
  passwordHistoryCount  Int       @default(5)
  
  // Session policy
  sessionTimeoutMinutes Int       @default(30)
  maxConcurrentSessions Int       @default(3)
  allowMultipleDevices  Boolean   @default(true)
  requireMfaForRole     String[]  // Roles that require MFA
  
  // IP policy
  enableIpWhitelist     Boolean   @default(false)
  enableGeoBlocking     Boolean   @default(false)
  blockedCountries      String[]
  allowVpn              Boolean   @default(true)
  allowTor              Boolean   @default(false)
  allowProxy            Boolean   @default(false)
  
  // Access policy
  enableRateLimiting    Boolean   @default(true)
  defaultRateLimit      Int       @default(100)
  enableBruteForce      Boolean   @default(true)
  maxLoginAttempts      Int       @default(5)
  lockoutDurationMinutes Int      @default(15)
  
  // Trust policy
  deviceTrustDays       Int       @default(30)
  ipTrustDays          Int       @default(7)
  requireDeviceVerification Boolean @default(false)
  
  // Company-specific
  companyId             String?
  company              company?  @relation(fields: [companyId], references: [id])
  
  isActive              Boolean   @default(true)
  isDefault             Boolean   @default(false)
  priority              Int       @default(0)
  createdAt             DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([companyId, isDefault])
  @@map("security_policy")
}

model role {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String?
  userType      UserType  @default(B2C)
  isSystem      Boolean   @default(false)
  isActive      Boolean   @default(true)
  priority      Int       @default(0)
  createdAt     DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(6)

  permissions       role_permission[]
  users             user[]
  roleServiceAccess role_service_access[]
  userRoles         userRole[]

  @@map("role")
}

model userRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)
  role role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_role")
}

model permission {
  id            String    @id @default(cuid())
  name          String    @unique
  description   String?
  category      String
  resource      String
  action        String
  conditions    Json?

  roles         role_permission[]

  @@unique([resource, action])
  @@index([category])
  @@index([resource])
  @@map("permission")
}

// Role-Permission junction table (explicit many-to-many)
model role_permission {
  roleId       String
  permissionId String
  grantedAt    DateTime  @default(now()) @db.Timestamptz(6)

  role         role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permission")
}

// ============== COMPANY STRUCTURE ==============

model company {
  id              String    @id @default(cuid())
  name            String    @unique
  code            String    @unique // Added for companies.ts
  type            String    @default("standard")
  registrationNo  String?
  taxId           String?
  businessLicense String?
  address         String?
  city            String?
  state           String?
  postalCode      String?
  country         String?
  phone           String?
  email           String?
  website         String?
  logoUrl         String?
  isActive        Boolean   @default(true)
  metadata        Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  // Relations
  users              user[]               @relation("CompanyUsers")
  identityProviders  identity_provider[]  @relation("CompanyIdP")
  securityPolicies   security_policy[]
  branches          branch[]
  departments       department[]
  designations      designation[]
  costCenters       cost_center[]

  @@index([name])
  @@index([isActive])
  @@map("company")
}

model branch {
  id          String    @id @default(cuid())
  companyId   String
  company     company   @relation(fields: [companyId], references: [id])
  name        String
  branchCode  String    @unique
  address     String?
  city        String?
  state       String?
  phone       String?
  email       String?
  managerName String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  // Reverse relations
  departments   department[]
  designations  designation[]
  costCenters   cost_center[]

  @@index([companyId])
  @@index([branchCode])
  @@map("branch")
}

model department {
  id          String    @id @default(cuid())
  companyId   String
  branchId    String?
  branch      branch?   @relation(fields: [branchId], references: [id])
  company     company   @relation(fields: [companyId], references: [id])
  name        String
  code        String    @unique // Renamed from deptCode to match routes
  headName    String?
  headId      String?   // Added for companies.ts
  description String?   // Added for companies.ts
  budget      Decimal?  @db.Decimal(12, 2)
  isActive    Boolean   @default(true)
  designations designation[]
  costCenters  cost_center[]
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  @@index([companyId])
  @@index([branchId])
  @@index([code])
  @@map("department")
}

model designation {
  id          String    @id @default(cuid())
  companyId   String
  branchId    String?
  departmentId String?
  department   department? @relation(fields: [departmentId], references: [id])
  branch      branch?    @relation(fields: [branchId], references: [id])
  company     company    @relation(fields: [companyId], references: [id])
  title       String    @unique
  level       String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@map("designation")
}

model cost_center {
  id          String    @id @default(cuid())
  companyId   String
  branchId    String?
  departmentId String?   // Added for department relation
  department  department? @relation(fields: [departmentId], references: [id])
  branch      branch?   @relation(fields: [branchId], references: [id])
  company     company   @relation(fields: [companyId], references: [id])
  code        String    @unique
  name        String
  manager     String?
  budget      Decimal?  @db.Decimal(12, 2)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(6)

  @@index([companyId])
  @@index([branchId])
  @@index([code])
  @@map("cost_center")
}

// ============== KYC & VERIFICATION ==============

model kyc_verification {
  id                String    @id @default(cuid())
  userId            String
  status            String    @default("pending")
  verificationType  String
  documentType      String?
  documentNumber    String?
  documentFront     String?
  documentBack      String?
  selfie            String?
  firstName         String?
  lastName          String?
  dateOfBirth       DateTime? @db.Timestamptz(6)
  nationality       String?
  address           Json?
  addressStreet     String?
  addressCity       String?
  addressState      String?
  addressPostalCode String?
  addressCountry    String?
  submittedAt       DateTime? @db.Timestamptz(6)
  reviewedAt        DateTime? @db.Timestamptz(6)
  reviewedBy        String?
  issuingCountry    String?
  expiryDate        DateTime? @db.Timestamptz(6)
  verifiedAt        DateTime? @db.Timestamptz(6)
  verifiedBy        String?
  rejectionReason   String?
  notes             String?
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  kyc_document_submissions kyc_document_submission[]

  @@index([userId])
  @@index([status])
  @@map("kyc_verification")
}

model kyc_document_submission {
  id              String    @id @default(cuid())
  kycVerificationId String
  documentType    String
  documentUrl     String
  fileName        String
  fileSize        Int
  mimeType        String
  uploadedAt      DateTime  @default(now()) @db.Timestamptz(6)
  verificationStatus String @default("pending")
  metadata        Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  kyc_verification kyc_verification @relation(fields: [kycVerificationId], references: [id])

  @@index([kycVerificationId])
  @@index([documentType])
  @@map("kyc_document_submission")
}

model kyc_verification_history {
  id              String    @id @default(cuid())
  kycVerificationId String
  status          String
  changeReason    String?
  changedBy       String
  changedAt       DateTime  @default(now()) @db.Timestamptz(6)
  metadata        Json?
