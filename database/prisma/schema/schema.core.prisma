model duffelOrder {
  id              String      @id @default(cuid())
  externalId      String?     @unique
  userId          String?     // Added for internal tracking
  customerEmail   String?
  customerPhone   String?
  status          String      @default("pending")
  type            String?     // "hold", "instant"
  slices          Json?
  passengers      Json?
  baseAmount      Decimal     @db.Decimal(12, 2) @default(0)
  taxAmount       Decimal     @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal     @db.Decimal(12, 2) @default(0)
  currency        String      @default("USD")
  confirmedAt     DateTime?   @db.Timestamptz(6)
  cancelledAt     DateTime?   @db.Timestamptz(6)
