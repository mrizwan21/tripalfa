  userId          String
  preferenceKey   String
  preferenceValue Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  user            user      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, preferenceKey])
  @@index([userId])
  @@map("admin_ui_preference")
}

model saved_search {
  id              String    @id @default(cuid())
  userId          String
  searchName      String
  searchQuery     Json
  filters         Json?
  isPublic        Boolean   @default(false)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@map("saved_search")
}

model admin_dashboard_widget {
  id              String    @id @default(cuid())
  userId          String
  widgetType      String
  widgetConfig    Json
  position        Int
  isVisible       Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@map("admin_dashboard_widget")
}


model admin_activity_log {
  id              String    @id @default(cuid())
  adminId         String
  action          String
  resourceType    String?
  resourceId      String?
  details         String?
  ipAddress       String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)

  @@index([adminId])
  @@index([createdAt])
  @@map("admin_activity_log")
}

model document {
  id              String    @id @default(cuid())
  entityType      String    // booking, user, company
  entityId        String
  bookingId       String?   // Added for bookings.ts
  documentType    String    // receipt, ticket, invoice, id_proof
  name            String
  fileUrl         String
  fileSize        Int?
  mimeType        String?
  metadata        Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  @@index([entityType, entityId])
  @@map("document")

  template        document_template? @relation(fields: [templateId], references: [id])
  access          document_access[]
  templateId      String?
}

model document_template {
  id              String    @id @default(cuid())
  name            String
  type            String
  content         String?   @db.Text
  metadata        Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  documents       document[]
  @@map("document_template")
}

model document_access {
  id              String    @id @default(cuid())
  documentId      String
  userId          String
  action          String    // read, download, print
  timestamp       DateTime  @default(now()) @db.Timestamptz(6)
  ipAddress       String?
  metadata        Json?

  document        document  @relation(fields: [documentId], references: [id])
  @@index([documentId])
  @@index([userId])
  @@map("document_access")
}
model currency {
  id              String    @id @default(cuid())
  code            String    @unique
  name            String
  symbol          String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)

  @@index([code])
  @@map("currency")
}

// ============== CRM SUPPORT TABLES ==============

model support_ticket {
  id              String    @id @default(cuid())
  ticketNumber    String    @unique
  userId          String?
  bookingId       String?
  companyId       String?
  
  // Ticket details
  subject         String
  description     String
  category        String    // billing, technical, booking, refund, other
  priority        String    // low, medium, high, critical
  status          String    // open, in_progress, resolved, closed
  source          String    // web, email, phone, chat, api
  
  // Assignment & tracking
  assignedTo      String?   // agent/user ID
  assignedAt      DateTime?
  dueDate         DateTime?
  slaBreachAt     DateTime?
  
  // Resolution
  resolution      String?
  resolvedAt      DateTime?
  closedAt        DateTime?
  
  // Metadata
  metadata        Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  
  // Relations
  user            user?     @relation(fields: [userId], references: [id])
  booking         booking?  @relation(fields: [bookingId], references: [id])
  interactions    support_interaction[]
  attachments     support_attachment[]
  
  @@index([userId])
  @@index([bookingId])
  @@index([status])
  @@index([priority])
  @@index([assignedTo])
  @@index([createdAt])
  @@map("support_ticket")
}

model support_interaction {
  id              String    @id @default(cuid())
  ticketId        String
  type            String    // internal_note, customer_reply, system_event
  content         String
  createdBy       String?   // user ID or system
  isInternal      Boolean   @default(false)
  
  metadata        Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  
  ticket          support_ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  attachments     support_attachment[]
  
  @@index([ticketId])
  @@index([createdAt])
  @@map("support_interaction")
}

model support_attachment {
  id              String    @id @default(cuid())
  ticketId        String
  interactionId   String?
  fileName        String
  fileType        String
  fileSize        Int
  storagePath     String
  uploadedBy      String?
  
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  
  ticket          support_ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  interaction     support_interaction? @relation(fields: [interactionId], references: [id])
  
  @@index([ticketId])
  @@map("support_attachment")
}

// ============== CRM MODULE: Contact & Activity ==============

enum ContactTier {
  PLATINUM
  GOLD
  SILVER
  STANDARD
}

enum ActivityType {
  BOOKING_CREATED
  BOOKING_MODIFIED
  AMENDMENT_REQUESTED
  TICKET_CREATED
  TICKET_RESOLVED
  EMAIL_SENT
  EMAIL_OPENED
  EMAIL_CLICKED
  PAYMENT_RECEIVED
  REFUND_ISSUED
  VISITOR_CONVERTED
  OTHER
}

enum CommunicationPreference {
  EMAIL
  SMS
  BOTH
  NONE
}

enum EmailFrequency {
  DAILY
  WEEKLY
  MONTHLY
  NEVER
}

model contact {
  id                String    @id @default(cuid())
  userId            String    @unique
  email             String    @db.VarChar(255)
  firstName         String?
  lastName          String?
  phoneNumber       String?   @db.VarChar(20)
  avatarUrl         String?
  
  tier              ContactTier @default(STANDARD)
  totalBookings     Int       @default(0)
  totalSpent        Float     @default(0)
  bookingsCount     Int       @default(0)
  openTicketsCount  Int       @default(0)
  
  communicationPref CommunicationPreference @default(EMAIL)
  languagePreference String?   @default("en")
  marketingConsent  Boolean   @default(true)
  
  metadata          Json?
  notes             String?
  
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  lastInteractionAt DateTime? @db.Timestamptz(6)
  
  activities        activity[]
  preferences       contact_preference?
  comments          contact_comment[]
  
  @@index([userId])
  @@index([email])
  @@index([tier])
  @@map("contact")
}

model activity {
  id                String    @id @default(cuid())
  contactId         String
  type              ActivityType
  title             String
  
  bookingId         String?
  ticketId          String?
  amendmentId       String?
  emailCampaignId   String?
  
  description       String?
  metadata          Json?
  
  createdBy         String?
  isInternal        Boolean   @default(false)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  
  contact           contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  @@index([contactId])
  @@index([type])
  @@index([createdAt(sort: Desc)])
  @@map("activity")
}

model contact_preference {
  id                String    @id @default(cuid())
  contactId         String    @unique
  
  marketingEmail    Boolean   @default(true)
  marketingSms      Boolean   @default(false)
  marketingPush     Boolean   @default(false)
  promotionalOffers Boolean   @default(true)
  newsletter        Boolean   @default(true)
  
  emailFrequency    EmailFrequency @default(WEEKLY)
  smsFrequency      EmailFrequency @default(NEVER)
  
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  updatedBy         String?
  
  contact           contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  @@map("contact_preference")
}

model contact_comment {
  id                String    @id @default(cuid())
  contactId         String
  content           String
  isInternal        Boolean   @default(true)
  
  createdBy         String
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime? @db.Timestamptz(6)
  
  contact           contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  
  @@index([contactId])
  @@index([createdAt(sort: Desc)])
  @@map("contact_comment")
}

// ============== MARKETING MODULE: Campaigns & Assets ==============

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  COMPLETED
  PAUSED
}

enum RecipientStatus {
  PENDING
  SENT
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  CONVERTED
}

model email_suppression_list {
  id                String    @id @default(cuid())
  email             String    @unique @db.VarChar(255)
  reason            String?   @db.VarChar(100)
  
  bounceType        String?   @db.VarChar(50)
  bounceSubtype     String?   @db.VarChar(50)
  
  metadata          Json?
  addedAt           DateTime  @default(now()) @db.Timestamptz(6)
  
  @@index([email])
  @@index([addedAt(sort: Desc)])
  @@map("email_suppression_list")
}

model email_campaign {
  id                String    @id @default(cuid())
  campaignId        String    @unique
  
  name              String
  subject           String
  description       String?
  
  segmentationRules Json     // e.g., {tier: ['GOLD', 'PLATINUM']}
  estimatedRecipients Int
  
  templateId        String?
  htmlContent       String?
  textContent       String?
  previewText       String?
  
  status            CampaignStatus @default(DRAFT)
  scheduledFor      DateTime? @db.Timestamptz(6)
  startedAt         DateTime? @db.Timestamptz(6)
  completedAt       DateTime? @db.Timestamptz(6)
  
  totalSent         Int       @default(0)
  totalOpened       Int       @default(0)
  totalClicked      Int       @default(0)
  totalConverted    Int       @default(0)
  totalBounced      Int       @default(0)
  totalComplained   Int       @default(0)
  
  conversionEvent   String?
  
  createdBy         String
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  
  recipients        campaign_recipient[]
  
  @@index([campaignId])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("email_campaign")
}

model campaign_recipient {
  id                String    @id @default(cuid())
  campaignId        String
  userId            String
  email             String    @db.VarChar(255)
  
  resendMessageId   String?
  
  status            RecipientStatus @default(PENDING)
  
  sentAt            DateTime? @db.Timestamptz(6)
  openedAt          DateTime? @db.Timestamptz(6)
  openedCount       Int       @default(0)
  
  clickedAt         DateTime? @db.Timestamptz(6)
  clickedCount      Int       @default(0)
  
  bouncedAt         DateTime? @db.Timestamptz(6)
  bounceType        String?
  bounceReason      String?
  
  complainedAt      DateTime? @db.Timestamptz(6)
  convertedAt       DateTime? @db.Timestamptz(6)
  conversionValue   Float?
  
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  
  campaign          email_campaign @relation(fields: [campaignId], references: [campaignId], onDelete: Cascade)
  
  @@index([campaignId])
  @@index([userId])
  @@index([email])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@map("campaign_recipient")
}

model marketing_flyer {
  id                String    @id @default(cuid())
  flyerId           String    @unique
  
  title             String
  description       String?
  
  designJson        Json     // Flyer builder JSON
  thumbnailUrl      String?
  previewUrl        String?
  
  shareableLink     String?   @unique
  shareViews        Int       @default(0)
  shareClicks       Int       @default(0)
  
  facebookShares    Int       @default(0)
  whatsappShares    Int       @default(0)
  twitterShares     Int       @default(0)
  linkedinShares    Int       @default(0)
  instagramShares   Int       @default(0)
  telegramShares    Int       @default(0)
  totalShares       Int       @default(0)
  
  qrCodeText        String?
  qrCodeImageUrl    String?
  
  isPublished       Boolean   @default(false)
  featured          Boolean   @default(false)
  
  createdBy         String
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  
  shareLinks        flyer_share_link[]
  
  @@index([flyerId])
  @@index([createdAt(sort: Desc)])
  @@index([isPublished])
  @@map("marketing_flyer")
}

model asset_file {
  id                String    @id @default(cuid())
  
  fileName          String
  originalFileName  String
  fileType          String?
  fileSize          Int
  mimeType          String?
  
  storagePath       String
  thumbnailPath     String?
  altText           String?
  
  width             Int?
  height            Int?
  
  uploadedBy        String
  uploadedAt        DateTime  @default(now()) @db.Timestamptz(6)
  lastAccessedAt    DateTime? @db.Timestamptz(6)
  cleanupAt         DateTime? @db.Timestamptz(6)
  
  isBackup          Boolean   @default(false)
  metadata          Json?
  
  @@index([uploadedAt(sort: Desc)])
  @@index([cleanupAt])
  @@map("asset_file")
}

model flyer_share_link {
  id                String    @id @default(cuid())
  flyerId           String
  shareKey          String    @unique
  
  views             Int       @default(0)
  clicks            Int       @default(0)
  
  platform          String?
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  
  flyer             marketing_flyer @relation(fields: [flyerId], references: [flyerId], onDelete: Cascade)
  
  @@index([shareKey])
  @@index([flyerId])
  @@map("flyer_share_link")
}

// ============== VISITOR TRACKING ==============

enum DeviceType {
  MOBILE
  DESKTOP
  TABLET
}

enum VisitorStatus {
  ACTIVE
  CONVERTED
  INACTIVE
}

model online_visitor {
  id                String    @id @default(cuid())
  sessionId         String    @unique
  
  userId            String?
  email             String?   @db.VarChar(255)
  
  pageViews         Int       @default(1)
  searchQueries     Int       @default(0)
  
  source            String?
  campaign          String?
  referrer          String?
  
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  utmTerm           String?
  
  deviceType        DeviceType @default(DESKTOP)
  deviceOs          String?
  browserName       String?
  browserVersion    String?
  
  country           String?
  countryCode       String?   @db.Char(2)
  region            String?
  city              String?
  latitude          Float?
  longitude         Float?
  
  lastPageUrl       String?
  lastSearchQuery   String?
  
  convertedAt       DateTime? @db.Timestamptz(6)
  convertedToBooking Boolean  @default(false)
  bookingId         String?
  
  leadScore         Int       @default(0)
  
  firstSeenAt       DateTime  @default(now()) @db.Timestamptz(6)
  lastSeenAt        DateTime  @updatedAt @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  
  pageViews_rel     visitor_page_view[]
  searches          visitor_search[]
  
  @@index([sessionId])
  @@index([email])
  @@index([userId])
  @@index([source])
  @@index([lastSeenAt(sort: Desc)])
  @@index([convertedAt])
  @@map("online_visitor")
}

model visitor_page_view {
  id                String    @id @default(cuid())
  visitorId         String
  
  pageUrl           String
  pageTitle         String?
  pageType          String?
  
  searchParams      Json?
  viewDurationSecs  Int?
  
  referrer          String?
  metadata          Json?
  
  viewedAt          DateTime  @default(now()) @db.Timestamptz(6)
  
  visitor           online_visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  
  @@index([visitorId])
  @@index([viewedAt(sort: Desc)])
  @@map("visitor_page_view")
}

model visitor_search {
  id                String    @id @default(cuid())
  visitorId         String
  
  searchType        String
  origin            String?
  destination       String?
  departureDate     DateTime? @db.Date
  returnDate        DateTime? @db.Date
  passengers        Int?
  
  filters           Json?
  resultsCount      Int?
  selectedResultId  String?
  
  metadata          Json?
  searchedAt        DateTime  @default(now()) @db.Timestamptz(6)
  
  visitor           online_visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  
  @@index([visitorId])
  @@index([searchedAt(sort: Desc)])
  @@map("visitor_search")
}

// ============== LEAD MANAGEMENT ==============

enum LeadGrade {
  A
  B
  C
  D
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
  COMPLAINED
  INACTIVE
}

model email_subscriber {
  id                String    @id @default(cuid())
  email             String    @unique @db.VarChar(255)
  
  firstName         String?
  lastName          String?
  phoneNumber       String?   @db.VarChar(20)
  
  leadScore         Int       @default(0)
  leadGrade         LeadGrade @default(C)
  
  status            SubscriberStatus @default(ACTIVE)
  
  interests         String[]
  preferredLanguage String?   @default("en")
  preferredCurrency String?   @db.Char(3)
  
  emailsReceived    Int       @default(0)
  emailsOpened      Int       @default(0)
  emailsClicked     Int       @default(0)
  lastEmailOpenedAt DateTime? @db.Timestamptz(6)
  
  convertedToContact Boolean @default(false)
  contactId         String?
  convertedAt       DateTime? @db.Timestamptz(6)
  
  metadata          Json?
  
  subscribedAt      DateTime  @default(now()) @db.Timestamptz(6)
  unsubscribedAt    DateTime? @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  
  activities        lead_activity[]
  sources           lead_source[]
  segments          segment_member[]
  
  @@index([email])
  @@index([status])
  @@index([leadGrade])
  @@index([leadScore(sort: Desc)])
  @@index([subscribedAt(sort: Desc)])
  @@map("email_subscriber")
}

model lead_activity {
  id                String    @id @default(cuid())
  subscriberId      String
  
  activityType      String
  description       String?
  activityData      Json?
  
  scoreDelta        Int       @default(0)
  
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  
  subscriber        email_subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  
  @@index([subscriberId])
  @@index([activityType])
  @@index([createdAt(sort: Desc)])
  @@map("lead_activity")
}

model lead_source {
  id                String    @id @default(cuid())
  subscriberId      String
  
  source            String
  campaign          String?
  
  utmSource         String?
  utmMedium         String?
  utmCampaign       String?
  utmContent        String?
  utmTerm           String?
  
  referrerUrl       String?
  referrerDomain    String?   @db.VarChar(255)
  
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  
  subscriber        email_subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  
  @@index([subscriberId])
  @@index([source])
  @@map("lead_source")
}

model subscriber_segment {
  id                String    @id @default(cuid())
  name              String
  description       String?
  
  segmentRules      Json     // Segmentation criteria
  memberCount       Int       @default(0)
  
  isActive          Boolean   @default(true)
  
  createdBy         String?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)
  
  members           segment_member[]
  
  @@index([name])
  @@index([isActive])
  @@map("subscriber_segment")
}

model segment_member {
  id                String    @id @default(cuid())
  segmentId         String
  subscriberId      String
  
  addedAt           DateTime  @default(now()) @db.Timestamptz(6)
  removedAt         DateTime? @db.Timestamptz(6)
  
  segment           subscriber_segment @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  subscriber        email_subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  
  @@unique([segmentId, subscriberId])
  @@index([segmentId])
  @@index([subscriberId])
  @@map("segment_member")
}


