// ============== AIRLINE-INITIATED CHANGES ==============

enum AirlineInitiatedChangeStatus {
  pending
  accepted
  declined
  expired
  cancelled
}

enum AirlineInitiatedChangeType {
  schedule_change
  aircraft_change
  cabin_change
  route_change
  cancellation
  other
}

enum AirlineInitiatedActionTaken {
  accept
  decline
  request_refund
  request_alternative
  no_action
}

model duffelAirlineInitiatedChange {
  id              String    @id @default(cuid())
  externalId      String?   @unique
  orderId         String
  
  // Relations
  order           duffelOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  
  // Core change information
  changeType      AirlineInitiatedChangeType
  status          AirlineInitiatedChangeStatus @default(pending)
  actionTaken     AirlineInitiatedActionTaken? @default(no_action)
  
  // Change details
  title           String?
  description     String?
  details         Json?     // Detailed change information (flight numbers, times, etc.)
  options         Json?     // Available options for the passenger (accept, refund, etc.)
  
  // Financial implications
  refundAmount    Decimal?  @db.Decimal(12, 2)
  refundCurrency  String    @default("USD")
  penaltyAmount   Decimal?  @db.Decimal(12, 2)
  penaltyCurrency String    @default("USD")
  
  // Timestamps
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  expiresAt       DateTime? @db.Timestamptz(6)
  notifiedAt      DateTime? @db.Timestamptz(6)
  respondedAt     DateTime? @db.Timestamptz(6)
  
  // Metadata
  metadata        Json?
  
  // Relations to other tables
  changeOptions   duffelAirlineChangeOption[]
  changeActions   duffelAirlineChangeAction[]
  changeDetails   duffelAirlineChangeDetail[]
  
  // Indexes
  @@index([externalId])
  @@index([orderId])
  @@index([status])
  @@index([changeType])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("duffel_airline_initiated_change")
}

model duffelAirlineChangeOption {
  id              String    @id @default(cuid())
  changeId        String
  optionType      String    // "accept", "refund", "alternative", "decline"
  optionValue     String?   // Specific option value
  description     String?
  isRecommended   Boolean   @default(false)
  financialImpact Decimal?  @db.Decimal(12, 2)
  currency        String    @default("USD")
  metadata        Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  
  // Relations
  change          duffelAirlineInitiatedChange @relation(fields: [changeId], references: [id], onDelete: Cascade)
  
  @@index([changeId])
  @@index([optionType])
  @@map("duffel_airline_change_option")
}

model duffelAirlineChangeAction {
  id              String    @id @default(cuid())
  changeId        String
  actionType      String    // "notified", "viewed", "responded", "accepted", "declined"
  actionBy        String?   // User ID or system
  actionDetails   Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  
  // Relations
  change          duffelAirlineInitiatedChange @relation(fields: [changeId], references: [id], onDelete: Cascade)
  
  @@index([changeId])
  @@index([actionType])
  @@index([createdAt])
  @@map("duffel_airline_change_action")
}

model duffelAirlineChangeDetail {
  id              String    @id @default(cuid())
  changeId        String
  detailType      String    // "flight_change", "schedule_change", "aircraft_change", "cabin_change"
  fieldName       String    // "departure_time", "arrival_time", "flight_number", "aircraft_type"
  oldValue        String?
  newValue        String?
  metadata        Json?
  createdAt       DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @db.Timestamptz(6)
  
  // Relations
  change          duffelAirlineInitiatedChange @relation(fields: [changeId], references: [id], onDelete: Cascade)
  
  @@index([changeId])
  @@index([detailType])
  @@index([fieldName])
  @@map("duffel_airline_change_detail")
}

