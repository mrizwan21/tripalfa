  firstName    String?
  lastName     String?
  email        String?
  phone        String?
  dateOfBirth  DateTime?
  passportNo   String?
  createdAt    DateTime @default(now()) @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @db.Timestamptz(6)

  @@index([bookingId])
  @@map("booking_passenger")

  booking booking @relation(fields: [bookingId], references: [id])
}

