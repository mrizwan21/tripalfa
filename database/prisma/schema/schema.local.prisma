// Prisma Schema: tripalfa_local (Static Reference Data)
// Database: PostgreSQL (tripalfa_local)
// Purpose: Static content, hotel data, flight reference lookup tables
// Schemas: shared, hotel, flight
// Note: This database is managed by the hotel importer and sync services; NOT modified by application services.

generator client {
  provider = "prisma-client-js"
  output   = "../../packages/shared-database/src/generated/local"
}

datasource db {
  provider = "postgresql"
  schemas  = ["shared", "hotel", "flight"]
}

// ==============================================================
// SCHEMA: shared
// Canonical reference data — countries, currencies, languages
// ==============================================================

model shared_currency {
  id                   String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code                 String   @unique @db.Char(3)
  name                 String   @db.VarChar(100)
  symbol               String   @db.VarChar(10)
  decimal_precision    Int      @default(2) // Number of decimal places
  rounding_mode        String   @default("ROUND_HALF_UP") @db.VarChar(50) // ROUND_HALF_UP, ROUND_DOWN, ROUND_CEILING, etc.
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)

  countries             shared_country[]
  exchange_rates_from   shared_exchange_rate_history[] @relation("FromCurrency")
  exchange_rates_to     shared_exchange_rate_history[] @relation("ToCurrency")
  hotel_details         hotel_detail[]

  @@map("currencies")
  @@schema("shared")
}

model shared_country {
  id                 String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  iso2_code          String  @unique @db.Char(2)
  iso3_code          String? @unique @db.Char(3)
  dialing_code       String?
  name               String  @db.VarChar(150)
  nationality        String? @db.VarChar(150)
  region             String? @db.VarChar(100)
  default_currency_id String? @db.Uuid
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @db.Timestamptz(6)

  default_currency   shared_currency? @relation(fields: [default_currency_id], references: [id])
  hotel_cities       hotel_city[]
  hotels             hotel_hotel[]
  flight_cities      flight_city[]
  flight_airports    flight_airport[]
  flight_airlines    flight_airline[]
  flight_places      flight_place[]

  @@map("countries")
  @@schema("shared")
}

model shared_language {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  iso_code    String   @unique @db.VarChar(10)
  name        String   @db.VarChar(100)
  native_name String?  @db.VarChar(100)
  flag_url    String?  @db.VarChar(500)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  @@map("languages")
  @@schema("shared")
}

model shared_exchange_rate_history {
  id               String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  from_currency_id String  @db.Uuid
  to_currency_id   String  @db.Uuid
  rate             Decimal @db.Decimal(18, 8)
  source           String? @db.VarChar(50)
  recorded_at      DateTime @default(now()) @db.Timestamptz(6)

  from_currency shared_currency @relation("FromCurrency", fields: [from_currency_id], references: [id], onDelete: Cascade)
  to_currency   shared_currency @relation("ToCurrency", fields: [to_currency_id], references: [id], onDelete: Cascade)

  @@unique([from_currency_id, to_currency_id, recorded_at])
  @@index([from_currency_id], map: "idx_exchange_rate_from")
  @@index([to_currency_id], map: "idx_exchange_rate_to")
  @@index([recorded_at(sort: Desc)], map: "idx_exchange_rate_time")
  @@map("exchange_rate_history")
  @@schema("shared")
}

model shared_ip_geolocation {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ip_address    String   @unique @db.VarChar(45) // Supports IPv4 and IPv6
  country_code  String?  @db.Char(2)
  country_name  String?  @db.VarChar(100)
  region        String?  @db.VarChar(100)
  city          String?  @db.VarChar(100)
  latitude      Decimal? @db.Decimal(9, 6)
  longitude     Decimal? @db.Decimal(9, 6)
  timezone      String?  @db.VarChar(50)
  isp           String?  @db.VarChar(200)
  organization  String?  @db.VarChar(200)
  currency      String?  @db.Char(3)
  cached_at     DateTime @default(now()) @db.Timestamptz(6)
  expires_at    DateTime? @db.Timestamptz(6)

  @@index([ip_address], map: "idx_ip_geolocation_ip")
  @@index([country_code], map: "idx_ip_geolocation_country")
  @@index([cached_at(sort: Desc)], map: "idx_ip_geolocation_cached")
  @@map("ip_geolocation")
  @@schema("shared")
}

// ==============================================================
// SCHEMA: hotel
// Hotels, details, reviews, facilities, rooms, images
// ==============================================================

model hotel_chain {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String   @db.VarChar(200)
  code       String?  @unique @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  hotels hotel_hotel[]

  @@map("chains")
  @@schema("hotel")
}

model hotel_type {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String   @db.VarChar(100)
  code       String?  @unique @db.VarChar(50)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  hotels hotel_hotel[]

  @@map("hotel_types")
  @@schema("hotel")
}

model hotel_city {
  id               String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String  @db.VarChar(200)
  iso2_country_code String @db.Char(2)
  iata_code        String? @db.VarChar(10)
  latitude         Decimal? @db.Decimal(9, 6)
  longitude        Decimal? @db.Decimal(9, 6)
  timezone         String? @db.VarChar(50) // IANA timezone (e.g., 'America/New_York')
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  country shared_country @relation(fields: [iso2_country_code], references: [iso2_code], onDelete: Restrict)
  hotels  hotel_hotel[]

  @@unique([name, iso2_country_code])
  @@index([iso2_country_code], map: "idx_cities_country")
  @@map("cities")
  @@schema("hotel")
}

model hotel_hotel {
  id               String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  liteapi_id       String  @unique @db.VarChar(50)
  name             String  @db.VarChar(500)
  iso2_country_code String @db.Char(2)
  city_id          String? @db.Uuid
  city_name        String? @db.VarChar(200)
  chain_id         String? @db.Uuid
  type_id          String? @db.Uuid
  latitude         Decimal? @db.Decimal(9, 6)
  longitude        Decimal? @db.Decimal(9, 6)
  address          String?
  zip              String? @db.VarChar(20)
  main_photo_url   String?
  stars            Decimal? @db.Decimal(3, 1)
  is_detail_fetched Boolean  @default(false)
  is_reviews_fetched Boolean @default(false)
  phone            String?
  fax              String?
  email            String?
  airport_code     String?   @db.VarChar(10)
  rating           Decimal?  @db.Decimal(4, 2)
  review_count     Int?
  roh_id           Int?
  parking          Boolean?
  group_room_min   Int?
  child_allowed    Boolean?
  pets_allowed     Boolean?
  deleted_at       DateTime? @db.Timestamptz(6)
  last_synced_at   DateTime? @db.Timestamptz(6)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @default(now()) @db.Timestamptz(6)

  country         shared_country       @relation(fields: [iso2_country_code], references: [iso2_code], onDelete: Restrict)
  city            hotel_city?          @relation(fields: [city_id], references: [id])
  chain           hotel_chain?         @relation(fields: [chain_id], references: [id])
  type            hotel_type?          @relation(fields: [type_id], references: [id])
  details         hotel_detail?
  images          hotel_image[]
  facility_map    hotel_facility_map[]
  rooms           hotel_room[]
  policies        hotel_policy[]
  accessibility   hotel_accessibility[]
  reviews         hotel_review[]

  @@index([iso2_country_code], map: "idx_hotels_country")
  @@index([city_id], map: "idx_hotels_city")
  @@index([chain_id], map: "idx_hotels_chain")
  @@index([stars], map: "idx_hotels_stars")
  @@index([liteapi_id], map: "idx_hotels_liteapi_id")
  @@map("hotels")
  @@schema("hotel")
}

model hotel_detail {
  id                   String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hotel_id             String  @unique @db.Uuid
  description          String?
  checkin_time         String? @db.VarChar(10)
  checkout_time        String? @db.VarChar(10)
  currency_code        String? @db.Char(3)
  star_rating          Decimal? @db.Decimal(3, 1)
  facilities           Json?
  facilities_json      Json?
  terms_and_conditions String?
  important_information String?
  checkin_start        String? @db.VarChar(20)
  checkin_end          String? @db.VarChar(20)
  checkout_start       String? @db.VarChar(20)
  checkout_end         String? @db.VarChar(20)
  video_url            String?
  detail_fetched_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @db.Timestamptz(6)

  hotel    hotel_hotel     @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  currency shared_currency? @relation(fields: [currency_code], references: [code])

  @@index([hotel_id], map: "idx_hotel_details_hotel")
  @@map("hotel_details")
  @@schema("hotel")
}

model hotel_image {
  id            String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hotel_id      String   @db.Uuid
  url           String
  thumbnail_url String?
  url_hd        String?
  video_url     String?
  caption       String?  @db.VarChar(500)
  display_order Int?     @default(0) @db.SmallInt
  is_default    Boolean  @default(false)
  is_main       Boolean  @default(false)
  created_at    DateTime @default(now()) @db.Timestamptz(6)

  hotel hotel_hotel @relation(fields: [hotel_id], references: [id], onDelete: Cascade)

  @@index([hotel_id], map: "idx_hotel_images_hotel")
  @@map("images")
  @@schema("hotel")
}

model hotel_facility {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String   @db.VarChar(200)
  category     String?  @db.VarChar(100)
  liteapi_code String?  @unique @db.VarChar(50)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  hotel_map hotel_facility_map[]

  @@map("facilities")
  @@schema("hotel")
}

model hotel_facility_map {
  hotel_id    String @db.Uuid
  facility_id String @db.Uuid

  hotel    hotel_hotel    @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  facility hotel_facility @relation(fields: [facility_id], references: [id], onDelete: Cascade)

  @@id([hotel_id, facility_id])
  @@map("hotel_facility_map")
  @@schema("hotel")
}

model hotel_room {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hotel_id     String   @db.Uuid
  room_type       String   @db.VarChar(200)
  id_liteapi      Int?
  description     String?
  capacity        Int?     @db.SmallInt
  max_adults      Int?     @db.SmallInt
  max_children    Int?     @db.SmallInt
  max_occupancy   Int?     @db.SmallInt
  size_sqm        Decimal? @db.Decimal(6, 2)
  room_size_unit  String?  @db.VarChar(20)
  bed_types_json  Json?
  amenities_json  Json?
  photos_json     Json?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  hotel         hotel_hotel             @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  amenity_map   hotel_room_amenity_map[]
  bed_types     hotel_room_bed_type[]

  @@index([hotel_id], map: "idx_rooms_hotel")
  @@map("rooms")
  @@schema("hotel")
}

model hotel_room_amenity {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String   @db.VarChar(200)
  category   String?  @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamptz(6)

  room_map hotel_room_amenity_map[]

  @@map("room_amenities")
  @@schema("hotel")
}

model hotel_room_amenity_map {
  room_id    String @db.Uuid
  amenity_id String @db.Uuid

  room    hotel_room         @relation(fields: [room_id], references: [id], onDelete: Cascade)
  amenity hotel_room_amenity @relation(fields: [amenity_id], references: [id], onDelete: Cascade)

  @@id([room_id, amenity_id])
  @@map("room_amenity_map")
  @@schema("hotel")
}

model hotel_room_bed_type {
  id         String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  room_id    String @db.Uuid
  bed_type   String @db.VarChar(100)
  count      Int    @default(1) @db.SmallInt

  room hotel_room @relation(fields: [room_id], references: [id], onDelete: Cascade)

  @@map("room_bed_types")
  @@schema("hotel")
}

model hotel_policy {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hotel_id    String   @db.Uuid
  type          String   @db.VarChar(100)
  policy_type   String?  @db.VarChar(100)
  description   String
  child_allowed String?
  pets_allowed  String?
  parking       String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @db.Timestamptz(6)

  hotel hotel_hotel @relation(fields: [hotel_id], references: [id], onDelete: Cascade)

  @@map("policies")
  @@schema("hotel")
}

model hotel_accessibility {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hotel_id   String   @db.Uuid
  feature    String   @db.VarChar(200)
  notes      String?
  created_at DateTime @default(now()) @db.Timestamptz(6)

  hotel hotel_hotel @relation(fields: [hotel_id], references: [id], onDelete: Cascade)

  @@map("accessibility")
  @@schema("hotel")
}

model hotel_review {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hotel_id        String   @db.Uuid
  source          String   @default("liteapi") @db.VarChar(50)
  rating           Decimal? @db.Decimal(3, 1)
  average_score    Decimal? @db.Decimal(3, 1)
  title            String?  @db.VarChar(500)
  headline         String?  @db.VarChar(500)
  content          String?
  pros             String?
  cons             String?
  reviewer_name    String?  @db.VarChar(200)
  reviewer_country String?  @db.Char(2)
  review_date      DateTime? @db.Date
  imported_at     DateTime  @default(now()) @db.Timestamptz(6)

  hotel     hotel_hotel              @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  sentiment hotel_sentiment_analysis?

  @@index([hotel_id], map: "idx_reviews_hotel")
  @@index([source], map: "idx_reviews_source")
  @@map("reviews")
  @@schema("hotel")
}

model hotel_sentiment_analysis {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  review_id   String   @unique @db.Uuid
  sentiment   String   @db.VarChar(20)
  score       Decimal? @db.Decimal(5, 4)
  breakdown   Json?
  analysed_at DateTime @default(now()) @db.Timestamptz(6)

  review hotel_review @relation(fields: [review_id], references: [id], onDelete: Cascade)

  @@index([review_id], map: "idx_sentiment_review")
  @@map("sentiment_analysis")
  @@schema("hotel")
}

// ==============================================================
// SCHEMA: flight
// Airports, airlines, aircraft, cities, loyalty programmes
// ==============================================================

model flight_city {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String   @db.VarChar(200)
  iso2_country_code String  @db.Char(2)
  iata_code        String?  @db.VarChar(10)
  latitude         Decimal? @db.Decimal(9, 6)
  longitude        Decimal? @db.Decimal(9, 6)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  country  shared_country  @relation(fields: [iso2_country_code], references: [iso2_code], onDelete: Restrict)
  airports flight_airport[]

  @@unique([name, iso2_country_code])
  @@index([iata_code], map: "idx_cities_iata")
  @@map("cities")
  @@schema("flight")
}

model flight_airport {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  iata_code        String   @unique @db.Char(3)
  icao_code        String?  @unique @db.Char(4)
  name             String   @db.VarChar(300)
  iso2_country_code String  @db.Char(2)
  city_id          String?  @db.Uuid
  city_name        String?  @db.VarChar(200)
  latitude         Decimal  @db.Decimal(9, 6)
  longitude        Decimal  @db.Decimal(9, 6)
  timezone         String?  @db.VarChar(50)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  country shared_country @relation(fields: [iso2_country_code], references: [iso2_code], onDelete: Restrict)
  city    flight_city?   @relation(fields: [city_id], references: [id])

  @@index([iso2_country_code], map: "idx_airports_country")
  @@index([city_id], map: "idx_airports_city")
  @@map("airports")
  @@schema("flight")
}

model flight_airline {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  iata_code        String?  @unique @db.Char(2)
  icao_code        String?  @unique @db.Char(3)
  name             String   @db.VarChar(300)
  iso2_country_code String? @db.Char(2)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  country            shared_country?              @relation(fields: [iso2_country_code], references: [iso2_code])
  loyalty_programmes flight_loyalty_programme[]

  @@index([iso2_country_code], map: "idx_airlines_country")
  @@map("airlines")
  @@schema("flight")
}

model flight_aircraft {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  iata_type    String?  @unique @db.VarChar(10)
  icao_type    String?  @db.VarChar(10)
  name         String   @db.VarChar(200)
  manufacturer String?  @db.VarChar(100)
  created_at   DateTime @default(now()) @db.Timestamptz(6)

  @@map("aircraft")
  @@schema("flight")
}

model flight_loyalty_programme {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  airline_id  String   @db.Uuid
  name        String   @db.VarChar(200)
  code        String?  @unique @db.VarChar(50)
  website_url String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @db.Timestamptz(6)

  airline flight_airline @relation(fields: [airline_id], references: [id], onDelete: Cascade)

  @@index([airline_id], map: "idx_loyalty_airline")
  @@map("loyalty_programmes")
  @@schema("flight")
}

model flight_place {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String   @db.VarChar(300)
  type             String?  @db.VarChar(50)
  iso2_country_code String? @db.Char(2)
  latitude         Decimal? @db.Decimal(9, 6)
  longitude        Decimal? @db.Decimal(9, 6)
  external_id      String?  @db.VarChar(100)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @db.Timestamptz(6)

  country shared_country? @relation(fields: [iso2_country_code], references: [iso2_code])

  @@index([iso2_country_code], map: "idx_places_country")
  @@map("places")
  @@schema("flight")
}
