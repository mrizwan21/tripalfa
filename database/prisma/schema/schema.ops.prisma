// Prisma Schema: tripalfa_ops (Operational database)
// Database: PostgreSQL (tripalfa_ops)
// Purpose: Notifications, rules engine, documents, disputes management
//
// KNOWN DUPLICATES: The following models also exist in schema.core.prisma:
// - activity (core has canonical version)
// - contact (core has canonical version)
// - document (core has canonical version)
// - document_access (core has canonical version)
// - document_template (core has canonical version)
// - email_suppression_list (core uses snake_case naming)
// - email_campaign (core uses snake_case naming)
// - campaign_recipient (core uses snake_case naming)
// - online_visitor (core uses snake_case naming)
// - visitor_page_view (core uses snake_case naming)
// - visitor_search (core uses snake_case naming)
// - email_subscriber (core uses snake_case naming)
// - asset_file (core uses snake_case naming)
// - marketing_flyer (core uses snake_case naming)
//
// TODO: Consolidate these models to use the core schema as single source of truth.
// Migration plan: Remove ops duplicates and update services to use core schema.

generator client {
  provider = "prisma-client-js"
  output   = "../../packages/shared-database/src/generated/ops"
}

datasource db {
  provider = "postgresql"
}

// ============== NOTIFICATIONS SYSTEM ==============

model notification {
  id                String    @id @default(cuid())
  userId            String
  orderId           String?
  bookingId         String?
  notificationType  String
  priority          String    @default("medium")
  status            String    @default("pending")
  channels          String[]
  content           Json
  contentHash       String?
  metadata          Json?
  tags              String[]  @default([])
  sentAt            DateTime? @db.Timestamptz(6)
  deliveredAt       DateTime? @db.Timestamptz(6)
  openedAt          DateTime? @db.Timestamptz(6)
  failureReason     String?
  isDLQ             Boolean   @default(false)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([status])
  @@index([bookingId])
  @@map("notification")
}

model channel_status {
  id                String    @id @default(cuid())
  notificationId    String
  channel           String
  sentAt            DateTime? @db.Timestamptz(6)
  deliveredAt       DateTime? @db.Timestamptz(6)
  openedAt          DateTime? @db.Timestamptz(6)
  clickedAt         DateTime? @db.Timestamptz(6)
  failedAt          DateTime? @db.Timestamptz(6)
  messageId         String?
  error             String?
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  @@unique([notificationId, channel])
  @@index([notificationId])
  @@map("channel_status")
}

model notification_template {
  id                String    @id @default(cuid())
  name              String
  type              String
  subtype           String?
  version           String    @default("1.0")
  content           Json?
  htmlTemplate      String?
  variables         String[]  @default([])
  isActive          Boolean   @default(true)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([type])
  @@map("notification_template")
}

model notification_retry {
  id                String    @id @default(cuid())
  notificationId    String
  channel           String?
  attemptNumber     Int       @default(1)
  maxRetries        Int       @default(3)
  nextRetryAt       DateTime? @db.Timestamptz(6)
  lastError         String?
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([notificationId])
  @@map("notification_retry")
}

model notification_analytic {
  id                String    @id @default(cuid())
  notificationId    String
  eventType         String?
  eventData         Json?
  timestamp         DateTime? @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  @@index([notificationId])
  @@map("notification_analytic")
}

model notification_metric {
  id                String    @id @default(cuid())
  notificationType  String
  channel           String?
  period            String?
  sentCount         Int       @default(0)
  deliveredCount    Int       @default(0)
  openedCount       Int       @default(0)
  failedCount       Int       @default(0)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([notificationType])
  @@map("notification_metric")
}

model scheduled_notification {
  id                String    @id @default(cuid())
  userId            String
  templateId        String?
  notificationType  String?
  channels          String[]
  variables         Json?
  scheduledFor      DateTime  @db.Timestamptz(6)
  jobQueueId        String?
  status            String    @default("scheduled")
  sentAt            DateTime? @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([scheduledFor])
  @@map("scheduled_notification")
}

model notification_target {
  id                String    @id @default(cuid())
  userId            String
  contactType       String
  contactValue      String
  isVerified        Boolean   @default(false)
  isPreferred       Boolean   @default(false)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([contactType])
  @@map("notification_target")
}

model dead_letter_queue {
  id                String    @id @default(cuid())
  originalNotificationId String?
  reason            String?
  failureCount      Int       @default(0)
  lastError         String?
  payload           Json?
  status            String    @default("dead_letter")
  replayedAt        DateTime? @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@map("dead_letter_queue")
}

model webhook_event {
  id                String    @id @default(cuid())
  provider          String
  eventType         String
  payload           Json?
  status            String    @default("received")
  processedAt       DateTime? @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  @@index([provider])
  @@index([eventType])
  @@map("webhook_event")
}

// ============== WEBHOOK DELIVERY SYSTEM ==============

enum WebhookDeliveryStatus {
  PENDING
  DELIVERING
  DELIVERED
  FAILED
  RETRYING
  DEAD_LETTER
}

model webhook_delivery {
  id                    String                  @id @default(cuid())
  // Source information
  provider              String                  // e.g., "duffel", "liteapi", "internal"
  eventType             String                  // e.g., "order.created"
  webhookId             String?                 // ID from source system
  payload               Json?                   // Original payload
  signature             String?                 // HMAC signature for verification
  verificationStatus    String?                 // "verified", "invalid", "skipped"
  
  // Target information
  endpointUrl           String                  // Customer endpoint URL
  customerId            String?                 // Associated customer/tenant
  subscriptionId        String?                 // Webhook subscription ID
  
  // Delivery status
  status                WebhookDeliveryStatus   @default(PENDING)
  attemptCount          Int                     @default(0)
  maxRetries            Int                     @default(3)
  nextRetryAt           DateTime?               @db.Timestamptz(6)
  
  // Response details
  responseStatusCode    Int?
  responseBody          String?                 @db.Text
  responseHeaders       Json?
  deliveredAt           DateTime?               @db.Timestamptz(6)
  
  // Error information
  lastError             String?                 @db.Text
  errorCode             String?
  
  // Timestamps
  createdAt             DateTime                @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime                @updatedAt @db.Timestamptz(6)
  
  // Indexes
  @@index([provider])
  @@index([eventType])
  @@index([status])
  @@index([customerId])
  @@index([createdAt])
  @@index([nextRetryAt])
  @@map("webhook_delivery")
}

// ============== RULE ENGINE ==============

model rule {
  id                String    @id @default(cuid())
  name              String
  description       String?
  category          String?
  trigger           Json?
  triggerEvent      String?
  condition         Json?
  actions           Json?
  priority          Int       @default(50)
  status            String    @default("draft")
  enabled           Boolean   @default(false)
  version           Int       @default(1)
  timeout           Int?
  maxRetries        Int?
  asyncExecution    Boolean   @default(false)
  tags              String[]  @default([])
  totalExecutions   Int       @default(0)
  successCount      Int       @default(0)
  failureCount      Int       @default(0)
  lastExecutedAt    DateTime? @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([category])
  @@index([enabled])
  @@map("rule")
}

model rule_execution {
  id                String    @id @default(cuid())
  ruleId            String
  userId            String?
  status            String    @default("pending")
  startedAt         DateTime? @db.Timestamptz(6)
  completedAt       DateTime? @db.Timestamptz(6)
  inputData         Json?
  outputData        Json?
  conditionMet      Boolean?
  conditionEval     Json?
  actionsExecuted   String[]
  executionTime     Int?
  error             String?
  errorType         String?
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  @@index([ruleId])
  @@index([status])
  @@map("rule_execution")
}

model rule_analysis {
  id                String    @id @default(cuid())
  ruleId            String
  riskLevel         String?
  conflictCount     Int       @default(0)
  conflicts         Json?
  performance       Json?
  recommendations   String[]
  analysisData      Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([ruleId])
  @@map("rule_analysis")
}

// ============== DOCUMENTS & DOCUMENT MANAGEMENT ==============

model document {
