  mimeType          String?
  fileSize          Int?
  expiresAt         DateTime? @db.Timestamptz(6)
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([userId])
  @@index([bookingId])
  @@index([type])
  @@map("document")
}

model document_access {
  id                String    @id @default(cuid())
  documentId        String
  userId            String
  action            String
  accessedAt        DateTime  @default(now()) @db.Timestamptz(6)
  ipAddress         String?
  metadata          Json?

  @@index([documentId])
  @@index([userId])
