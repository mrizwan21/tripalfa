  resolvedAt        DateTime? @db.Timestamptz(6)
  resolvedBy        String?
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([bookingId])
  @@index([userId])
  @@index([status])
  @@map("dispute")
}

model settlement {
  id                String    @id @default(cuid())
  bookingId         String?
  walletId          String?
  amount            Decimal?  @db.Decimal(12, 2)
  settlementDate    DateTime? @db.Timestamptz(6)
  referenceId       String?
  status            String    @default("pending")
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([bookingId])
  @@index([status])
  @@map("settlement")
}

// ============== CRM SYSTEM ==============

model contact {
  id                String    @id @default(cuid())
  userId            String    @unique
  email             String    @unique
  firstName         String
  lastName          String
  tier              String    @default("bronze") // bronze, silver, gold, platinum
  totalBookings     Int       @default(0)
  totalSpent        Decimal   @default(0) @db.Decimal(12, 2)
  bookingsCount     Int       @default(0)
  openTicketsCount  Int       @default(0)
  source            String?   @default("direct")
  phone             String?
  location          String?
  metadata          Json?
  lastActivity      DateTime  @updatedAt @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([email])
  @@index([userId])
  @@index([tier])
  @@index([createdAt])
  @@map("contact")
}

model activity {
  id                String    @id @default(cuid())
  contactId         String
  type              String    // BOOKING_CREATED, TICKET_CREATED, EMAIL_SENT, etc.
  title             String
  description       String?
  bookingId         String?
  ticketId          String?
  metadata          Json?
  createdBy         String?
  isInternal        Boolean   @default(false)
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)

  @@index([contactId])
  @@index([type])
  @@index([createdAt])
  @@index([contactId, createdAt])
  @@map("activity")
}

model emailCampaign {
  id                String    @id @default(cuid())
  name              String
  subject           String
  html              String?
  previewText       String?
  recipientCount    Int       @default(0)
  sentCount         Int       @default(0)
  openedCount       Int       @default(0)
  clickedCount      Int       @default(0)
  convertedCount    Int       @default(0)
  segmentationRules Json?
  status            String    @default("draft") // draft, scheduled, running, completed
  scheduledFor      DateTime? @db.Timestamptz(6)
  completedAt       DateTime? @db.Timestamptz(6)
  templateId        String?
  metadata          Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@index([createdAt])
  @@map("email_campaign")
}

model campaignRecipient {
  id                String    @id @default(cuid())
