# ============================================================
# TripAlfa Static Database — Environment Variables
# Copy to .env and fill in real values
# ============================================================

# --- PostgreSQL (Docker) ---
STATICDB_NAME=tripalfa_static
STATICDB_USER=staticdb_admin
STATICDB_PASSWORD=your_strong_password_here
STATICDB_PORT=5435
STATICDB_HOST=localhost

# --- pgAdmin ---
PGADMIN_EMAIL=admin@tripalfa.com
PGADMIN_PASSWORD=your_pgadmin_password_here
PGADMIN_PORT=5051

# --- LiteAPI ---
LITEAPI_KEY=your_liteapi_sandbox_or_production_key

# --- Duffel ---
DUFFEL_API_KEY=your_duffel_access_token_here

# --- OpenExchangeRates ---
OER_APP_ID=8d44ab64feac4666aed17e66dd939a9e

# --- Sync Settings ---
# Number of parallel API requests (stay within rate limits)
SYNC_CONCURRENCY=5
# Countries to pre-fetch hotel cities for (comma-separated ISO-2)
LITEAPI_SEED_COUNTRIES=US,GB,AE,FR,DE,ES,IT,JP,SG,AU,IN,TH,TR,MX,BR
# Max hotels to fetch per country batch (LiteAPI max=5000)
LITEAPI_HOTELS_LIMIT=200
