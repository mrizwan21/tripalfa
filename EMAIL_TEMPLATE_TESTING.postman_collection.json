    {
      "name": "6. Test With Custom Data",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"templateStyle\": \"detailed\",\n  \"toEmail\": \"{{test_email}}\",\n  \"testOrderData\": {\n    \"id\": \"ord_custom_test_001\",\n    \"booking_reference\": \"CUSTOM1A2B\",\n    \"custom_metadata\": {\n      \"customer_id\": \"cust_custom_001\"\n    },\n    \"created_at\": \"2024-01-15T10:00:00Z\",\n    \"total_price\": \"1299.99\",\n    \"total_currency\": \"USD\",\n    \"base_amount\": \"1000.00\",\n    \"tax_amount\": \"299.99\",\n    \"total_amount\": \"1299.99\",\n    \"email\": \"{{test_email}}\",\n    \"passengers\": [\n      {\n        \"id\": \"pas_001\",\n        \"name\": \"Executive Traveler\",\n        \"email\": \"{{test_email}}\",\n        \"given_name\": \"Executive\",\n        \"family_name\": \"Traveler\",\n        \"cabin_class\": \"business\",\n        \"seat_designator\": \"1A\"\n      },\n      {\n        \"id\": \"pas_002\",\n        \"name\": \"Companion Traveler\",\n        \"given_name\": \"Companion\",\n        \"family_name\": \"Traveler\",\n        \"cabin_class\": \"business\",\n        \"seat_designator\": \"1B\"\n      }\n    ],\n    \"slices\": [\n      {\n        \"id\": \"slice_001\",\n        \"segments\": [\n          {\n            \"id\": \"seg_001\",\n            \"operating_flight_number\": \"LH456\",\n            \"flight_number\": \"LH456\",\n            \"departing_at\": \"2024-02-01T08:00:00Z\",\n            \"arriving_at\": \"2024-02-01T18:30:00Z\",\n            \"origin\": {\n              \"iata_code\": \"SFO\",\n              \"city_name\": \"San Francisco\",\n              \"icao_code\": \"KSFO/T1\"\n            },\n            \"destination\": {\n              \"iata_code\": \"LHR\",\n              \"city_name\": \"London\",\n              \"icao_code\": \"EGLL/T2\"\n            },\n            \"airlines\": [\n              {\n                \"name\": \"Lufthansa\"\n              }\n            ],\n            \"operating_carrier\": {\n              \"name\": \"Lufthansa\"\n            },\n            \"aircraft\": {\n              \"name\": \"Airbus A350\"\n            }\n          }\n        ]\n      }\n    ]\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/webhooks/email-templates/send-test",
