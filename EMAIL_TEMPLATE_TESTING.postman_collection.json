          "raw": "{\n  \"templateStyle\": \"detailed\",\n  \"toEmail\": \"{{test_email}}\",\n  \"templateOptions\": {\n    \"includeTerminals\": true,\n    \"includeOperatingAirline\": true,\n    \"includeDuration\": true,\n    \"includeSeatInfo\": true,\n    \"includePricingBreakdown\": true\n  }\n}"
        },
