{
  "name": "booking-engine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^3.10.0",
    "@nestjs/swagger": "^11.2.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@shadcn/ui": "^0.0.4",
    "@tanstack/react-query": "^4.43.0",
    "@tripalfa/static-data": "^1.0.0",
    "@tripalfa/ui-components": "^1.0.0",
    "react-query": "^3.39.3",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "axios": "^1.0.0",
    "clsx": "^2.0.0",
    "date-fns": "^4.1.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "lint-staged": "16.2.7",
    "lucide-react": "0.462.0",
    "multer": "2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.19",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@faker-js/faker": "^10.2.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^18.19.130",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.23",
    "dotenv": "^16.6.1",
    "jsdom": "^23.0.1",
    "postcss": "^8.5.6",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:errors": "npx playwright test tests/e2e/payment.spec.ts tests/e2e/validation-errors.spec.ts tests/e2e/timeout-errors.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "TEST_SMOKE_ONLY=true playwright test",
    "test:e2e:ci": "TEST_ENV=ci playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:staging": "TEST_ENV=staging playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:enhanced": "playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:visual": "TEST_VISUAL=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:mobile": "TEST_MOBILE=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:firefox": "TEST_FIREFOX=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:webkit": "TEST_WEBKIT=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:cross-browser": "TEST_FIREFOX=true TEST_WEBKIT=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:tagged": "playwright test --grep",
    "test:e2e:report:enhanced": "playwright show-report playwright-report-local",
    "test:e2e:report:ci": "playwright show-report playwright-report-ci",
    "test:e2e:report:staging": "playwright show-report playwright-report-staging"
  }
}
