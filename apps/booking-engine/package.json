{
  "name": "@tripalfa/booking-engine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@nestjs/swagger": "^11.2.6",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@shadcn/ui": "^0.0.4",
    "@tanstack/react-query": "^5.90.21",
    "@tripalfa/api-clients": "workspace:*",
    "@tripalfa/static-data": "workspace:*",
    "@tripalfa/ui-components": "workspace:*",
    "@typescript-eslint/eslint-plugin": "8.55.0",
    "@typescript-eslint/parser": "8.55.0",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "framer-motion": "^12.34.0",
    "lint-staged": "16.2.7",
    "lucide-react": "^0.564.0",
    "mapbox-gl": "^3.18.1",
    "multer": "2.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-router": "^7.13.0",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@alloc/quick-lru": "^5.2.0",
    "@faker-js/faker": "^10.2.0",
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.3.1",
    "jsdom": "^28.0.0",
    "msw": "^2.1.5",
    "postcss": "^8.5.6",
    "stylelint": "^17.3.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "generate:static": "pnpm dlx tsx scripts/generate-static-data.ts",
    "generate:static:watch": "pnpm dlx tsx watch scripts/generate-static-data.ts",
    "dev": "pnpm exec vite",
    "dev:test": "NODE_ENV=test VITE_TEST_MODE=true pnpm exec vite --port 5174",
    "build": "pnpm exec vite build",
    "preview": "pnpm exec vite preview",
    "test": "pnpm exec vitest",
    "test:e2e": "playwright test",
    "test:e2e:modules": "playwright test --config=playwright.config.simple.ts",
    "test:e2e:errors": "npx playwright test tests/e2e/payment.spec.ts tests/e2e/validation-errors.spec.ts tests/e2e/timeout-errors.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "TEST_SMOKE_ONLY=true playwright test",
    "test:e2e:ci": "TEST_ENV=ci playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:staging": "TEST_ENV=staging playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:enhanced": "playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:visual": "TEST_VISUAL=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:mobile": "TEST_MOBILE=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:firefox": "TEST_FIREFOX=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:webkit": "TEST_WEBKIT=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:cross-browser": "TEST_FIREFOX=true TEST_WEBKIT=true playwright test --config=playwright.config.enhanced.ts",
    "test:e2e:tagged": "playwright test --grep",
    "test:e2e:report:enhanced": "playwright show-report playwright-report-local",
    "test:e2e:report:ci": "playwright show-report playwright-report-ci",
    "test:e2e:report:staging": "playwright show-report playwright-report-staging",
    "test:api:duffel-flight-integration": "npx ts-node scripts/test-duffel-flight-integration.ts",
    "test:e2e:duffel-flights": "playwright test tests/e2e/duffel-flight-integration.spec.ts",
    "test:e2e:duffel-flights:headed": "playwright test tests/e2e/duffel-flight-integration.spec.ts --headed",
    "test:e2e:duffel-flights:debug": "playwright test tests/e2e/duffel-flight-integration.spec.ts --debug",
    "test:ci": "NODE_ENV=test VITE_TEST_MODE=false npm run test:e2e:ci"
  }
}
