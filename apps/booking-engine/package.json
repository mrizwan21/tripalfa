{
  "name": "@tripalfa/booking-engine",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "zod": "^4.3.6",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "tailwindcss": "^4.1.18",
    "@radix-ui/react-popover": "^1.1.15",
    "tailwind-merge": "^3.4.0",
    "react-router-dom": "^7.13.0",
    "@tanstack/react-query": "^5.90.21",
    "@tripalfa/api-clients": "workspace:*",
    "@tripalfa/shared-types": "workspace:*",
    "@tripalfa/static-data": "workspace:*",
    "@tripalfa/ui-components": "workspace:*",
    "@typescript-eslint/eslint-plugin": "8.55.0",
    "@typescript-eslint/parser": "8.55.0",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "eslint": "9.39.2",
    "react-hook-form": "^7.71.1",
    "framer-motion": "^12.34.0",
    "lint-staged": "16.2.7",
    "lucide-react": "^0.564.0",
    "mapbox-gl": "^3.18.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "vitest": "^4.0.18",
    "vite": "^7.3.1",
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/mapbox-gl": "^3.4.1",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.23",
    "dotenv": "^17.3.1",
    "jsdom": "^28.0.0",
    "msw": "^2.1.5",
    "postcss": "^8.5.6",
    "stylelint": "^17.3.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "generate:static": "pnpm dlx tsx scripts/generate-static-data.ts",
    "generate:static:watch": "pnpm dlx tsx watch scripts/generate-static-data.ts",
    "dev": "pnpm exec vite",
    "dev:test": "NODE_ENV=test VITE_TEST_MODE=true pnpm exec vite --config vite.config.e2e.ts --port 5174",
    "build": "pnpm exec vite build",
    "preview": "pnpm exec vite preview",
    "test": "pnpm exec vitest",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:mock": "TEST_MODE_MOCK=true playwright test --config=playwright.config.ts",
    "test:e2e:ui": "playwright test --config=playwright.config.ts --ui",
    "test:e2e:debug": "playwright test --config=playwright.config.ts --debug",
    "test:e2e:headed": "playwright test --config=playwright.config.ts --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:smoke": "TEST_SMOKE_ONLY=true playwright test --config=playwright.config.ts",
    "test:e2e:ci": "TEST_ENV=ci playwright test --config=playwright.config.ts",
    "test:e2e:staging": "TEST_ENV=staging playwright test --config=playwright.config.ts",
    "test:e2e:visual": "TEST_VISUAL=true playwright test --config=playwright.config.ts",
    "test:e2e:mobile": "TEST_MOBILE=true playwright test --config=playwright.config.ts",
    "test:e2e:firefox": "TEST_FIREFOX=true playwright test --config=playwright.config.ts",
    "test:e2e:webkit": "TEST_WEBKIT=true playwright test --config=playwright.config.ts",
    "test:e2e:cross": "TEST_FIREFOX=true TEST_WEBKIT=true playwright test --config=playwright.config.ts",
    "test:e2e:tagged": "playwright test --config=playwright.config.ts --grep",
    "test:e2e:duffel": "playwright test tests/e2e/duffel-flight-integration.spec.ts --config=playwright.config.ts",
    "test:ci": "NODE_ENV=test VITE_TEST_MODE=false npm run test:e2e:ci"
  }
}
