# TripAlfa Booking Engine - Environment Variables
# Copy this file to .env.local and update values as needed

# API Gateway URL (Kong proxy port: 8000)
# All API requests will be routed through the gateway
VITE_GATEWAY_URL=http://localhost:8000

# WebSocket Gateway URL (for real-time notifications)
# Should point to the gateway's WebSocket endpoint
VITE_GATEWAY_WS_URL=ws://localhost:8000

# Other environment variables
# VITE_WS_URL is deprecated - use VITE_GATEWAY_WS_URL instead
# VITE_API_URL is deprecated - use VITE_GATEWAY_URL instead
