# Staging Environment Configuration for E2E Testing
# Epic: 99ed40b1-7f2a-4835-8eda-9976e060bb30
# Spec: d0e3e304-309a-40c0-8e50-cc7e6322d692

# Test Environment
TEST_ENV=staging
NODE_ENV=test

# Base URLs (Staging)
BASE_URL=https://staging.tripalfa.com
API_URL=https://api-staging.tripalfa.com

# Database Configuration (Staging)
DATABASE_URL=postgresql://neondb_owner:password@staging-db.tripalfa.com:5432/neondb_staging

# Test User Credentials (Staging)
TEST_USER_EMAIL=staging-test@example.com
TEST_USER_PASSWORD=StagingTest@123
TEST_ADMIN_EMAIL=staging-admin@example.com
TEST_ADMIN_PASSWORD=StagingAdmin@123

# API Keys (Staging/Sandbox)
STRIPE_PUBLISHABLE_KEY=pk_test_staging
STRIPE_SECRET_KEY=sk_test_staging
HOTELSTON_API_KEY=staging_key
DUFFEL_API_KEY=staging_key

# Feature Flags for Testing
TEST_MODE_FLIGHTS=false
TEST_MODE_HOTELS=false
TEST_MODE_PAYMENTS=false
MOCK_EXTERNAL_SERVICES=false

# Test Execution Settings
TEST_WORKERS=4
TEST_RETRIES=1
TEST_TIMEOUT=120000

# Reporting
ALLURE_RESULTS_DIR=test-results/allure-results

# Debug Settings
DEBUG_TESTS=false
SLOW_MO=0
RECORD_HAR=false

# Mobile Testing (enabled for staging)
TEST_MOBILE=true
TEST_TABLET=true
