# CI Environment Configuration for E2E Testing
# Epic: 99ed40b1-7f2a-4835-8eda-9976e060bb30
# Spec: d0e3e304-309a-40c0-8e50-cc7e6322d692

# Test Environment
TEST_ENV=ci
NODE_ENV=test
CI=true

# Base URLs
BASE_URL=http://localhost:3002
API_URL=http://localhost:3003

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/tripalfa_test

# Test User Credentials
TEST_USER_EMAIL=testuser1@example.com
TEST_USER_PASSWORD=Test@123
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=Admin@123

# API Keys (Test/Sandbox)
STRIPE_PUBLISHABLE_KEY=pk_test_sample
STRIPE_SECRET_KEY=sk_test_sample
HOTELSTON_API_KEY=test_key
DUFFEL_API_KEY=test_key

# Feature Flags for Testing
TEST_MODE_FLIGHTS=true
TEST_MODE_HOTELS=true
TEST_MODE_PAYMENTS=true
MOCK_EXTERNAL_SERVICES=true

# Test Execution Settings
TEST_WORKERS=2
TEST_RETRIES=2
TEST_TIMEOUT=90000

# Reporting
ALLURE_RESULTS_DIR=test-results/allure-results

# Debug Settings (disabled in CI)
DEBUG_TESTS=false
SLOW_MO=0
RECORD_HAR=false
