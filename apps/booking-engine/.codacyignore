# Codacy ignore file

## Ignore all TypeScript and JavaScript files

*.ts
*.tsx
*.js
*.jsx

# Ignore configuration files

*.json
*.config.js
*.config.ts
*.config.json
*.d.ts

# Ignore test files and directories

tests/
test-results/
playwright-report/

