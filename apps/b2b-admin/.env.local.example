# Example env for local development (do NOT commit real keys)

# API Gateway Configuration
VITE_USE_API_GATEWAY=false
VITE_API_GATEWAY_URL=http://localhost:3000

# Microservice URLs
REACT_APP_PAYMENT_SERVICE_URL=http://localhost:3003
REACT_APP_KYC_SERVICE_URL=http://localhost:3008
REACT_APP_MARKETING_SERVICE_URL=http://localhost:3009
REACT_APP_SUPPORT_SERVICE_URL=http://localhost:3010
REACT_APP_TAX_SERVICE_URL=http://localhost:3011
REACT_APP_AUDIT_SERVICE_URL=http://localhost:3012

# Replace with the API key generated in Kong (do NOT commit secrets)
VITE_API_KEY=YOUR_ADMIN_API_KEY_HERE
