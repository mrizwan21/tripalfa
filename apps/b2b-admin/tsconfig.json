{
  "compilerOptions": {
    "target": "ESNext",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ESNext"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/components/ui/*": [
        "../../packages/ui-components/ui/*"
      ],
      "@/components/dashboard/*": [
        "./src/features/dashboard/components/*"
      ],
      "@/lib/*": [
        "./src/shared/lib/*"
      ],
      "@tripalfa/rules": [
        "../../packages/rules"
      ],
      "@tripalfa/rules/*": [
        "../../packages/rules/*"
      ],
      "@tripalfa/shared-utils": [
        "../../packages/shared-utils"
      ],
      "@tripalfa/shared-utils/*": [
        "../../packages/shared-utils/*"
      ],
      "@tripalfa/ui-components": [
        "../../packages/ui-components"
      ],
      "@tripalfa/ui-components/*": [
        "../../packages/ui-components/*"
      ],
      "@tripalfa/shared-types": [
        "../../packages/shared-types"
      ],
      "@tripalfa/shared-types/*": [
        "../../packages/shared-types/*"
      ],
      "@tripalfa/api-clients": [
        "../../packages/api-clients"
      ],
      "@tripalfa/api-clients/*": [
        "../../packages/api-clients/*"
      ]
    },
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.tsx",
    "**/*.test.ts",
    "**/__tests__/**"
  ]
}
