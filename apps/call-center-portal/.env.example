# Call Center Portal Environment
# All API requests must go through the API Gateway (Kong)
VITE_GATEWAY_URL=http://localhost:8000

# WebSocket Gateway URL (for real-time features)
VITE_GATEWAY_WS_URL=ws://localhost:8000

# FusionAuth Configuration (if used)
# VITE_FUSIONAUTH_URL=http://localhost:9011
# VITE_FUSIONAUTH_API_KEY=your_api_key
# VITE_FUSIONAUTH_APP_ID=your_app_id
