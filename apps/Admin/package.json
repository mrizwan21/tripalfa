{
  "name": "@tripalfa/b2b-admin",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm exec vite",
    "build": "cd ../.. && pnpm exec tsc --noEmit --project apps/b2b-admin/tsconfig.json && cd apps/b2b-admin && pnpm exec vite build",
    "preview": "pnpm exec vite preview",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "test": "vitest --globals --environment jsdom",
    "test:watch": "vitest --watch --globals --environment jsdom",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@mui/material": "^7.3.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "@tripalfa/api-clients": "workspace:*",
    "@tripalfa/shared-types": "workspace:*",
    "axios": "^1.7.7",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.564.0",
    "next-themes": "^0.4.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.1",
    "react-router-dom": "^7.12.0",
    "recharts": "^2.15.4",
    "sonner": "^1.7.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^5.1.3",
    "autoprefixer": "^10.4.23",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
