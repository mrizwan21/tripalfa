{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "ignoreDeprecations": "5.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@tripalfa/shared-types": ["packages/shared-types/src"],
      "@tripalfa/shared-types/*": ["packages/shared-types/src/*"],
      "@tripalfa/shared-utils": ["packages/shared-utils/src"],
      "@tripalfa/shared-utils/*": ["packages/shared-utils/src/*"],
      "@tripalfa/shared-database": ["packages/shared-database/src"],
      "@tripalfa/shared-database/*": ["packages/shared-database/src/*"],
      "@tripalfa/shared-express": ["packages/shared-express/src"],
      "@tripalfa/shared-express/*": ["packages/shared-express/src/*"],
      "@tripalfa/shared-openapi": ["packages/shared-openapi/src"],
      "@tripalfa/shared-openapi/*": ["packages/shared-openapi/src/*"],
      "@tripalfa/wallet": ["packages/wallet/src"],
      "@tripalfa/wallet/*": ["packages/wallet/src/*"],
      "@tripalfa/static-data": ["packages/static-data/src"],
      "@tripalfa/static-data/*": ["packages/static-data/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
