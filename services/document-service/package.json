{
  "name": "@tripalfa/document-service",
  "version": "1.0.0",
  "description": "Document generation and management service for TripAlfa",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@prisma/client": "*",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "jsonwebtoken": "^9.0.2",
    "puppeteer": "^19.0.0",
    "handlebars": "^4.7.7",
    "aws-sdk": "^2.1400.0",
    "sharp": "^0.32.0",
    "node-cron": "^3.0.2",
    "bull": "^4.10.3",
    "redis": "^4.6.7",
    "uuid": "^9.0.0",
    "axios": "^1.4.0",
    "date-fns": "^2.30.0",
    "joi": "^17.9.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/jest": "^29.5.0",
    "typescript": "^5.0.0",
    "ts-node": "^10.9.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "prettier": "^2.8.0",
    "eslint": "^8.40.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
