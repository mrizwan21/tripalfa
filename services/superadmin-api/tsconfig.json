{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "rootDir": "../../",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "types": ["node", "react", "react-dom", "jest"]
  },
  "include": ["src/**/*", "../../packages/shared-types/src/**/*"]
}