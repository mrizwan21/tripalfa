{
  "name": "@tripalfa/organization-service",
  "version": "1.0.0",
  "description": "Organization management service for TripAlfa",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm dlx tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "pnpm exec eslint 'src/**/*.{ts,tsx}' --no-error-on-unmatched-pattern",
    "type-check": "pnpm exec tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^7.4.0",
    "@tripalfa/shared-database": "workspace:*",
    "@tripalfa/shared-types": "workspace:*",
    "@tripalfa/shared-utils": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.0.6",
    "jsonwebtoken": "^9.0.3",
    "multer": "2.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^25.2.1",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
