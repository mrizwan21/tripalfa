    "lint": "pnpm exec eslint src --ext .ts",
    "test": "pnpm exec vitest --passWithNoTests"
  },
  "dependencies": {
    "@tripalfa/shared-database": "workspace:*",
    "@tripalfa/shared-types": "workspace:*",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.1",
    "express-validator": "^7.2.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.0.0",
    "zod": "^3.23.11"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.2.3",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.4"
  }
}
