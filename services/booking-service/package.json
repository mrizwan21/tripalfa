{
  "name": "booking-service",
  "version": "1.0.0",
  "description": "Booking service for Travel Kingdom microservices architecture",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "start:worker": "tsx src/notifications/worker/bullWorker.ts",
    "test:notifications:integration": "tsx src/notifications/tests/producer_worker_integration.test.ts",
    "build": "esbuild src/main.ts --bundle --platform=node --outfile=dist/main.js --minify --sourcemap --external:express-rate-limit --external:@prisma/adapter-neon",
    "test:server:ci": "node src/notifications/tests/producer_worker_integration.test.js",
    "migrate:neon": "ts-node src/notifications/scripts/apply_migration_neon.ts",
    "test": "jest --runInBand",
    "test:unit": "INTEGRATION_DB=false jest --testPathPattern=unit --runInBand",
    "test:integration": "INTEGRATION_DB=true TEST_DB_RESET=true jest --testPathPattern=integration --runInBand",
    "test:integration:api": "INTEGRATION_DB=true TEST_DB_RESET=true jest --testPathPattern='tests/integration' --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:watch": "jest --watch",
    "test:watch:integration": "INTEGRATION_DB=true jest --testPathPattern=integration --watch --runInBand",
    "test:integration:e2e": "NODE_ENV=test jest --testPathPattern=e2e --runInBand",
    "test:seed": "ts-node tests/integration/seed.ts",
    "test:seed:reset": "ts-node tests/integration/seed.ts --reset",
    "test:setup": "npm run test:seed && npm run test:integration",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "docker:build": "docker build -t booking-service .",
    "docker:run": "docker run -p 3001:3001 booking-service",
    "docker:run:dev": "docker run -p 3001:3001 -e PORT=3001 booking-service"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-neon": "^7.3.0",
    "@types/ioredis": "^4.28.10",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "effect": "^3.18.4",
    "eslint-plugin-react-hooks": "7.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.11.2",
    "express-validator": "^7.3.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.9.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "16.2.7",
    "mongoose": "^7.5.0",
    "morgan": "^1.10.0",
    "node-mailjet": "^6.0.11",
    "nodemailer": "7.0.12",
    "pg": "^8.11.3",
    "portal-env": "^0.0.1-security",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sequelize": "^6.35.2",
    "uuid": "^9.0.1",
    "vite": "7.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.2",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.18.2",
    "@types/express-validator": "^2.20.33",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.97",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.30",
    "@types/passport": "^1.0.17",
    "@types/passport-apple": "^2.0.3",
    "@types/passport-azure-ad": "^4.3.6",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-github": "^1.1.13",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/passport-local-mongoose": "^6.1.5",
    "@types/passport-microsoft": "^2.1.1",
    "@types/passport-oauth2": "^1.8.0",
    "@types/passport-openidconnect": "^0.1.3",
    "@types/passport-saml": "^1.1.7",
    "@types/passport-twitter": "^1.0.40",
    "@types/pg": "^8.16.0",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^2.0.16",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "bcrypt": "^5.1.1",
    "esbuild": "^0.27.3",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prisma": "^6.19.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "microservices",
    "booking",
    "travel",
    "express"
  ],
  "author": "Travel Kingdom Team",
  "license": "MIT"
}