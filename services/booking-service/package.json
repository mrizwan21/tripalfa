{
  "name": "@tripalfa/booking-service",
  "version": "1.0.0",
  "description": "Booking management service for TripAlfa",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm dlx tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "pnpm exec eslint 'src/**/*.{ts,tsx}' --no-error-on-unmatched-pattern",
    "type-check": "pnpm exec tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^7.4.0",
    "@tripalfa/shared-database": "workspace:*",
    "@tripalfa/shared-openapi": "workspace:*",
    "@tripalfa/shared-types": "workspace:*",
    "@types/multer": "^2.0.0",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.1.0",
    "pg": "^8.11.0",
    "redis": "^4.7.0",
    "swagger-jsdoc": "^6.2.8",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.2.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "prisma": "^7.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
