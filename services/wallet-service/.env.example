# Wallet Service Environment Configuration

# Server
NODE_ENV=development
PORT=3007

# Database (Neon Postgres)
# Example Neon connection string:
# DATABASE_URL=postgresql://<user>:<password>@<project-id>.<region>.neon.tech/<db>?sslmode=require
DATABASE_URL=postgresql://your_user:your_password@your_project_id.your_region.neon.tech/your_db?sslmode=require

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_change_in_production

# External APIs
OPEN_EXCHANGE_RATES_API_KEY=your_openexchangerates_api_key
OPENEXCHANGERATES_BASE_URL=https://openexchangerates.org/api

# FX Fetching Schedule
# Cron format: minute hour dayOfMonth month dayOfWeek
FX_FETCH_SCHEDULE=5 * * * *

# Reconciliation Schedule
RECONCILIATION_SCHEDULE=0 2 * * *

# Logging
LOG_LEVEL=info

# Feature Flags
ENABLE_LEDGER_AUDIT=true
ENABLE_WEBHOOK_SIGNATURE_VERIFICATION=true
ALLOW_TEST_MODE=false

# Stripe Integration (optional)
STRIPE_API_KEY=sk_live_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_secret

# PayPal Integration (optional)
PAYPAL_CLIENT_ID=your_client_id
PAYPAL_CLIENT_SECRET=your_client_secret
PAYPAL_MODE=sandbox

# Wise Integration (optional)
WISE_API_KEY=your_wise_api_key
WISE_PROFILE_ID=your_profile_id

# Settlement Config
SETTLEMENT_MIN_AMOUNT=100
SETTLEMENT_MAX_WAIT_DAYS=30
AUTO_RECONCILE_ENABLED=true

# Security
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
ENABLE_REQUEST_VALIDATION=true
ENABLE_RESPONSE_COMPRESSION=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
SENTRY_DSN=https://your_sentry_dsn
