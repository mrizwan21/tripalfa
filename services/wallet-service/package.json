{
  "name": "wallet-service",
  "version": "1.0.0",
  "description": "Multi-currency wallet service with FX management and ledger tracking",
  "type": "module",
  "main": "dist/app.js",
  "scripts": {
    "build": "pnpm exec tsc",
    "start": "node dist/app.js",
    "dev": "pnpm dlx tsx watch src/app.ts",
    "test": "pnpm exec jest",
    "test:watch": "pnpm exec jest --watch",
    "lint": "pnpm exec eslint src/**/*.ts",
    "lint:fix": "pnpm exec eslint src/**/*.ts --fix",
    "migrations": "node dist/scripts/runMigrations.js",
    "fx:fetch": "node dist/jobs/fxFetcher.js --now",
    "fx:schedule": "node dist/jobs/fxFetcher.js",
    "reconcile": "node dist/jobs/reconciliationJob.js --now",
    "docker:build": "docker build -t wallet-service .",
    "docker:run": "docker run -p 3008:3008 wallet-service"
  },
  "dependencies": {
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^7.4.0",
    "@tripalfa/shared-database": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.2.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.2",
    "node-fetch": "^2.7.0",
    "uuid": "^9.0.1",
    "vite": "7.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^2.0.12",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.5.0",
    "nodemon": "^3.0.1",
    "prisma": "^7.4.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "wallet",
    "multi-currency",
    "fx",
    "ledger",
    "microservices"
  ],
  "author": "Travel Kingdom Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}