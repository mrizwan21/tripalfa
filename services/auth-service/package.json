{
  "name": "@tripalfa/auth-service",
  "version": "1.0.0",
  "description": "Authentication service for TripAlfa",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm dlx tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "pnpm exec eslint 'src/**/*.{ts,tsx}' --no-error-on-unmatched-pattern",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@prisma/client": "^7.4.0",
    "@tripalfa/shared-database": "workspace:*",
    "@tripalfa/shared-openapi": "workspace:*",
    "@tripalfa/shared-types": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^5.0.6",
    "jsonwebtoken": "^9.0.2",
    "@node-rs/bcrypt": "1.10.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^25.2.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3"
  }
}
