{
  "name": "inventory-service",
  "version": "1.0.0",
  "description": "Inventory service for Travel Kingdom microservices architecture",
  "type": "module",
  "main": "src/app.ts",
  "scripts": {
    "start": "tsx src/app.ts",
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "docker:build": "docker build -t inventory-service .",
    "docker:run": "docker run -p 3002:3002 inventory-service"
  },
  "dependencies": {
    "@nestjs/swagger": "^11.2.6",
    "@prisma/client": "^6.19.2",
    "@tripalfa/shared-types": "*",
    "axios": "^1.6.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "morgan": "^1.10.0",
    "node-cache": "^5.1.2",
    "node-cron": "^3.0.2",
    "pg": "^8.11.3",
    "prisma": "^6.19.2",
    "sequelize": "^6.35.2",
    "string-similarity": "^4.0.4",
    "vite": "7.3.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node-cache": "^4.1.3",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "jest": "^29.5.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.1.3"
  },
  "keywords": [
    "microservices",
    "inventory",
    "travel",
    "express"
  ],
  "author": "Travel Kingdom Team",
  "license": "MIT"
}