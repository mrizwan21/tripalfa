{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "lib": [
      "ES2020"
    ],
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "rootDir": "../..",
    "resolveJsonModule": true,
"skipLibCheck": true,
    "types": ["node", "react", "react-dom", "jest"]
  },
  "include": [
    "src"
  ]
}