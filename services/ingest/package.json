{
  "name": "@tripalfa/ingest-service",
  "version": "1.0.0",
  "description": "Static data import service for multiple suppliers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "import-static": "tsx src/cli.ts",
    "import-hotel-reference": "tsx src/import-hotel-reference.ts",
    "import-hotelbeds": "tsx src/cli.ts hotelbeds-hotels",
    "import-hotelbeds-incremental": "tsx src/cli.ts hotelbeds-hotels --incremental",
    "import-liteapi": "tsx src/cli.ts liteapi-all",
    "import-liteapi-hotels": "tsx src/cli.ts liteapi-hotels",
    "import-liteapi-reviews": "tsx src/cli.ts liteapi-reviews",
    "import-liteapi-reference": "tsx src/cli.ts liteapi-reference",
    "import-duffel": "tsx src/cli.ts duffel-all",
    "import-duffel-logos": "tsx src/cli.ts duffel-all --download-logos",
    "import-duffel-airlines": "tsx src/cli.ts duffel-airlines",
    "import-duffel-aircraft": "tsx src/cli.ts duffel-aircraft",
    "import-duffel-airports": "tsx src/cli.ts duffel-airports",
    "import-duffel-cities": "tsx src/cli.ts duffel-cities",
    "import-duffel-loyalty": "tsx src/cli.ts duffel-loyalty",
    "update-image-dimensions": "tsx src/update-image-dimensions.ts",
    "seed-suppliers": "tsx ../../database/prisma/seed-suppliers.ts",
    "seed-currencies": "tsx src/seed-currencies.ts",
    "migrate-inventory": "tsx ../../scripts/migrate-hotel-inventory.ts",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src/**/*.ts",
    "test": "vitest"
  },
  "dependencies": {
    "@prisma/client": "^7.4.0",
    "@tripalfa/shared-database": "workspace:*",
    "axios": "^1.6.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "csv-parse": "^5.5.0",
    "p-queue": "^8.0.0",
    "p-retry": "^6.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "prisma": "^7.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}