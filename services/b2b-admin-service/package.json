{
  "name": "@tripalfa/b2b-admin-service",
  "version": "1.0.0",
  "description": "B2B Admin Backend Service for TripAlfa",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "pnpm dlx tsx watch src/index.ts",
    "build": "pnpm exec tsc",
    "start": "node dist/index.js",
    "lint": "pnpm exec eslint src --ext .ts",
    "test": "pnpm exec vitest --passWithNoTests"
  },
  "dependencies": {
    "@tripalfa/shared-database": "workspace:*",
    "@tripalfa/shared-types": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-validator": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^14.20.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.1.4",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.14.0",
    "openapi3-ts": "^4.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
