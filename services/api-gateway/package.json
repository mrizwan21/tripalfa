{
  "name": "@tripalfa/api-gateway",
  "version": "1.0.0",
  "description": "Central API gateway for TripAlfa microservices",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "pnpm exec tsc",
    "dev": "pnpm dlx tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "pnpm exec eslint src --ext .ts,.tsx",
    "type-check": "pnpm exec tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tripalfa/shared-types": "workspace:*",
    "express": "^5.0.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "axios": "^1.7.2",
    "@prisma/client": "^7.4.0",
    "pg": "^8.11.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "@types/jsonwebtoken": "^9.0.5",
    "typescript": "^5.9.3",
    "tsx": "^4.7.0",
    "@types/jest": "^29.5.12"
  }
}
