{
  "name": "@tripalfa/static-data-service",
  "version": "1.0.0",
  "description": "Static data microservice — serves airports, airlines, cities, currencies, hotel amenities etc. directly from PostgreSQL",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npx tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@prisma/adapter-pg": "^6.0.0",
    "express": "^5.0.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "@types/pg": "^8.11.6",
    "typescript": "^5.9.3",
    "tsx": "^4.7.0"
  }
}
