# =========================================================
# Static Data Service — Environment Variables
# Copy this file to .env and update the values below.
# =========================================================

# PostgreSQL connection string for the local/staging DB.
# This service uses raw pg (no Prisma client generation required).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tripalfa"

# Port the service listens on.
# Vite proxies /static/* → http://localhost:$STATIC_DATA_SERVICE_PORT/*
STATIC_DATA_SERVICE_PORT=3002

# Node environment
NODE_ENV=development
