# TripAlfa Local Deployment Environment Configuration
# Copy this file to .env.local and fill in your actual values
# This is for LOCAL DEVELOPMENT ONLY

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Neon Cloud PostgreSQL (Application Data)
NEON_DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@your-neon-host.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=20"
DIRECT_NEON_DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@your-neon-host.neon.tech/neondb?sslmode=require"

# Local PostgreSQL (Static Reference Data)
# Default: PostgreSQL running on localhost:5433
# If using a different host/port, update the connection string
STATIC_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/staticdatabase"

# Redis Cache (Local Instance)
REDIS_URL="redis://localhost:6379"

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================

NODE_ENV="development"

# ============================================================================
# DOCKER NETWORK CONFIGURATION
# ============================================================================
# Set to 1 if running services in Docker containers (uses container names as hostnames)
# Leave unset or set to 0 for local development (uses localhost)
USE_DOCKER_NETWORK=0

# ============================================================================
# SERVICE PORTS (Local Process Deployment)
# ============================================================================
# Each service runs as a local process on its designated port
# Change these only if ports are already in use on your machine

API_GATEWAY_PORT=3000
BOOKING_SERVICE_PORT=3001
STATIC_DATA_SERVICE_PORT=3002
USER_SERVICE_PORT=3004
ORGANIZATION_SERVICE_PORT=3006
PAYMENT_SERVICE_PORT=3007
WALLET_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3009
RULE_ENGINE_SERVICE_PORT=3010
KYC_SERVICE_PORT=3011
MARKETING_SERVICE_PORT=3012
B2B_ADMIN_SERVICE_PORT=3020
BOOKING_ENGINE_SERVICE_PORT=3021

BOOKING_ENGINE_FRONTEND_PORT=5174
B2B_ADMIN_FRONTEND_PORT=5173

# ============================================================================
# JWT & SECURITY
# ============================================================================

JWT_SECRET="your-jwt-secret-key-change-in-production"
JWT_EXPIRY="7d"
JWT_ISSUER="https://tripinfo.com"
JWT_AUDIENCE="tripinfo-app"

# ============================================================================
# EXTERNAL API KEYS
# ============================================================================

# Duffel Flight Integration
DUFFEL_API_KEY="your_duffel_test_api_key"
DUFFEL_ENV="test"  # "test" or "live"

# LiteAPI Hotel Integration
LITEAPI_API_KEY="your_liteapi_test_api_key"
LITEAPI_BASE_URL="https://api.liteapi.com"

# IP Geolocation API (https://ipapi.co) - Free tier: 1000 requests/day
IPAPI_API_KEY="your_ipapi_api_key"

# Amadeus Flight Integration
AMADEUS_CLIENT_ID="your_amadeus_client_id"
AMADEUS_CLIENT_SECRET="your_amadeus_client_secret"
AMADEUS_ENV="test"  # "test" or "live"

# Stripe Payment Processing
STRIPE_SECRET_KEY="sk_test_your_stripe_test_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_test_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Google OAuth
VITE_GOOGLE_CLIENT_ID="your_google_client_id.apps.googleusercontent.com"

# Facebook OAuth
VITE_FACEBOOK_APP_ID="your_facebook_app_id"

# Apple OAuth
VITE_APPLE_CLIENT_ID="your_apple_client_id"

# Weather API (Optional)
VITE_OPENWEATHERMAP_API_KEY="your_openweathermap_api_key"

# ============================================================================
# SERVICE DISCOVERY (Local Deployment)
# ============================================================================
# All services communicate via localhost on designated ports
# No need to change these for local development

API_GATEWAY_URL="http://localhost:3000"
BOOKING_SERVICE_URL="http://localhost:3001"
STATIC_DATA_SERVICE_URL="http://localhost:3002"
USER_SERVICE_URL="http://localhost:3004"
ORGANIZATION_SERVICE_URL="http://localhost:3006"
PAYMENT_SERVICE_URL="http://localhost:3007"
WALLET_SERVICE_URL="http://localhost:3008"
NOTIFICATION_SERVICE_URL="http://localhost:3009"
RULE_ENGINE_SERVICE_URL="http://localhost:3010"
KYC_SERVICE_URL="http://localhost:3011"
MARKETING_SERVICE_URL="http://localhost:3012"
B2B_ADMIN_SERVICE_URL="http://localhost:3020"
BOOKING_ENGINE_SERVICE_URL="http://localhost:3021"

# ============================================================================
# FRONTEND CONFIGURATION
# ============================================================================

VITE_API_BASE_URL="http://localhost:3000/api"
VITE_API_URL="http://localhost:3000/api"
VITE_API_GATEWAY_URL="http://localhost:3000"
VITE_APP_URL="http://localhost:5174"
VITE_WS_URL="ws://localhost:3001"  # WebSocket URL for real-time features

# Booking Engine specific
VITE_BOOKING_ENGINE_API_URL="http://localhost:3000/api"
VITE_BOOKING_ENGINE_STATIC_URL="http://localhost:3002/static"

# B2B Admin specific
VITE_B2B_ADMIN_API_URL="http://localhost:3000/api"

# ============================================================================
# NOTIFICATION CONFIGURATION
# ============================================================================

# Email Service
EMAIL_SERVICE_PROVIDER="sendgrid"  # or "smtp", "mailgun", etc.
SENDGRID_API_KEY="your_sendgrid_api_key"
EMAIL_FROM="noreply@tripinfo.com"

# SMS Service (Optional)
SMS_SERVICE_PROVIDER="twilio"  # or "aws_sns", "vonage", etc.
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# Push Notifications
VITE_VAPID_PUBLIC_KEY="your_vapid_public_key"
VAPID_PRIVATE_KEY="your_vapid_private_key"

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

LOG_LEVEL="debug"  # "debug", "info", "warn", "error"
LOG_FORMAT="json"  # "json" or "text"

# Sentry (Error Tracking) - Optional
SENTRY_DSN="your_sentry_dsn"
SENTRY_ENVIRONMENT="local"

# ============================================================================
# FEATURE FLAGS
# ============================================================================

ENABLE_CACHING=true
ENABLE_WALLET=true
ENABLE_LOYALTY=true
ENABLE_FLIGHT_BOOKING=true
ENABLE_HOTEL_BOOKING=true
ENABLE_PAYMENT_PROCESSING=true
ENABLE_KYC_VERIFICATION=false  # Usually disabled in development

# Demo/Test Mode
VITE_DEMO_MODE=false
VITE_TEST_MODE=false

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

CACHE_TTL_HOTELS=3600
CACHE_TTL_FLIGHTS=1800
CACHE_TTL_STATIC_DATA=86400
CACHE_TTL_RATES=900

# ============================================================================
# RATE LIMITING
# ============================================================================

RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

CORS_ORIGIN="http://localhost:5173,http://localhost:5174,http://localhost:3000"
CORS_CREDENTIALS=true

# ============================================================================
# ANALYTICS & TRACKING (Optional)
# ============================================================================

VITE_GOOGLE_ANALYTICS_ID="your_ga_id"
VITE_MIXPANEL_TOKEN="your_mixpanel_token"

# ============================================================================
# NOTES
# ============================================================================
# 1. Never commit .env.local or keys to version control
# 2. For production, use secure secret management (e.g., AWS Secrets Manager)
# 3. All service URLs use localhost for local development
# 4. Static database on port 5433 must be running separately
# 5. Redis on port 6379 must be running (optional for development)
# 6. Neon database credentials can be found in your Neon dashboard
