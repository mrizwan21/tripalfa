# TripAlfa Local Development Configuration
# Copy this to .env.local and adjust values as needed

# ============================================
# Database Configuration — TWO databases
# ============================================

# 1. Application DB (Neon in production, local Postgres for dev)
#    Contains: users, bookings, payments, notifications, wallets, etc.
#    Docker container: postgres-app on port 5432
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/neondb"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/neondb"

# 2. Static Data DB (always local Docker Postgres)
#    Contains: airports, airlines, cities, hotels, destinations, amenities, etc.
#    Docker container: postgres-static on port 5433
STATIC_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/staticdatabase"

# ============================================
# Service Ports
# ============================================

NOTIFICATION_SERVICE_PORT=3001
RULE_ENGINE_SERVICE_PORT=3002
API_GATEWAY_PORT=3000

# ============================================
# Service URLs
# ============================================

# When running locally (not in Docker)
NOTIFICATION_SERVICE_URL="http://localhost:3001"
RULE_ENGINE_SERVICE_URL="http://localhost:3002"

# When running in Docker Compose
# NOTIFICATION_SERVICE_URL="http://notification-service:3001"
# RULE_ENGINE_SERVICE_URL="http://rule-engine-service:3002"

# ============================================
# Environment & Logging
# ============================================

NODE_ENV=development
LOG_LEVEL=debug

# ============================================
# Rate Limiting (Development - Permissive)
# ============================================

RATE_LIMIT_REQUESTS_PER_MINUTE=100
RATE_LIMIT_REQUESTS_PER_HOUR=5000

# ============================================
# API Keys (Optional - for external integrations)
# ============================================

API_KEY=dev_local_key_12345

# OpenWeatherMap API - Weather data for hotel locations
# Sign up at: https://openweathermap.org/api/one-call-3
VITE_OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# ============================================
# Testing & Debug
# ============================================

DEBUG=true
SHOW_SQL=false
