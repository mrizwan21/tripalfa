{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["vitest/globals", "node"],
    "allowJs": true,
    "isolatedModules": false,
    "verbatimModuleSyntax": false
  },
  "include": [
    "vitest.config.ts",
    "vitest.workspace.ts",
    "**/__tests__/**/*",
    "**/*.test.ts",
    "**/*.spec.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/dist/**"
  ]
}