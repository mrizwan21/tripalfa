{
  "$schema": "https://json.schemastore.org/package.json",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@prisma/client": "7.4.0",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.2.1",
    "@types/pg": "^8.16.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.3.2",
    "markdownlint": "^0.40.0",
    "prettier": "^3.8.1",
    "prisma": "7.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "consolidate": "pnpm dlx tsx scripts/consolidate-hotel-data.ts",
    "consolidate:analyze": "pnpm dlx tsx scripts/consolidate-hotel-data.ts --analyze",
    "consolidate:mishor": "pnpm dlx tsx scripts/consolidate-hotel-data.ts --mishor",
    "consolidate:innstant": "pnpm dlx tsx scripts/consolidate-hotel-data.ts --innstant",
    "lint": "pnpm exec eslint .",
    "lint:fix": "pnpm exec eslint . --fix",
    "format": "pnpm exec prettier --write .",
    "build": "pnpm recursive run build",
    "dev": "pnpm recursive run dev",
    "db:migrate": "pnpm exec prisma migrate deploy --schema=database/prisma/schema.prisma",
    "db:generate": "pnpm exec prisma generate --schema=database/prisma/schema.prisma",
    "db:push": "pnpm exec prisma db push --schema=database/prisma/schema.prisma",
    "db:reset": "pnpm exec prisma db push --force-reset --schema=database/prisma/schema.prisma",
    "db:studio": "pnpm exec prisma studio --schema=database/prisma/schema.prisma",
    "neon:rebuild:optimized": "bash scripts/neon/rebuild-neon-optimized.sh",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "husky",
    "ci:lint": "eslint . --ext .ts,.tsx --ignore-pattern node_modules_trash/** --ignore-pattern **/node_modules_trash/**",
    "ci:docs:runtime-consistency": "bash scripts/verify-doc-runtime-consistency.sh",
    "ci:enforce-no-js": "bash scripts/ci-check-no-js.sh",
    "ci": "npm run ci:lint && npm run ci:docs:runtime-consistency && npm run ci:enforce-no-js",
    "test:e2e:errors": "npm run test:e2e:errors --workspace=booking-engine",
    "setup:api:sandbox": "bash scripts/setup/setup-api-sandbox.sh",
    "test:api:duffel": "ts-node scripts/test-duffel-sandbox.ts",
    "test:api:liteapi": "pnpm dlx tsx scripts/test-liteapi-sandbox.ts",
    "test:api:liteapi:config": "pnpm dlx tsx scripts/test-liteapi-config.ts",
    "test:api:liteapi:all-keys": "pnpm dlx tsx scripts/test-liteapi-all-keys.ts",
    "test:api:liteapi:cancellation": "pnpm dlx tsx scripts/test-liteapi-cancellation-refund.ts",
    "test:api:liteapi:errors": "pnpm dlx tsx scripts/test-liteapi-error-scenarios.ts",
    "test:api:liteapi:workflows": "pnpm dlx tsx scripts/test-liteapi-additional-workflows.ts",
    "test:api:liteapi:orchestrator": "pnpm dlx tsx scripts/booking-workflow-orchestrator.ts",
    "test:api:liteapi:orchestrator:local": "pnpm dlx tsx scripts/booking-workflow-orchestrator.ts",
    "test:api:liteapi:performance": "LOAD_LEVEL=medium pnpm dlx tsx scripts/test-liteapi-performance.ts",
    "test:api:liteapi:performance:light": "LOAD_LEVEL=light pnpm dlx tsx scripts/test-liteapi-performance.ts",
    "test:api:liteapi:performance:high": "LOAD_LEVEL=high pnpm dlx tsx scripts/test-liteapi-performance.ts",
    "test:api:liteapi:performance:stress": "LOAD_LEVEL=stress pnpm dlx tsx scripts/test-liteapi-performance.ts",
    "test:api:liteapi:e2e": "npm run test:api:liteapi && npm run test:api:liteapi:cancellation",
    "test:api:liteapi:comprehensive": "npm run test:api:liteapi && npm run test:api:liteapi:cancellation && npm run test:api:liteapi:errors && npm run test:api:liteapi:workflows && npm run test:api:liteapi:orchestrator",
    "test:api:wallet:orchestrator": "pnpm dlx tsx scripts/wallet-management-orchestrator.ts",
    "test:api:wallet:orchestrator:verbose": "VERBOSE=true pnpm dlx tsx scripts/wallet-management-orchestrator.ts",
    "test:api:wallet:e2e": "npm run test:api:wallet:orchestrator",
    "test:api:supplier-wallet:e2e": "pnpm dlx tsx scripts/supplier-wallet-management-e2e.ts",
    "test:api:supplier-wallet:e2e:verbose": "VERBOSE=true pnpm dlx tsx scripts/supplier-wallet-management-e2e.ts",
    "test:api:supplier-onboarding:e2e": "pnpm dlx tsx scripts/supplier-onboarding-api-gateway-e2e.ts",
    "test:api:supplier-onboarding:e2e:verbose": "VERBOSE=true pnpm dlx tsx scripts/supplier-onboarding-api-gateway-e2e.ts",
    "test:api:supplier-management:phase2-e2e": "pnpm dlx tsx scripts/supplier-management-phase2-e2e.ts",
    "test:api:supplier-management:phase2-e2e:verbose": "VERBOSE=true pnpm dlx tsx scripts/supplier-management-phase2-e2e.ts",
    "test:api:supplier-management:phase3-payment-gateway": "pnpm dlx tsx scripts/phase3-payment-gateway-e2e.ts",
    "test:api:supplier-management:phase3-payment-gateway:verbose": "VERBOSE=true pnpm dlx tsx scripts/phase3-payment-gateway-e2e.ts",
    "test:api:supplier-wallet:comprehensive": "npm run test:api:supplier-wallet:e2e && npm run test:api:wallet:orchestrator",
    "test:api:marketplace:transactions": "pnpm dlx tsx scripts/marketplace-transaction-orchestrator.ts",
    "test:api:marketplace:transactions:verbose": "VERBOSE=true pnpm dlx tsx scripts/marketplace-transaction-orchestrator.ts",
    "test:fx:integration": "pnpm dlx tsx scripts/test-fx-integration.ts",
    "test:fx:integration:verbose": "VERBOSE=true pnpm dlx tsx scripts/test-fx-integration.ts",
    "test:e2e:booking:fx": "pnpm dlx tsx scripts/test-e2e-booking-fx.ts",
    "test:e2e:booking:fx:verbose": "VERBOSE=true pnpm dlx tsx scripts/test-e2e-booking-fx.ts",
    "test:fx:advanced": "pnpm dlx tsx scripts/test-fx-advanced.ts",
    "test:fx:advanced:verbose": "pnpm dlx tsx scripts/test-fx-advanced.ts verbose",
    "test:fx:advanced:load": "pnpm dlx tsx scripts/test-fx-advanced.ts load",
    "test:fx:advanced:edge": "pnpm dlx tsx scripts/test-fx-advanced.ts edge",
    "test:fx:advanced:all": "pnpm dlx tsx scripts/test-fx-advanced.ts all",
    "test:fx:currencies": "pnpm dlx tsx scripts/test-fx-currency-expansion.ts",
    "test:fx:currencies:verbose": "pnpm dlx tsx scripts/test-fx-currency-expansion.ts verbose",
    "test:wallet:load": "pnpm dlx tsx scripts/wallet-load-test.ts",
    "test:wallet:load:light": "LOAD_LEVEL=light pnpm dlx tsx scripts/wallet-load-test.ts",
    "test:wallet:load:normal": "LOAD_LEVEL=normal pnpm dlx tsx scripts/wallet-load-test.ts",
    "test:wallet:load:peak": "LOAD_LEVEL=peak pnpm dlx tsx scripts/wallet-load-test.ts",
    "test:payment:gateway": "pnpm dlx tsx scripts/payment-gateway-e2e-tests.ts",
    "test:payment:gateway:verbose": "VERBOSE=true pnpm dlx tsx scripts/payment-gateway-e2e-tests.ts",
    "start:wallet:api": "pnpm dlx tsx scripts/mock-wallet-api.ts",
    "test:api:integration": "ts-node scripts/test-api-integration.ts",
    "test:api:offers": "ts-node scripts/test-duffel-offer-requests.ts",
    "test:api:offers:integration": "ts-node scripts/test-duffel-offer-requests-integration.ts",
    "test:api:offers:validate": "ts-node scripts/validate-duffel-offers.ts",
    "test:api:duffel:orders": "ts-node scripts/test-duffel-orders.ts",
    "test:api:duffel:orders:e2e": "ts-node scripts/test-duffel-orders-e2e.ts",
    "test:api:combined-payment": "ts-node scripts/test-combined-payment-api-manager.ts",
    "test:api:combined-payment:json": "ts-node scripts/test-combined-payment-api-manager.ts --output=json",
    "test:api:duffel:endpoints": "ts-node scripts/test-duffel-endpoints.ts",
    "test:api:duffel:endpoints:all": "ts-node scripts/test-duffel-endpoints.ts --all",
    "test:api:frontend:integration": "ts-node scripts/verify-duffel-frontend-integration.ts",
    "test:api:duffel-flight-integration": "cd apps/booking-engine && npm run test:api:duffel-flight-integration",
    "test:e2e:duffel-flights": "cd apps/booking-engine && npm run test:e2e:duffel-flights",
    "test:api:flight:confirmation-docs": "node scripts/verify-flight-confirmation-docs.cjs",
    "test:api:all": "npm run test:api:duffel && npm run test:api:liteapi && npm run test:api:integration && npm run test:api:offers:validate && npm run test:api:duffel:orders && npm run test:api:combined-payment && npm run test:api:duffel:endpoints",
    "test:pricing:integration": "ts-node scripts/test-pricing-integration.ts",
    "test:loyalty:integration": "ts-node scripts/test-loyalty-integration.ts",
    "test:pricing:loyalty:e2e": "ts-node scripts/test-pricing-loyalty-e2e.ts",
    "test:pricing:loyalty:all": "npm run test:pricing:integration && npm run test:loyalty:integration && npm run test:pricing:loyalty:e2e",
    "import-liteapi": "pnpm --filter @tripalfa/ingest-service run import-liteapi",
    "import-liteapi-hotels": "pnpm --filter @tripalfa/ingest-service run import-liteapi-hotels",
    "import-liteapi-reviews": "pnpm --filter @tripalfa/ingest-service run import-liteapi-reviews",
    "import-liteapi-reference": "pnpm --filter @tripalfa/ingest-service run import-liteapi-reference",
    "import-hotelbeds": "pnpm --filter @tripalfa/ingest-service run import-hotelbeds",
    "import-duffel": "pnpm --filter @tripalfa/ingest-service run import-duffel",
    "import-duffel-airlines": "pnpm --filter @tripalfa/ingest-service run import-duffel-airlines",
    "import-duffel-airports": "pnpm --filter @tripalfa/ingest-service run import-duffel-airports",
    "import-duffel-cities": "pnpm --filter @tripalfa/ingest-service run import-duffel-cities",
    "update-image-dimensions": "pnpm --filter @tripalfa/ingest-service run update-image-dimensions",
    "seed-currencies": "pnpm --filter @tripalfa/ingest-service run seed-currencies",
    "postinstall": "prisma generate --schema=database/prisma/schema.prisma",
    "lint:security": "eslint . --ext .ts,.tsx --rule 'no-restricted-syntax: [error, {selector: BinaryExpression[operator=\"||\"][left.object.name=\"process\"][left.property.name=\"env\"] > Literal[value=\"\"], message: \"Environment variable fallback detected - use explicit validation\"}]'",
    "lint:no-fallbacks": "eslint . --ext .ts,.tsx --no-eslintrc --parser @typescript-eslint/parser --plugin no-restricted-syntax --rule 'no-restricted-syntax: [error, {selector: BinaryExpression[operator=\"||\"][left.type=\"MemberExpression\"][left.object.name=\"process\"] > Literal, message: \"process.env fallback pattern detected\"}]'"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client-runtime-utils": "^7.4.2",
    "@tanstack/react-query": "^5.90.21",
    "@types/node-fetch": "^2.6.13",
    "axios": "^1.6.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "pg": "^8.11.0",
    "resend": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "pnpm": {
    "overrides": {
      "form-data": "^4.0.4",
      "hono": "^4.11.10",
      "lodash": "^4.17.23",
      "qs": "^6.14.1",
      "minimatch": ">=9.0.7",
      "esbuild": ">=0.25.0"
    }
  }
}
