{
  "name": "tripalfa",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "apps/b2b-admin/server",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=api-gateway & npm run dev --workspace=booking-engine",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"apps/**/src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "prepare": "husky install",
    "db:generate": "cd database/prisma && prisma generate",
    "db:migrate": "cd database/prisma && prisma migrate dev",
    "db:push": "cd database/prisma && prisma db push",
    "test:api": "ts-node scripts/comprehensive-api-testing.ts",
    "test:api:hotelston": "ts-node scripts/test-hotelston-api.ts",
    "test:api:innstant": "ts-node scripts/test-innstant-api.ts",
    "test:api:duffel": "ts-node scripts/test-duffel-api.ts",
    "test:api:amadeus": "ts-node scripts/test-amadeus-api.ts"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcryptjs": "^2.4.6",
    "@types/dotenv": "^6.1.1",
    "@types/expect": "^1.20.4",
    "@types/express": "^4.17.25",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.14",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.19.31",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/pretty-format": "^20.0.1",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/string-similarity": "^4.0.2",
    "@typescript-eslint/eslint-plugin": "8.54.0",
    "@typescript-eslint/parser": "8.54.0",
    "dlv": "^1.1.3",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "expect": "^30.2.0",
    "glob": "^13.0.0",
    "husky": "^8.0.3",
    "lint-staged": "^16.2.7",
    "pg-protocol": "^1.11.0",
    "prettier": "^2.8.8",
    "pretty-format": "^30.2.0",
    "prisma": "^6.19.2",
    "tailwindcss": "3.4.19",
    "ts-morph": "^27.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "apps/**/src/**/*.{ts,tsx,js,jsx}": [
      "npm run lint --workspaces --if-present --silent",
      "npm run format --silent",
      "git add"
    ]
  },
  "dependencies": {
    "@nestjs/swagger": "^11.2.5",
    "@prisma/adapter-pg": "^6.19.2",
    "@prisma/client": "^6.19.2",
    "autoprefixer": "^10.4.23",
    "axios": "^1.13.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "debug": "^4.4.3",
    "dotenv": "^17.2.3",
    "eslint": "9.39.2",
    "express": "^5.2.1",
    "lucide-react": "0.462.0",
    "multer": "2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "7.0.12",
    "pg": "^8.11.3",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.12.0",
    "string-similarity": "^4.0.4",
    "vite": "7.3.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "@types/express-serve-static-core": "4.17.41",
    "http-proxy-middleware": "2.0.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
