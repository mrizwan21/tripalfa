# TripAlfa Unified Database URLs
# Copy this file to .env.services and replace placeholders with actual credentials
# IMPORTANT: Never commit .env.services to version control

# Application data (single Neon database: neondb)
DATABASE_URL="postgresql://neondb_owner:<DB_PASSWORD>@<NEON_POOLED_HOST>/neondb?sslmode=require&pgbouncer=true&connection_limit=20"
DIRECT_DATABASE_URL="postgresql://neondb_owner:<DB_PASSWORD>@<NEON_DIRECT_HOST>/neondb?sslmode=require"

# Local Docker static reference database (hotel + flight static data)
STATIC_DATABASE_URL="postgresql://postgres:postgres@host.docker.internal:5433/staticdatabase"

# LiteAPI Configuration
LITEAPI_BASE_URL="https://api.liteapi.travel/v3.0"
LITEAPI_API_KEY="your-liteapi-api-key-here"
