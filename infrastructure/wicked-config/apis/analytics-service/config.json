{
  "api": {
    "upstream_url": "http://host.docker.internal:3006",
    "request_path": "/analytics",
    "strip_uri": true,
    "preserve_host": false
  },
  "plugins": [
    {
      "config": {
        "key_names": ["apikey"],
        "hide_credentials": true
      },
      "name": "key-auth"
    }
  ]
}
