# Pylint ignore file
# This file tells pylint to skip non-Python files

Dockerfile
**/Dockerfile
**/Dockerfile.*
docker-compose*.yml
docker-compose*.yaml
services/**/Dockerfile
services/booking-service/Dockerfile

# TypeScript/JavaScript files - Pylint is a Python linter and cannot parse these
**/*.ts
**/*.tsx
**/*.js
**/*.jsx
**/*.mjs
**/*.cjs

# Configuration files
**/tsconfig.json
**/tsconfig.*.json
**/package.json
**/vite.config.ts
**/vite.config.js
**/.eslintrc.js
**/.eslintrc.cjs
**/.eslintrc.mjs

# Shell scripts - Pylint is a Python linter and cannot parse these
**/*.sh

# Specific service files that cause parsing issues
services/api-gateway/src/index.ts
services/api-gateway/src/**/*.ts

# Specific tsconfig.json files
apps/booking-engine/tsconfig.json
