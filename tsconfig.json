{
  "compilerOptions": {
    "target": "ES2020",
    "module": "node16",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@tripalfa/static-data": [
        "packages/static-data/src"
      ]
    },
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "./types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}