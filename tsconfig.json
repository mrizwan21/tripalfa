{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "Node16",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "./types"]
  },
  "include": [
    "./types/**/*.d.ts",
    "services/**/*",
    "packages/**/*",
    "apps/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ],
  "references": [
    {
      "path": "packages/shared-utils"
    },
    {
      "path": "packages/wallet"
    },
    {
      "path": "packages/rules"
    },
    {
      "path": "packages/notifications"
    },
    {
      "path": "packages/api-clients"
    },
    {
      "path": "packages/shared-database"
    },
    {
      "path": "services/booking-service"
    },
    {
      "path": "services/payment-service"
    },
    {
      "path": "services/user-service"
    },
    {
      "path": "services/notification-service"
    },
    {
      "path": "services/organization-service"
    },
    {
      "path": "services/rule-engine-service"
    },
    {
      "path": "services/kyc-service"
    },
    {
      "path": "services/marketing-service"
    },
    {
      "path": "services/wallet-service"
    }
  ]
}
