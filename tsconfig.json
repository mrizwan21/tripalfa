{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "types": []
  },
  "include": [
    "./types/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ],
  "references": [
    {
      "path": "packages/shared-utils"
    },
    {
      "path": "packages/wallet"
    },
    {
      "path": "packages/rules"
    },
    {
      "path": "packages/notifications"
    },
    {
      "path": "packages/static-data"
    },
    {
      "path": "packages/api-clients"
    },
    {
      "path": "packages/shared-database"
    },
    {
      "path": "services/booking-service"
    },
    {
      "path": "services/payment-service"
    },
    {
      "path": "services/user-service"
    },
    {
      "path": "services/notification-service"
    },
    {
      "path": "services/organization-service"
    },
    {
      "path": "services/rule-engine-service"
    },
    {
      "path": "services/kyc-service"
    },
    {
      "path": "services/marketing-service"
    }
  ]
}
