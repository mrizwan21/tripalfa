# Neon Database & Docker Deployment Environment Variables
# Copy this file to .env.neon and customize with your values

# ============================================
# Neon Database Connection
# ============================================
# Get your connection string from: https://console.neon.tech/app/projects
# Format: postgresql://user:password@ep-xxxx.region.neon.tech/database_name?sslmode=require
NEON_DATABASE_URL=postgresql://<username>:<password>@<host>:<port>/<database>?sslmode=require

# ============================================
# Service Port Configuration
# ============================================
# API Gateway (main entry point)
API_GATEWAY_PORT=3000

# Notification Service
NOTIFICATION_SERVICE_PORT=3001

# Rule Engine Service
RULE_ENGINE_SERVICE_PORT=3002

# ============================================
# Environment Configuration
# ============================================
# Environment: development | production | test
NODE_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=info

# ============================================
# Service URLs (for Docker Internal Communication)
# ============================================
# These are used for inter-service communication within Docker
# Do NOT change unless you modify docker-compose configuration

NOTIFICATION_SERVICE_URL=http://notification-service:3001
RULE_ENGINE_SERVICE_URL=http://rule-engine-service:3002
API_GATEWAY_URL=http://api-gateway:3000

# ============================================
# Redis Configuration
# ============================================
# Redis cache for sessions, caching, and queue management
REDIS_URL=redis://redis-cache:6379

# ============================================
# Database Connection Pooling
# ============================================
# Number of database connections to maintain
DATABASE_POOL_SIZE=20

# Maximum additional connections to create when pool is exhausted
DATABASE_MAX_OVERFLOW=5

# ============================================
# Rate Limiting Configuration
# ============================================
# Time window for rate limiting (milliseconds)
RATE_LIMIT_WINDOW=60000

# Maximum requests allowed per window
RATE_LIMIT_MAX=100

# ============================================
# Logging Configuration
# ============================================
# Enable structured logging (JSON format)
STRUCTURED_LOGGING=true

# Debug patterns to enable
# Example: "notification-service:*,rule-engine-service:*"
DEBUG=

# ============================================
# API Configuration
# ============================================
# API request timeout (milliseconds)
API_REQUEST_TIMEOUT=30000

# API request max body size
API_MAX_BODY_SIZE=10mb

# ============================================
# Security Configuration
# ============================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API authentication enabled
AUTH_ENABLED=true

# ============================================
# Feature Flags
# ============================================
# Enable notification service
NOTIFICATIONS_ENABLED=true

# Enable rule engine service
RULES_ENGINE_ENABLED=true

# Enable analytics
ANALYTICS_ENABLED=true

# ============================================
# B2B Admin UI Configuration
# ============================================
# API URL for frontend
VITE_API_URL=http://localhost:3000

# ============================================
# Database Schema Notes
# ============================================
# The following Prisma models are created in the database:
# - Rule (rule definitions)
# - RuleExecution (execution tracking)
# - RuleAnalysis (conflict analysis)
# - NotificationCampaign (campaign management)
# - NotificationCampaignExecution (execution tracking)
# - NotificationChannelConfig (channel configuration)

# ============================================
# Neon-Specific Configuration
# ============================================
# Neon branch to use (default: main)
NEON_BRANCH=main

# Enable connection pooling (PgBouncer)
NEON_POOLING_ENABLED=true

# Auto-suspend inactive branch after (seconds, 0 = disabled)
# Recommended: 300 (5 minutes) for development
NEON_AUTO_SUSPEND_SECONDS=300

# ============================================
# Deployment Configuration
# ============================================
# Docker registry (optional, for pushing images)
DOCKER_REGISTRY=

# Service replica count (Docker Swarm / Kubernetes)
REPLICA_COUNT=1

# ============================================
# Monitoring & Observability
# ============================================
# Enable metrics collection
METRICS_ENABLED=true

# Metrics export endpoint (optional)
METRICS_EXPORT_URL=

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# DataDog API key (optional)
DATADOG_API_KEY=

# ============================================
# Backup & Recovery
# ============================================
# Enable automated database backups
BACKUPS_ENABLED=true

# Backup retention days
BACKUP_RETENTION_DAYS=30

# ============================================
# Example Neon Connection Strings
# ============================================
# Development (with SSL):
# postgresql://user:password@ep-super-river-123456.us-east-1.neon.tech/tripalfa_dev?sslmode=require

# Production (with SSL):
# postgresql://user:password@ep-super-river-789012.us-east-1.neon.tech/tripalfa_prod?sslmode=require

# With pooling via PgBouncer:
# postgresql://user:password@ep-super-river-123456-pooler.us-east-1.neon.tech/tripalfa_dev?sslmode=require

# ============================================
# Setup Instructions
# ============================================
# 1. Go to https://console.neon.tech
# 2. Create a new project or use existing
# 3. Copy your connection string from project settings
# 4. Paste into NEON_DATABASE_URL above
# 5. Run: docker-compose -f docker-compose.neon.yml up -d

# ============================================
# Useful Commands
# ============================================
# Load environment:
# source .env.neon

# Start Docker deployment:
# docker-compose -f docker-compose.neon.yml up -d

# View logs:
# docker-compose -f docker-compose.neon.yml logs -f

# Stop services:
# docker-compose -f docker-compose.neon.yml down

# Database migrations:
# docker-compose -f docker-compose.neon.yml exec notification-service npx prisma migrate deploy

# Prisma Studio (local only):
# npx prisma studio
