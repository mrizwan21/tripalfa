# TripAlfa Environment Configuration - NEON Cloud Setup Example

# ==========================================
# DATABASE CONFIGURATION - HYBRID SETUP
# ==========================================

# ===== NEON CLOUD DATABASE (Application Data - Transactions) =====
# Once you have your NEON credentials, update these values:

DIRECT_DATABASE_URL="postgresql://default:YOUR_PASSWORD@your-neon-host.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://default:YOUR_PASSWORD@your-neon-host.neon.tech/neondb?sslmode=require"

# ===== LOCAL POSTGRESQL (Static Data - Hotels, Flights, Reference) =====
# Keep this pointing to local PostgreSQL running on your machine

STATIC_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/staticdatabase"

# ===== DATABASE CONFIGURATION OPTIONS =====
# Optional: Adjust connection pooling if needed
DB_POOL_MAX=20
DB_SSL_REJECT_UNAUTHORIZED=true

# ==========================================
# SERVICE CONFIGURATION
# ==========================================

API_GATEWAY_URL="http://localhost:3000"

# Backend Service Ports (Local Machine)
USER_SERVICE_PORT=3003
BOOKING_SERVICE_PORT=3001
PAYMENT_SERVICE_PORT=3007
ORGANIZATION_SERVICE_PORT=3006
WALLET_SERVICE_PORT=3008
NOTIFICATION_SERVICE_PORT=3009
RULE_ENGINE_SERVICE_PORT=3010
KYC_SERVICE_PORT=3011
MARKETING_SERVICE_PORT=3012
B2B_ADMIN_SERVICE_PORT=3020
BOOKING_ENGINE_SERVICE_PORT=3021

# Frontend App Ports (Local Machine)
B2B_ADMIN_PORT=5173
BOOKING_ENGINE_PORT=5174

# ==========================================
# EXTERNAL API CONFIGURATION
# ==========================================

# Duffel API (Flight Search)
DUFFEL_API_KEY="your_duffel_api_key"
DUFFEL_API_BASE_URL="https://api.duffel.com"

# LiteAPI (Hotel Search)
LITEAPI_BASE_URL="https://api.liteapi.travel"
LITEAPI_KEY="your_liteapi_key"

# Stripe (Payments)
STRIPE_SECRET_KEY="sk_test_your_stripe_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Resend (Email Service)
RESEND_API_KEY="your_resend_api_key"

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================

JWT_SECRET="your_super_secure_jwt_secret_key_change_in_production"
JWT_EXPIRES_IN="24h"

# CORS Origins (comma-separated)
CORS_ORIGIN="http://localhost:5173,http://localhost:5174,https://yourdomain.com"

# ==========================================
# REDIS CONFIGURATION
# ==========================================

REDIS_URL="redis://localhost:6379"

# ==========================================
# LOGGING & MONITORING
# ==========================================

LOG_LEVEL="debug"
HEALTH_CHECK_PORT=3000
HEALTH_CHECK_PATH="/health"

# ==========================================
# DEVELOPMENT SETTINGS
# ==========================================

NODE_ENV="development"
HOT_RELOAD="true"
DEBUG="*"

# Set to 1 if running services in Docker containers (uses container names as hostnames)
# Leave unset or set to 0 for local development (uses localhost)
USE_DOCKER_NETWORK=0

# ==========================================
# SERVICE-SPECIFIC CONFIGURATION
# ==========================================

USER_SERVICE_URL="http://localhost:3003"
USER_SERVICE_TIMEOUT=30000

BOOKING_SERVICE_URL="http://localhost:3001"
BOOKING_SERVICE_TIMEOUT=60000

PAYMENT_SERVICE_URL="http://localhost:3007"
PAYMENT_SERVICE_TIMEOUT=120000

NOTIFICATION_SERVICE_URL="http://localhost:3009"
NOTIFICATION_SERVICE_TIMEOUT=10000

RULE_ENGINE_SERVICE_URL="http://localhost:3010"
RULE_ENGINE_SERVICE_TIMEOUT=30000

# ==========================================
# DEVELOPMENT TOOLS
# ==========================================

API_MANAGER_URL="http://localhost:3000"
EXTERNAL_API_TIMEOUT=30000

RETRY_ATTEMPTS=3
RETRY_DELAY=1000

DEBUG_PORT=9229
WATCH_MODE="true"
AUTO_RESTART="true"

# ==========================================
# HOW TO USE THIS FILE
# ==========================================
# 1. Copy this file: cp .env.neon.example .env.local
# 2. Replace placeholder values with your actual credentials:
#    - DIRECT_DATABASE_URL: Your NEON connection string from neon.tech
#    - DUFFEL_API_KEY: From duffel.com dashboard
#    - LITEAPI_KEY: From liteapi.travel dashboard
#    - STRIPE_SECRET_KEY: From stripe.com dashboard
#    - JWT_SECRET: Generate a strong random string
# 3. Keep STATIC_DATABASE_URL pointing to local PostgreSQL
# 4. Save as .env.local (don't commit to git)
# 5. Run: bash scripts/start-local-dev.sh
