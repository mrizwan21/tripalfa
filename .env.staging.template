# Payment Gateway Configuration - Staging Environment
# Copy this file to .env.staging and fill in actual values from your processor accounts

# ============================================================================
# STRIPE CONFIGURATION (test mode)
# ============================================================================
# Register at: https://dashboard.stripe.com/register
# Test Mode Dashboard: https://dashboard.stripe.com/test/dashboard

# Stripe API Key (starts with sk_test_)
# Find at: Dashboard > Developers > API keys
STRIPE_API_KEY=sk_test_YOUR_TEST_KEY_HERE

# Stripe Webhook Signing Secret (starts with whsec_)
# Find at: Dashboard > Developers > Webhooks > Select endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_test_YOUR_SECRET_HERE

# Stripe Publishable Key (optional, for reference)
# Find at: Dashboard > Developers > API keys
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# ============================================================================
# PAYPAL CONFIGURATION (sandbox mode)
# ============================================================================
# Register at: https://developer.paypal.com/signin
# Sandbox Dashboard: https://sandbox.paypal.com

# PayPal Client ID (sandbox)
# Find at: Dashboard > Apps & Credentials > Sandbox > Client ID
PAYPAL_CLIENT_ID=YOUR_SANDBOX_CLIENT_ID_HERE

# PayPal Client Secret (sandbox)
# Find at: Dashboard > Apps & Credentials > Sandbox > Secret
PAYPAL_CLIENT_SECRET=YOUR_SANDBOX_CLIENT_SECRET_HERE

# PayPal API Mode (sandbox or live)
# Use 'sandbox' for testing, 'live' for production
PAYPAL_API_MODE=sandbox

# PayPal Webhook ID (for event verification)
# Find at: Dashboard > Apps & Credentials > Sandbox > Webhook ID
PAYPAL_WEBHOOK_ID=YOUR_WEBHOOK_ID_HERE

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string for payment transaction storage

# Local staging (Docker)
DATABASE_URL=postgresql://tripalfa_user:tripalfa_pass@localhost:5432/tripalfa_staging

# Cloud staging (NEON/Railway/other)
# DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require

# ============================================================================
# WEBHOOK CONFIGURATION
# ============================================================================
# URLs where payment processors send webhook events

# Your staging server URL (used by processors to send webhooks)
STAGING_SERVER_URL=https://staging.tripalfa.com

# Webhook endpoints (will be: https://staging.tripalfa.com/webhooks/stripe, etc.)
STRIPE_WEBHOOK_ENDPOINT=/webhooks/stripe
PAYPAL_WEBHOOK_ENDPOINT=/webhooks/paypal

# Webhook retry policy
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_MS=5000

# ============================================================================
# PAYMENT GATEWAY SERVICE CONFIGURATION
# ============================================================================

# Default currency for transactions
DEFAULT_CURRENCY=USD

# Supported currencies
SUPPORTED_CURRENCIES=USD,EUR,GBP,AED,JPY,SGD,CAD

# Payment processing retry policy
PAYMENT_RETRY_MAX_ATTEMPTS=3
PAYMENT_RETRY_DELAY_MS=1000

# Transaction timeout (milliseconds)
TRANSACTION_TIMEOUT_MS=30000

# ============================================================================
# WALLET SERVICE CONFIGURATION
# ============================================================================
# (If integrating payments with wallet system)

# Wallet service URL
WALLET_SERVICE_URL=http://localhost:3001

# Wallet update endpoint
WALLET_UPDATE_ENDPOINT=/api/wallet/update-balance

# ============================================================================
# MONITORING & ALERTING
# ============================================================================

# Sentry (error tracking) - optional
SENTRY_DSN=https://your-key@sentry.io/your-project-id

# DataDog (performance monitoring) - optional
DATADOG_API_KEY=your_datadog_api_key_here
DATADOG_SITE=datadoghq.com

# Alert thresholds
ALERT_FAILED_PAYMENTS_THRESHOLD=10  # Alert if 10+ consecutive failures
ALERT_PAYMENT_LATENCY_MS=5000       # Alert if payment > 5s
ALERT_ERROR_RATE_THRESHOLD=0.05     # Alert if error rate > 5%

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Rate limiting
RATE_LIMIT_PAYMENTS_PER_MINUTE=60
RATE_LIMIT_REFUNDS_PER_MINUTE=10
RATE_LIMIT_WEBHOOKS_PER_MINUTE=1000

# IP whitelist (comma-separated, optional)
# Only allow webhooks from these IPs
# Find Stripe IPs at: https://stripe.com/files/ips/stripe_ip_addresses.json
# Find PayPal IPs at: https://developer.paypal.com/docs/platforms/webhooks/webhook-event-names/
STRIPE_WEBHOOK_IP_WHITELIST=
PAYPAL_WEBHOOK_IP_WHITELIST=

# API key encryption (for storing sensitive data)
ENCRYPTION_KEY=your-256-bit-hex-key-here

# Session security
SESSION_SECRET=your-random-session-secret-here
CSRF_TOKEN_SECRET=your-random-csrf-secret-here

# ============================================================================
# LOGGING & DEBUGGING
# ============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable verbose logging for payment processing
VERBOSE_PAYMENT_LOGS=false

# Log payment transactions to file
LOG_TRANSACTIONS_TO_FILE=true
LOG_FILE_PATH=./logs/payments.log

# ============================================================================
# TESTING CONFIGURATION
# ============================================================================

# Enable test mode (uses mock responses)
TEST_MODE=false

# Stripe test card numbers (for manual testing)
# Success: 4242 4242 4242 4242
# Decline: 4000 0000 0000 0002
# 3D Secure: 4000 0025 0000 3155

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Redis (if using for idempotency caching)
REDIS_URL=redis://localhost:6379/1

# Cache TTL for transactions (seconds)
TRANSACTION_CACHE_TTL=3600

# ============================================================================
# DEPLOYMENT INFORMATION
# ============================================================================

# Environment name
ENVIRONMENT=staging

# Application version
APP_VERSION=4.2.0

# Deployment timestamp (auto-set by CI/CD)
DEPLOYED_AT=

# Feature flags
FEATURE_PAYMENT_PROCESSING=true
FEATURE_WEBHOOK_HANDLING=true
FEATURE_REFUND_PROCESSING=true
FEATURE_MULTI_CURRENCY=true

# ============================================================================
# NOTES FOR SETUP
# ============================================================================

# 1. STRIPE SETUP:
#    - Create test API keys at https://dashboard.stripe.com/test/apikeys
#    - Create webhook endpoint at Dashboard > Developers > Webhooks
#    - Add events: payment_intent.succeeded, payment_intent.payment_failed, charge.refunded
#    - Copy webhook signing secret

# 2. PAYPAL SETUP:
#    - Create sandbox app at https://developer.paypal.com/dashboard/apps/sandbox
#    - Get Client ID and Secret from App Details
#    - Log in to https://sandbox.paypal.com with sandbox account
#    - Set up IPNs (Webhooks) in sandbox account settings

# 3. NGINX CONFIGURATION:
#    - Configure reverse proxy to forward requests to payment service
#    - SSL/TLS certificates for https://staging.tripalfa.com
#    - Rate limiting at reverse proxy level

# 4. DATABASE:
#    - Run migration: npm run db:migrate
#    - Create payment_transactions table
#    - Create webhook_events audit table

# 5. MONITORING:
#    - Set up error tracking (Sentry)
#    - Configure performance monitoring (DataDog)
#    - Create alerting rules for payment failures

# 6. SECURITY:
#    - Configure IP whitelisting for webhooks
#    - Enable SSL/TLS everywhere
#    - Rotate API keys regularly
#    - Use secrets manager for sensitive values

# ============================================================================

# Example fully configured (do NOT use in production):
# 
# STRIPE_API_KEY=sk_test_51234567890abcdefghijklmnop
# STRIPE_WEBHOOK_SECRET=whsec_test_1234567890abcdef
# PAYPAL_CLIENT_ID=AaBbCcDdEeFfGgHhIiJjKk
# PAYPAL_CLIENT_SECRET=EeFfGgHhIiJjKkLlMmNnOoPp
# STAGING_SERVER_URL=https://staging.tripalfa.com
# DATABASE_URL=postgresql://tripalfa:secure_pass@db-staging.example.com:5432/tripalfa_staging
