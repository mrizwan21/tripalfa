{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignore": [
    "apps/booking-engine/src/components/**",
    "apps/booking-engine/src/api/**",
    "apps/booking-engine/src/hooks/**",
    "apps/booking-engine/src/pages/FlightSearchLoading.tsx",
    "apps/booking-engine/src/pages/HotelSearchLoading.tsx",
    "apps/booking-engine/src/pages/index.ts",
    "apps/booking-engine/src/lib/apiClient.ts",
    "apps/booking-engine/src/lib/authToken.ts",
    "apps/booking-engine/src/lib/innstant-api.ts",
    "apps/booking-engine/src/lib/notificationIntegration.ts",
    "apps/booking-engine/src/lib/constants/seo.ts",
    "apps/booking-engine/src/lib/examples/**",
    "apps/booking-engine/src/lib/api.ts",
    "apps/booking-engine/src/lib/constants.ts",
    "apps/booking-engine/src/lib/currency.ts",
    "apps/booking-engine/src/lib/hooks.ts",
    "apps/booking-engine/src/lib/translation.ts",
    "apps/booking-engine/src/lib/ancillary-types.ts",
    "apps/booking-engine/src/lib/srs-types.ts",
    "apps/booking-engine/src/lib/constants/theme.ts",
    "apps/booking-engine/src/services/**",
    "apps/booking-engine/src/types/**",
    "**/src/swagger.ts",
    "**/src/docs/**",
    "**/src/middlewares/**",
    "**/src/middleware/**",
    "**/src/utils/**",
    "packages/notification-service/src/**",
    "packages/booking-service/src/**",
    "packages/booking-engine-service/src/static-db.ts",
    "packages/booking-engine-service/src/middlewares/**",
    "packages/booking-engine-service/src/utils/**",
    "packages/ui-components/src/**",
    "packages/shared-utils/src/cache-manager.ts",
    "packages/shared-utils/src/featureFlags.ts",
    "packages/shared-utils/src/monitoring.ts",
    "packages/shared-utils/tracing.ts",
    "packages/shared-utils/logger.ts",
    "packages/shared-types/src/static.types.ts",
    "packages/shared-types/src/test.ts",
    "packages/shared-types/src/hotel-deals.ts",
    "packages/api-clients/src/liteapiclient.ts",
    "packages/api-clients/src/notificationservice.ts",
    "packages/rules/src/services/**",
    "packages/message-queue/src/backends/**",
    "packages/resilience/src/**",
    "packages/fusionauth-client/src/types.ts",
    "packages/static-data/src/scripts/**",
    "packages/shared-database/src/index.ts",
    "packages/static-data/src/frontend-index.ts",
    "vitest.config.ts",
    "vitest.workspace.ts"
  ],
  "ignoreBinaries": ["prisma", "playwright"],
  "ignoreExportsUsedInFile": true,
  "ignoreDependencies": [
    "@types/mapbox-gl",
    "stylelint",
    "stylelint-config-standard",
    "stylelint-config-tailwindcss",
    "@types/react-dom",
    "husky",
    "markdownlint-cli",
    "ts-node",
    "@types/uuid",
    "@types/nodemailer",
    "@typescript-eslint/eslint-plugin",
    "@typescript-eslint/parser",
    "ts-jest",
    "vitest",
    "nodemon",
    "@types/ioredis",
    "@types/swagger-ui-express",
    "@types/swagger-jsdoc",
    "@types/bcryptjs",
    "@vitest/coverage-v8",
    "@types/supertest",
    "openapi3-ts",
    "@types/jsonwebtoken",
    "@types/multer",
    "prisma",
    "vite",
    "@babel/preset-env",
    "@babel/preset-typescript",
    "next-themes",
    "@types/react",
    "@tanstack/react-query",
    "node-cron",
    "node-fetch",
    "@prisma/client",
    "@tripalfa/shared-types",
    "@tripalfa/shared-utils",
    "@tripalfa/shared-database",
    "@tripalfa/wallet",
    "@tripalfa/api-clients",
    "@tripalfa/static-data",
    "axios",
    "eslint",
    "lint-staged",
    "jsonwebtoken",
    "node-cache",
    "express-rate-limit",
    "winston",
    "@duffel/api",
    "typescript",
    "framer-motion",
    "lucide-react",
    "sonner",
    "recharts",
    "zod",
    "react-hook-form",
    "@hookform/resolvers",
    "@mui/material",
    "@tanstack/react-table",
    "react-router-dom",
    "react",
    "react-dom",
    "postcss",
    "tailwindcss",
    "autoprefixer",
    "@tailwindcss/postcss",
    "@vitejs/plugin-react",
    "@playwright/test",
    "jsdom",
    "@modelcontextprotocol/sdk",
    "@phosphor-icons/react",
    "@radix-ui/react-dropdown-menu",
    "@radix-ui/react-popover",
    "tailwind-merge",
    "clsx",
    "date-fns",
    "mapbox-gl",
    "@prisma/client-runtime-utils",
    "dotenv",
    "express",
    "pg",
    "amqplib",
    "pino",
    "@tanstack/react-query-devtools",
    "@tripalfa/shared-openapi",
    "swagger-jsdoc",
    "cors",
    "@node-rs/bcrypt",
    "express-validator",
    "stripe",
    "uuid",
    "redis",
    "puppeteer",
    "helmet",
    "morgan",
    "resend",
    "multer",
    "joi",
    "@tripalfa/ui-components"
  ],
  "workspaces": {
    ".": {
      "entry": ["*.config.ts"],
      "project": ["types/**/*.d.ts"]
    },
    "apps/booking-engine": {
      "entry": ["src/main.tsx", "src/App.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/b2b-portal": {
      "entry": ["src/main.tsx", "src/App.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/call-center-portal": {
      "entry": ["src/main.tsx", "src/App.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/super-admin-portal": {
      "entry": ["src/main.tsx", "src/AppRouter.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/*": {
      "entry": ["src/index.ts", "index.ts"],
      "project": ["**/*.{ts,tsx}", "!dist/**"]
    },
    "packages/ui-components": {
      "entry": ["src/index.ts", "index.ts"],
      "project": ["**/*.{ts,tsx}", "!dist/**", "!optics/**"]
    },
    "packages/shared-types": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/shared-utils": {
      "entry": ["src/index.ts", "index.ts"],
      "project": ["*.ts", "src/**/*.ts", "!dist/**"]
    },
    "packages/static-data": {
      "entry": ["src/server.ts", "src/scheduler.ts", "src/frontend-index.ts"],
      "project": ["src/**/*.ts"]
    }
  }
}
