# =========================================================
# TripAlfa Unified Environment Configuration
# =========================================================
#
# LOCAL DEVELOPMENT: Copy this file to .env
# DOCKER DEVELOPMENT: Copy this file to .env.docker
# For documentation, see: README.md
#
# CRITICAL: Never commit actual credentials to version control
# =========================================================

# =========================================================
# 1. DATABASE CONFIGURATION
# =========================================================
# TripAlfa requires TWO independent databases:
#
# A. APPLICATION DATABASE (Neon Cloud - Required for services)
#    Stores: users, bookings, payments, notifications, wallets,
#            kyc, organizations, rules, marketing, etc.
#    Get credentials from: https://console.neon.tech
#
# B. STATIC REFERENCE DATABASE (Local Docker Postgres - Required)
#    Stores: airports, airlines, cities, hotels, amenities, etc.
#    Docker service: postgres-static on port 5433
#    Default creds: user=postgres, pass=postgres

# Application Database (Neon)
# Pooled endpoint (recommended for serverless/lambda)
NEON_DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-XXX.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Direct endpoint (required for Prisma migrations)
DIRECT_NEON_DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-XXX.us-east-1.aws.neon.direct-connect.aws.neon.tech/neondb?sslmode=require"

# Static Reference Database (Local Docker)
# When running with docker-compose.local.yml:
STATIC_DATABASE_URL="postgresql://postgres:postgres@postgres-static:5432/staticdatabase?sslmode=disable"

# When running locally (pnpm dev):
# STATIC_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/staticdatabase"

# =========================================================
# 2. SERVICE CONFIGURATION
# =========================================================

NODE_ENV="development"
LOG_LEVEL="debug"

# API Gateway
PORT=3000
API_GATEWAY_PORT=3000
API_GATEWAY_URL="http://localhost:3000"

# Booking Service
BOOKING_SERVICE_PORT=3001
BOOKING_SERVICE_URL="http://localhost:3001"

# Static Data Service
STATIC_DATA_SERVICE_PORT=3002
STATIC_DATA_SERVICE_URL="http://localhost:3002"

# User Service
USER_SERVICE_PORT=3003
USER_SERVICE_URL="http://localhost:3003"

# Organization Service
ORGANIZATION_SERVICE_PORT=3006
ORGANIZATION_SERVICE_URL="http://localhost:3006"

# Payment Service
PAYMENT_SERVICE_PORT=3007
PAYMENT_SERVICE_URL="http://localhost:3007"

# Wallet Service
WALLET_SERVICE_PORT=3008
WALLET_SERVICE_URL="http://localhost:3008"

# Notification Service
NOTIFICATION_SERVICE_PORT=3009
NOTIFICATION_SERVICE_URL="http://localhost:3009"

# Rule Engine Service
RULE_ENGINE_SERVICE_PORT=3010
RULE_ENGINE_SERVICE_URL="http://localhost:3010"

# KYC Service
KYC_SERVICE_PORT=3011
KYC_SERVICE_URL="http://localhost:3011"

# Marketing Service
MARKETING_SERVICE_PORT=3012
MARKETING_SERVICE_URL="http://localhost:3012"

# B2B Admin App
B2B_ADMIN_PORT=3020

# Booking Engine App
BOOKING_ENGINE_PORT=3021

# =========================================================
# 3. REDIS CONFIGURATION
# =========================================================
REDIS_URL="redis://localhost:6379"
REDIS_HOST="redis"
REDIS_PORT=6379

# =========================================================
# 4. AUTHENTICATION & SECURITY
# =========================================================

# JWT Configuration
JWT_SECRET="development-secret-key-change-in-production"
JWT_EXPIRES_IN="24h"

# Session Configuration
SESSION_SECRET="session-secret-key-change-in-production"

# =========================================================
# 5. EXTERNAL API INTEGRATIONS
# =========================================================

# Duffel Flight API (https://duffel.com)
DUFFEL_API_KEY="your-duffel-api-key-here"
DUFFEL_BASE_URL="https://api.duffel.com"

# LiteAPI Hotel API (https://liteapi.travel)
LITEAPI_API_KEY="your-liteapi-api-key-here"
LITEAPI_BASE_URL="https://api.liteapi.travel/v3.0"

# Kiwi.com Integration
KIWI_AFFIL_ID="your-kiwi-affiliate-id"
KIWI_API_KEY="your-kiwi-api-key"
KIWI_PARTNER_ID="your-kiwi-partner-id"

# Amadeus Flight API
AMADEUS_CLIENT_ID="your-amadeus-client-id"
AMADEUS_CLIENT_SECRET="your-amadeus-client-secret"

# Innstant Hotel API
INNSTANT_API_KEY="your-innstant-api-key"

# =========================================================
# 6. PAYMENT & FINANCIAL
# =========================================================

# Stripe Configuration
STRIPE_SECRET_KEY="sk_test_your_stripe_key"
STRIPE_PUBLISHABLE_KEY="pk_test_your_stripe_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Payment Gateway
PAYMENT_GATEWAY_URL="http://localhost:3007"
PAYMENT_GATEWAY_API_KEY="your-payment-gateway-key"

# =========================================================
# 7. EMAIL & NOTIFICATIONS
# =========================================================

# Email Service
EMAIL_SERVICE_PROVIDER="sendgrid"  # or "mailgun", "smtp"
SENDGRID_API_KEY="your-sendgrid-key"
EMAIL_FROM="noreply@tripalfa.com"

# SMS Service
SMS_PROVIDER="twilio"  # or "nexmo"
TWILIO_ACCOUNT_SID="your-account-sid"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# =========================================================
# 8. STORAGE & CDN
# =========================================================

# AWS S3 / Object Storage
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
S3_BUCKET="tripalfa-development"
S3_URL="https://s3.amazonaws.com/tripalfa-development"

# =========================================================
# 9. MONITORING & ANALYTICS
# =========================================================

# Sentry Error Tracking
SENTRY_DSN="your-sentry-dsn"

# Google Analytics
GOOGLE_ANALYTICS_ID="your-google-analytics-id"

# =========================================================
# 10. KYC & VERIFICATION
# =========================================================

# IDenfy KYC Service
IDENFY_API_KEY="your-idenfy-api-key"
IDENFY_BASE_URL="https://api.idenfy.com"

# =========================================================
# 11. FEATURE FLAGS & CONFIGURATION
# =========================================================

# Feature Flags
ENABLE_FLIGHT_BOOKING=true
ENABLE_HOTEL_BOOKING=true
ENABLE_TRANSFER_BOOKING=true
ENABLE_WALLET_SYSTEM=true
ENABLE_PAYMENT_GATEWAY=true
ENABLE_KYC_VERIFICATION=true

# Database Features
ENABLE_QUERY_LOGGING=false
ENABLE_SLOW_QUERY_LOG=true
SLOW_QUERY_THRESHOLD_MS=1000

# =========================================================
# 12. DEVELOPMENT ONLY
# =========================================================

# Mock API Responses (for testing without external APIs)
USE_MOCK_DUFFEL=false
USE_MOCK_LITEAPI=false
USE_MOCK_PAYMENT_GATEWAY=false

# Debug Options
DEBUG_API_REQUESTS=false
DEBUG_DATABASE_QUERIES=false
DEBUG_AUTHENTICATION=false

# =========================================================
# 13. DOCKER-SPECIFIC (used by docker-compose.local.yml)
# =========================================================

# Only needed when running with Docker
# For local development without Docker, these are optional
DOCKER_POSTGRES_USER="postgres"
DOCKER_POSTGRES_PASSWORD="postgres"
DOCKER_POSTGRES_DB="staticdatabase"
DOCKER_REDIS_PASSWORD=""

# =========================================================
# SETUP INSTRUCTIONS
# =========================================================
#
# 1. LOCAL DEVELOPMENT (pnpm dev):
#    - Copy this file to .env
#    - Set NEON_DATABASE_URL and DIRECT_NEON_DATABASE_URL
#    - Set STATIC_DATABASE_URL to localhost:5433
#    - Fill in API keys for services you're testing
#    - Run: pnpm install && npm run db:generate && npm run dev
#
# 2. DOCKER DEVELOPMENT (docker-compose):
#    - Copy this file to .env.docker
#    - Set NEON_DATABASE_URL and DIRECT_NEON_DATABASE_URL
#    - Run: docker-compose -f docker-compose.local.yml up
#
# 3. QUICK START:
#    - Get Neon credentials from https://console.neon.tech
#    - Copy pooled endpoint to NEON_DATABASE_URL
#    - Copy direct endpoint to DIRECT_NEON_DATABASE_URL
#    - Run: cp .env.example .env.docker
#    - Run: docker-compose -f docker-compose.local.yml up
#
# =========================================================
