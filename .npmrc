# NPM/PNPM Configuration for better network handling
# These settings help with intermittent network issues during Docker builds

# Network timeout settings (in milliseconds)
network-timeout=600000
fetch-timeout=300000

# Retry settings - increased for better resilience
fetch-retries=10
fetch-retry-mintimeout=30000
fetch-retry-maxtimeout=300000
fetch-retry-factor=3

# Registry
registry=https://registry.npmjs.org/

# Enable offline mode as fallback
enable-pre-post-scripts=true

# Concurrent socket connections (increased for faster builds)
maxsockets=10
